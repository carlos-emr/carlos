  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s\\n' '⚠️ ENVIRONMENT CHECK: These Claude Code settings are configured for ISOLATED DEVCONTAINERS ONLY. The pre-approved permissions assume a sandboxed development environment with no real patient data (PHI). If running outside a devcontainer, review .claude/settings.json carefully.' 1>&2 2>/dev/null || printf '%s\\n' 'WARNING: ENVIRONMENT CHECK - Review .claude/settings.json for devcontainer-only permissions' 1>&2",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/inject-test-context.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/validate-sql-safety.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/validate-owasp-encoding.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
