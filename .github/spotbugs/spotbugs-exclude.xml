<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Exclude Filter for CARLOS EMR

  Suppresses known false positives and noisy patterns in legacy code
  while keeping all security-relevant and correctness detectors active.

  Reference: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ================================================================
         TEST CLASSES
         Exclude all test code from analysis.
         ================================================================ -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
    <Match>
        <Source name="~.*TestBase\.java"/>
    </Match>
    <Match>
        <Package name="~org\.oscarehr\.common\.dao\.utils.*"/>
    </Match>

    <!-- ================================================================
         LEGACY SERIALIZATION WARNINGS
         Many Struts Action classes and Hibernate entities are flagged for
         serialization issues that are not exploitable in this context.
         ================================================================ -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>

    <!-- ================================================================
         KNOWN STRUTS/SPRING PATTERNS
         The 2Action pattern deliberately uses static field access to
         SpringUtils.getBean() and stores request/response as instance
         fields. These are intentional design decisions, not bugs.
         ================================================================ -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
        <Class name="~.*2Action"/>
    </Match>

    <!-- ================================================================
         GENERATED / THIRD-PARTY CODE
         Code generated by tools or vendored libraries.
         ================================================================ -->
    <Match>
        <Package name="~ca\.uhn\.hl7v2.*"/>
    </Match>
    <Match>
        <Package name="~org\.apache\.ws\.security.*"/>
    </Match>

    <!-- ================================================================
         LOW-VALUE STYLE WARNINGS
         Suppress noisy warnings that do not indicate real bugs in this
         codebase. Security and correctness detectors remain enabled.
         ================================================================ -->

    <!-- Unread fields in model/entity classes (often set by Hibernate) -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Or>
            <Package name="~.*\.model"/>
            <Package name="~.*\.model\..*"/>
        </Or>
    </Match>

    <!-- Return value of putIfAbsent ignored — common in cache patterns -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_OF_PUTIFABSENT_IGNORED"/>
    </Match>

    <!--
      HRM report temp files are created under DOCUMENT_DIR only after the configured directory is
      normalized and verified as an existing directory. The temp filename prefix is derived from an
      integer-parsed HRM id, so no request-controlled path segment reaches createTempFile().
    -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.hospitalReportManager.PrintHRMReport2Action"/>
        <Method name="execute"/>
    </Match>

    <!--
      BC billing receipt redirects are built as context-relative application paths, URL-encode every
      billing_no value, and are validated with RedirectValidationUtils before sendRedirect().
    -->
    <Match>
        <Bug pattern="UNVALIDATED_REDIRECT"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.pageUtil.BillingSaveBilling2Action"/>
        <Method name="sendReceiptRedirect"/>
    </Match>

    <!--
      BC billing rejection bodies are text/plain direct responses with X-Content-Type-Options:
      nosniff. User-facing values are sanitized before formatting, and the helper is only used after
      callers set the status/content type for rejection responses.
    -->
    <Match>
        <Bug pattern="XSS_SERVLET"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.pageUtil.BillingSaveBilling2Action"/>
        <Method name="writeBody"/>
    </Match>

    <!-- ================================================================
         FIND SECURITY BUGS PATH TRAVERSAL FALSE POSITIVES
         These are exact method-level suppressions for reviewed file paths
         where the flagged sink receives a File that has already passed
         PathValidationUtils or equivalent canonical containment checks.
         Do not broaden these to package/class-level PATH_TRAVERSAL rules.
         ================================================================ -->

    <!-- Teleplan response files are bounded by DOCUMENT_DIR or an allowed temp directory before reading. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billing.CA.BC.Teleplan.TeleplanCodesManager"/>
        <Method name="parse"/>
    </Match>

    <!-- Teleplan explanatory/ICD response files are validated before FileReader opens them. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billing.CA.BC.pageUtil.ManageTeleplan2Action"/>
        <Method name="updateteleplanICDCodesList"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billing.CA.BC.pageUtil.ManageTeleplan2Action"/>
        <Method name="updateExplanatoryCodesList"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billing.CA.BC.pageUtil.ManageTeleplan2Action"/>
        <Method name="checkElig"/>
    </Match>

    <!-- Teleplan send files are resolved under HOME_DIR with PathValidationUtils.validatePath(). -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.pageUtil.ManageTeleplan2Action"/>
        <Method name="sendFile"/>
    </Match>

    <!-- Ontario RA imports validate the selected file under DOCUMENT_DIR before parsing. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billing.CA.ON.service.BillingOnRaService"/>
        <Method name="importRAFile"/>
    </Match>

    <!-- Generic downloads canonicalize the directory and validate the filename before FileInputStream. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.util.GenericDownload"/>
        <Method name="transferFile"/>
    </Match>

    <!-- Document manager file creation/lookup is bounded by DOCUMENT_DIR via PathValidationUtils. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.managers.DocumentManagerImpl"/>
        <Method name="createDocument"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.managers.DocumentManagerImpl"/>
        <Method name="getFullPathToDocument"/>
    </Match>

    <!-- Uploaded image temp files are accepted only after PathValidationUtils.validateUpload(). -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.eform.upload.ImageUpload2Action"/>
        <Method name="withUploadedFiles"/>
    </Match>

    <!-- ================================================================
         FIND SECURITY BUGS INFORMATIONAL TAINT-SOURCE / ENDPOINT MARKERS
         These detectors are NOT vulnerabilities. Find Security Bugs emits
         them to map attack surface: SERVLET_PARAMETER flags every point
         where request data enters, and *_ENDPOINT flags every reachable
         action/web-service method. On this codebase they account for the
         large majority of "security" Code Scanning alerts (~1,300
         SERVLET_PARAMETER, ~270 STRUTS2_ENDPOINT) while flagging zero
         concrete sinks. They drown out actionable findings (injection,
         path traversal, XSS, weak crypto), so we suppress the source/
         endpoint markers and keep every sink detector active.

         Reference: Find Security Bugs bug patterns — these are documented
         as informational ("count"/"endpoint") detectors, not defects.
         ================================================================ -->
    <Match>
        <Bug pattern="SERVLET_PARAMETER"/>
    </Match>
    <Match>
        <Bug pattern="STRUTS2_ENDPOINT"/>
    </Match>
    <Match>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>
    <Match>
        <Bug pattern="JAXWS_ENDPOINT"/>
    </Match>
    <Match>
        <Bug pattern="JAXRS_ENDPOINT"/>
    </Match>

</FindBugsFilter>
