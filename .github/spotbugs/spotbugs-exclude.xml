        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.documentManager.actions.ManageDocument2Action"/>
        <Method name="addIncomingDocument"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.documentManager.actions.ManageDocument2Action"/>
        <Method name="validateConfiguredDocumentDirectory"/>
    </Match>

    <!-- Temp deletion accepts path-derived input only after canonical allowed-temp checks
         and PathValidationUtils.validateUpload() confirms a regular temp file. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.managers.NioFileManagerImpl"/>
        <Method name="validateTempDeletionTarget"/>
    </Match>

    <!-- Uploaded image temp files are accepted only after PathValidationUtils.validateUpload(). -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.eform.upload.ImageUpload2Action"/>
        <Method name="withUploadedFiles"/>
    </Match>


    <!--
      Generated JSP classes call Spring BeanUtils.copyProperties between fixed CARLOS model/archive
