<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Exclude Filter for CARLOS EMR

  Suppresses known false positives and noisy patterns in legacy code
  while keeping all security-relevant and correctness detectors active.

  Reference: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ================================================================
         TEST CLASSES
         Exclude all test code from analysis.
         ================================================================ -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
    <Match>
        <Source name="~.*TestBase\.java"/>
    </Match>
    <Match>
        <Package name="~org\.oscarehr\.common\.dao\.utils.*"/>
    </Match>

    <!-- ================================================================
         LEGACY SERIALIZATION WARNINGS
         Many Struts Action classes and Hibernate entities are flagged for
         serialization issues that are not exploitable in this context.
         ================================================================ -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>

    <!-- ================================================================
         KNOWN STRUTS/SPRING PATTERNS
         The 2Action pattern deliberately uses static field access to
         SpringUtils.getBean() and stores request/response as instance
         fields. These are intentional design decisions, not bugs.
         ================================================================ -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
        <Class name="~.*2Action"/>
    </Match>

    <!-- ================================================================
         GENERATED / THIRD-PARTY CODE
         Code generated by tools or vendored libraries.
         ================================================================ -->
    <Match>
        <Package name="~ca\.uhn\.hl7v2.*"/>
    </Match>
    <Match>
        <Package name="~org\.apache\.ws\.security.*"/>
    </Match>

    <!-- ================================================================
         LOW-VALUE STYLE WARNINGS
         Suppress noisy warnings that do not indicate real bugs in this
         codebase. Security and correctness detectors remain enabled.
         ================================================================ -->

    <!-- Unread fields in model/entity classes (often set by Hibernate) -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Or>
            <Package name="~.*\.model"/>
            <Package name="~.*\.model\..*"/>
        </Or>
    </Match>

    <!-- Return value of putIfAbsent ignored — common in cache patterns -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_OF_PUTIFABSENT_IGNORED"/>
    </Match>

    <!-- TrustedSql is constructed only after legacy SELECT validation; values are bound below. -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
        <Class name="io.github.carlos_emr.carlos.db.LegacyJdbcQuery"/>
        <Method name="getPreparedResultSetValidated"/>
    </Match>
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.db.LegacyJdbcQuery"/>
        <Method name="getPreparedResultSetValidated"/>
    </Match>
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.db.LegacyJdbcQuery"/>
        <Method name="getPreparedResultSetLegacyRaw"/>
    </Match>

    <!-- Stored procedure names are validated before the CallableStatement is prepared. -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
        <Class name="io.github.carlos_emr.carlos.db.LegacyJdbcQuery"/>
        <Method name="procExecute"/>
    </Match>

    <!-- CaisiResult delegates server-owned legacy templates through the same JDBC value binding. -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
        <Class name="io.github.carlos_emr.carlos.db.LegacyJdbcQuery"/>
        <Method name="queryResultsCaisi"/>
    </Match>

    <!--
      FrmRecordHelp prepares server-owned form table SELECT statements and binds all
      form values as JDBC parameters. Dynamic table names are resolved by the legacy
      form classes, not request SQL text.
    -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
        <Class name="io.github.carlos_emr.carlos.form.FrmRecordHelp"/>
        <Method name="prepareResultSetStatement"/>
    </Match>
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.form.FrmRecordHelp"/>
        <Method name="prepareResultSetStatement"/>
    </Match>

    <!--
      MSP dbExtract is scoped to the legacy MSP extract path migrated in this PR.
      Callers supply server-owned SQL templates and pass runtime values separately
      for PreparedStatement binding.
    -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
        <Class name="io.github.carlos_emr.carlos.billings.MSP.dbExtract"/>
        <Method name="prepare"/>
    </Match>

    <!--
      AppointmentMainBean resolves SQL templates from server-side UtilDict entries
      and delegates to LegacyJdbcQuery for JDBC value binding. The alert is on the
      nonconstant template dispatch, not on request-controlled SQL execution.
    -->
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.AppointmentMainBean"/>
    </Match>

    <!--
      MSP reconciliation builds SQL from fixed report clauses and an allowlisted
      criteria helper; user values are accumulated in criteriaParams and bound by
      LegacyJdbcQuery.
    -->
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.MSP.MSPReconcile"/>
        <Method name="getBillsByType"/>
    </Match>
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.MSP.MSPReconcile"/>
        <Method name="getPayments"/>
    </Match>
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.MSP.MSPReconcile"/>
        <Method name="getPrivatePayments"/>
    </Match>

    <!--
      The MSP extract query is a legacy server-owned billing template. providerNo
      and invoice values are bound as parameters; the remaining SQL fragment is
      the established dateRange clause for this extract path.
    -->
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
        <Class name="io.github.carlos_emr.carlos.billings.MSP.ExtractBean"/>
        <Method name="dbQuery"/>
    </Match>

    <!--
      parseImportDocument uses XmlUtils.createSecureDocumentBuilderFactory(), which
      fails closed if DOCTYPE disabling cannot be applied and disables external
      entities before DocumentBuilder.parse().
    -->
    <Match>
        <Bug pattern="XXE_DOCUMENT"/>
        <Class name="io.github.carlos_emr.carlos.util.JDBCUtil"/>
        <Method name="parseImportDocument"/>
    </Match>

    <!--
      HRM report temp files are created under DOCUMENT_DIR only after the configured directory is
      normalized and verified as an existing directory. The temp filename prefix is derived from an
      integer-parsed HRM id, so no request-controlled path segment reaches createTempFile().
    -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.hospitalReportManager.PrintHRMReport2Action"/>
        <Method name="execute"/>
    </Match>

    <!--
      AddEditDocument2Action uses the configured DOCUMENT_DIR as the base directory, then validates
      dynamic filenames and written files with PathValidationUtils before PDF reads, upload writes,
      completeness checks, or cleanup. SpotBugs treats CarlosProperties.getDocumentDirectory() as an
      unknown path source, so keep this suppression scoped to the validated document-upload helpers.
    -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.documentManager.actions.AddEditDocument2Action"/>
        <Method name="countNumOfPages"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.documentManager.actions.AddEditDocument2Action"/>
        <Method name="writeLocalFile"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.documentManager.actions.AddEditDocument2Action"/>
        <Method name="resolveWrittenDocumentPath"/>
    </Match>

    <!--
      BC billing receipt redirects are built as context-relative application paths, URL-encode every
      billing_no value, and are validated with RedirectValidationUtils before sendRedirect().
    -->
    <Match>
        <Bug pattern="UNVALIDATED_REDIRECT"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.pageUtil.BillingSaveBilling2Action"/>
        <Method name="sendReceiptRedirect"/>
    </Match>

    <!--
      BC billing rejection bodies are text/plain direct responses with X-Content-Type-Options:
      nosniff. User-facing values are sanitized before formatting, and the helper is only used after
      callers set the status/content type for rejection responses.
    -->
    <Match>
        <Bug pattern="XSS_SERVLET"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.pageUtil.BillingSaveBilling2Action"/>
        <Method name="writeBody"/>
    </Match>

    <!-- ================================================================
         FIND SECURITY BUGS PATH TRAVERSAL FALSE POSITIVES
         These are exact method-level suppressions for reviewed file paths
         where the flagged sink receives a File that has already passed
         PathValidationUtils or equivalent canonical containment checks.
         Do not broaden these to package/class-level PATH_TRAVERSAL rules.
         ================================================================ -->

    <!-- Teleplan response files are bounded by DOCUMENT_DIR or an allowed temp directory before reading. -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Class name="io.github.carlos_emr.carlos.billings.ca.bc.Teleplan.TeleplanCodesManager"/>
        <Method name="parse"/>
    </Match>

    <!-- Teleplan explanatory/ICD response files are validated before FileReader opens them. -->
