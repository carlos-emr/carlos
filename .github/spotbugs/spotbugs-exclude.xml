<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Exclude Filter for CARLOS EMR

  Suppresses known false positives and noisy patterns in legacy code
  while keeping all security-relevant and correctness detectors active.

  Reference: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/spotbugs/blob/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ================================================================
         TEST CLASSES
         Exclude all test code from analysis.
         ================================================================ -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
    <Match>
        <Source name="~.*TestBase\.java"/>
    </Match>
    <Match>
        <Package name="~org\.oscarehr\.common\.dao\.utils.*"/>
    </Match>

    <!-- ================================================================
         LEGACY SERIALIZATION WARNINGS
         Many Struts Action classes and Hibernate entities are flagged for
         serialization issues that are not exploitable in this context.
         ================================================================ -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
        <Or>
            <Class name="~.*2Action"/>
            <Class name="~.*Action"/>
        </Or>
    </Match>

    <!-- ================================================================
         KNOWN STRUTS/SPRING PATTERNS
         The 2Action pattern deliberately uses static field access to
         SpringUtils.getBean() and stores request/response as instance
         fields. These are intentional design decisions, not bugs.
         ================================================================ -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
        <Class name="~.*2Action"/>
    </Match>

    <!-- ================================================================
         GENERATED / THIRD-PARTY CODE
         Code generated by tools or vendored libraries.
         ================================================================ -->
    <Match>
        <Package name="~ca\.uhn\.hl7v2.*"/>
    </Match>
    <Match>
        <Package name="~org\.apache\.ws\.security.*"/>
    </Match>

    <!-- ================================================================
         LOW-VALUE STYLE WARNINGS
         Suppress noisy warnings that do not indicate real bugs in this
         codebase. Security and correctness detectors remain enabled.
         ================================================================ -->

    <!-- Unread fields in model/entity classes (often set by Hibernate) -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Or>
            <Package name="~.*\.model"/>
            <Package name="~.*\.model\..*"/>
        </Or>
    </Match>

    <!-- Return value of putIfAbsent ignored — common in cache patterns -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_OF_PUTIFABSENT_IGNORED"/>
    </Match>

</FindBugsFilter>
