# =============================================================================
# CARLOS EMR - Production Environment Configuration
# =============================================================================
# Copy to `.env` and customize before running `docker compose up`.
# setup.sh generates this file automatically based on interactive prompts.
#
# Never commit a real .env file. The default .gitignore excludes it.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Database root password
# -----------------------------------------------------------------------------
# No default is provided. setup.sh generates a 32-character random password
# using openssl rand. Store this in a password manager - it is substituted
# into carlos.properties and drugref2.properties at setup time, and you will
# need it to connect to the database from outside the container.
DB_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# Province (jurisdiction-specific schema and reference data)
# -----------------------------------------------------------------------------
# "on" = Ontario (default) - loads ICD-9, OLIS, Ontario labs/billing
# "bc" = British Columbia - loads BC MSP billing, BC pharmacies
#
# The database image loads different schema extensions based on this. Cannot
# be changed after the DB volume is initialized without destroying data.
CARLOS_PROVINCE=on

# -----------------------------------------------------------------------------
# Load demo patient data?
# -----------------------------------------------------------------------------
# true  = Load development.sql (demo patients, appointments, providers) plus
#         demographic name sanitization. Use for evaluation/testing only.
# false = Clean install (default). Only the default admin provider account
#         (carlosdoc / carlos2026 / PIN 1117) is created.
#
# This runs ONCE on database initialization. To change, destroy the
# carlos-db-data volume and re-run compose up.
LOAD_DEMO_DATA=false

# -----------------------------------------------------------------------------
# Host port mappings
# -----------------------------------------------------------------------------
# Rootless podman cannot bind ports below 1024. The defaults are safe for
# rootless. If your host already uses 8080, change CARLOS_PORT to e.g. 18080.
CARLOS_PORT=8080
DRUGREF_PORT=8180

# -----------------------------------------------------------------------------
# WAR source (build-mode only)
# -----------------------------------------------------------------------------
# Path to the WAR file or exploded WAR directory relative to the repository
# root. setup.sh sets this based on whether you chose prebuilt or
# build-from-source mode. Ignored when using the `image:` line in
# docker-compose.yml instead of `build:`.
WAR_PATH=docker/carlos.war

# -----------------------------------------------------------------------------
# Timezone (affects audit log timestamps and scheduled jobs)
# -----------------------------------------------------------------------------
TZ=America/Toronto

# -----------------------------------------------------------------------------
# Clinic identity (optional, shown in UI)
# -----------------------------------------------------------------------------
# Not currently substituted into carlos.properties by setup.sh, but reserved
# for future use. Edit carlos.properties directly for UI customization.
CLINIC_NAME=My Clinic
