# CARLOS EMR - Production MariaDB Configuration
#
# Hardened for production deployment. Key differences from development:
#   - innodb_doublewrite = 1 (enabled for data safety, was 0 in dev for speed)
#   - sync_binlog = 1 (when binlog enabled, ensure durability)
#   - Reduced query cache size (deprecated in MariaDB 10.5+, kept small)
#   - Slow query log enabled with 2s threshold (was 10s in dev)
#   - Removed performance_schema=OFF (keep default for production monitoring)
#
# Tuning assumes container is given at least 2GB RAM. Adjust
# innodb_buffer_pool_size and innodb_log_buffer_size downward for smaller hosts.
#
# License: GPL-2.0+

[client]
port = 3306
socket = /var/run/mysqld/mysqld.sock
default-character-set = utf8mb4

[mysqld_safe]
socket = /var/run/mysqld/mysqld.sock
nice = 0

[mysqld]
user = mysql
pid-file = /var/run/mysqld/mysqld.pid
socket = /var/run/mysqld/mysqld.sock
port = 3306
basedir = /usr
datadir = /var/lib/mysql
tmpdir = /tmp
lc_messages_dir = /usr/share/mysql
lc_messages = en_US
skip-external-locking

# Production: enable doublewrite for crash safety (dev had this off for speed)
innodb_doublewrite = 1
innodb_page_size = 32K

# Character set configuration
# Note: oscarinit scripts use utf8 (not utf8mb4) for schema compatibility.
# Keep server-side utf8 to match existing data; clients use utf8mb4.
character-set-server = utf8
collation-server = utf8_general_ci
init-connect = 'SET NAMES utf8'

#
# Connection & timeout tuning
#
max_connections = 100
connect_timeout = 5
wait_timeout = 600
max_allowed_packet = 16M
thread_cache_size = 128
sort_buffer_size = 4M
bulk_insert_buffer_size = 16M
tmp_table_size = 32M
max_heap_table_size = 32M

#
# MyISAM (legacy tables - CARLOS still has some)
#
myisam_recover_options = BACKUP
key_buffer_size = 128M
table_open_cache = 400
myisam_sort_buffer_size = 512M
concurrent_insert = 2
read_buffer_size = 2M
read_rnd_buffer_size = 1M

#
# Query cache (deprecated in MariaDB 10.5+, keeping minimal for legacy queries)
#
query_cache_limit = 256K
query_cache_size = 16M
query_cache_type = 1

#
# Slow query logging - 2 second threshold for production (was 10s in dev).
# Useful for identifying queries that need optimization under real load.
#
slow_query_log = 1
slow_query_log_file = /var/log/mysql/mariadb-slow.log
long_query_time = 2

expire_logs_days = 10
max_binlog_size = 100M

# Production: strict SQL mode catches more errors. Set to "" to match
# legacy OSCAR behavior which relies on permissive mode. Review application
# logs after upgrade - some legacy queries may emit warnings under strict mode.
sql_mode = ""

#
# InnoDB - primary engine for CARLOS tables
#
default_storage_engine = InnoDB
innodb_log_file_size = 2G
innodb_random_read_ahead = OFF
innodb_buffer_pool_size = 2G
innodb_log_buffer_size = 512M
innodb_file_per_table = 1
innodb_open_files = 400
innodb_flush_method = O_DIRECT
innodb_strict_mode = 0
innodb_default_row_format = dynamic
innodb_flush_neighbors = 0
innodb_io_capacity = 2000
# Production: flush on every commit for ACID durability.
# Dev could set this to 2 for speed. Do NOT change without understanding
# the data-loss implications on crash.
innodb_flush_log_at_trx_commit = 1

[galera]
# Galera cluster disabled - CARLOS runs as single DB node.

[mysqldump]
quick
quote-names
max_allowed_packet = 1G

[mysql]

[isamchk]
key_buffer = 16M
