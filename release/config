		db_password=$(sed '/^\#/d' ${C_HOME}${PROGRAM}.properties | grep 'db_password'  | tail -n 1 | cut -d "=" -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//') 2>>$LOG_FILE
		echo "grep the previous db_name from the properties file" >> $LOG_FILE
		## you want oscar_15=oscar_15 but trim off the switches that we might be sending
		existing=$(sed '/^\#/d' ${C_HOME}${PROGRAM}.properties | grep 'db_name'  | tail -n 1 | cut -d "=" -f2 | cut -d "?" -f1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//') 2>>$LOG_FILE
		if [ "${db_name}" = "${existing}" ] ; then

            # UPDATE late breaking property key values here, we will support back to the first 15 deb
            # grep the key, tail backwards to the last entry and cut the key itself to test that it is present
	       # echo "adding new properties file key values"  >>$LOG_FILE

# PHC test and add newer properties here

