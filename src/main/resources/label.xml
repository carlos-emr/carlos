<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="label" columnCount="1" printOrder="Vertical" orientation="Portrait" pageWidth="350" pageHeight="75" columnWidth="200" columnSpacing="0" leftMargin="0" rightMargin="0" topMargin="10" bottomMargin="0" whenNoDataType="NoPages" isTitleNewPage="false" isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />
	<reportFont name="sansserif" isDefault="false" fontName="sansserif" size="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfFontName="Helvetica" pdfEncoding="Cp1252" isPdfEmbedded="false" />
	<parameter name="demo" isForPrompting="true" class="java.lang.String" />
	<queryString><![CDATA[select d.last_name, d.chart_no, d.first_name, d.address, d.city , d.province, d.postal, d.phone, d.phone2, d.email, d.year_of_birth, d.month_of_birth, d.date_of_birth, d.hin, d.ver, d.sex, CONCAT(p.last_name, ', ' ,p.first_name) as doc_name from demographic d, provider p where demographic_no =$P{demo} and d.provider_no = p.provider_no]]></queryString>
	<field name="last_name" class="java.lang.String" />
	<field name="chart_no" class="java.lang.String" />
	<field name="first_name" class="java.lang.String" />
	<field name="address" class="java.lang.String" />
	<field name="city" class="java.lang.String" />
	<field name="province" class="java.lang.String" />
	<field name="postal" class="java.lang.String" />
	<field name="phone" class="java.lang.String" />
	<field name="phone2" class="java.lang.String" />
	<field name="email" class="java.lang.String" />
	<field name="year_of_birth" class="java.lang.String" />
	<field name="month_of_birth" class="java.lang.String" />
	<field name="date_of_birth" class="java.lang.String" />
	<field name="hin" class="java.lang.String" />
	<field name="ver" class="java.lang.String" />
	<field name="sex" class="java.lang.String" />
	<field name="doc_name" class="java.lang.String" />
	<variable name="nowyear" class="java.lang.Integer" resetType="None" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer( 1900 +  (new java.util.Date().getYear()) )]]></variableExpression>
	</variable>
	<variable name="useryear" class="java.lang.Integer" resetType="None" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer($F{year_of_birth})]]></variableExpression>
	</variable>
	<background height="0">
		</background>
	<title height="60">
		<element kind="textField" positionType="Float" mode="Opaque" x="17" y="0" width="330" height="14" key="textField" fontSize="12.0" bold="true" underline="true" blankWhenNull="false" evaluationTime="Now" hyperlinkType="None" hyperlinkTarget="Self">
			<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000" />
			<expression><![CDATA[$F{last_name} + "," + $F{first_name} + "   " + "CHART#:" + $F{chart_no}]]></expression>
		</element>
		<element kind="textField" positionType="Float" mode="Opaque" x="17" y="15" width="330" height="14" key="textField" fontSize="12.0" blankWhenNull="false" evaluationTime="Now" hyperlinkType="None" hyperlinkTarget="Self">
			<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000" />
			<expression><![CDATA["HIN:" + $F{hin} + " " + $F{ver} + "   " + "SEX:" + $F{sex} + "  " + "DOB:" +$F{date_of_birth} + "/" + $F{month_of_birth} + "/" + $F{year_of_birth} + "  AGE:" + (new java.lang.Integer(  ($V{nowyear}.intValue()) -($V{useryear}.intValue()) )).toString()]]></expression>
		</element>
		<element kind="textField" positionType="Float" mode="Opaque" x="17" y="30" width="330" height="14" key="textField" fontSize="12.0" blankWhenNull="false" evaluationTime="Now" hyperlinkType="None" hyperlinkTarget="Self">
			<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000" />
			<expression><![CDATA[$F{address} + " " + $F{city} + "," + $F{province} + " " + $F{postal}]]></expression>
		</element>
		<element kind="textField" positionType="Float" mode="Opaque" x="17" y="45" width="330" height="14" key="textField" fontSize="12.0" blankWhenNull="false" evaluationTime="Now" hyperlinkType="None" hyperlinkTarget="Self">
			<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000" />
			<expression><![CDATA["HOME: " + $F{phone} + "EMAIL: " + $F{email} + " + "Dr. " + $F{doc_name}]]></expression>
		</element>
	</title>
	<pageHeader height="0">
		</pageHeader>
	<columnHeader height="0">
		</columnHeader>
	<detail>
		<band height="0">
		</band>
	</detail>
	<columnFooter height="0">
		</columnFooter>
	<pageFooter height="0">
		</pageFooter>
	<summary height="0">
		</summary>
</jasperReport>