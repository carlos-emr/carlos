<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="billingInvoice" pageWidth="612" pageHeight="792" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0" />
	<property name="ireport.x" value="0" />
	<property name="ireport.y" value="243" />
	<style name="table">
		<box>
			<pen lineWidth="1.0" lineColor="#000000" />
		</box>
	</style>
	<style name="table_TH" mode="Opaque" backcolor="#C3CFD9">
		<box>
			<topPen lineWidth="0.5" lineColor="#000000" />
			<bottomPen lineWidth="0.5" lineColor="#000000" />
		</box>
	</style>
	<style name="table_CH" mode="Opaque" backcolor="#E6F3FF">
		<box>
			<topPen lineWidth="0.5" lineColor="#000000" />
			<bottomPen lineWidth="0.5" lineColor="#000000" />
		</box>
	</style>
	<style name="table_TD" mode="Opaque" backcolor="#FFFFFF">
		<box>
			<topPen lineWidth="0.5" lineColor="#000000" />
			<bottomPen lineWidth="0.5" lineColor="#000000" />
		</box>
	</style>
	<subDataset name="dataset1" />
	<parameter name="invoice_no" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="clinic_logo" class="java.io.InputStream" />
	<parameter name="clinic_name" class="java.lang.String" />
	<parameter name="clinic_address" class="java.lang.String" />
	<parameter name="clinic_city" class="java.lang.String" />
	<parameter name="clinic_province" class="java.lang.String" />
	<parameter name="clinic_postal" class="java.lang.String" />
	<parameter name="clinic_phone" class="java.lang.String" />
	<parameter name="billing_print_date" class="java.lang.String" />
	<parameter name="billing_due_date" class="java.lang.String" />
	<parameter name="first_last_name" class="java.lang.String" />
	<parameter name="address_street_number_and_name" class="java.lang.String" />
	<parameter name="city" class="java.lang.String" />
	<parameter name="province" class="java.lang.String" />
	<parameter name="postal" class="java.lang.String" />
	<parameter name="email" class="java.lang.String" />
	<parameter name="phone" class="java.lang.String" />
	<parameter name="chartno" class="java.lang.String" />
	<parameter name="service_date" class="java.lang.String" />
	<parameter name="practitioner" class="java.lang.String" />
	<parameter name="payee" class="java.lang.String" />
	<parameter name="ref_doctor" class="java.lang.String" />
	<parameter name="bill_item_number" class="java.lang.String" />
	<parameter name="fee_total" class="java.lang.String" />
	<parameter name="payment_total" class="java.lang.String" />
	<parameter name="refund_total" class="java.lang.String" />
	<parameter name="balance_owing" class="java.lang.String" />
	<parameter name="bill_item_description" class="java.lang.String" />
	<parameter name="bill_item_service_code" class="java.lang.String" />
	<parameter name="bill_item_qty" class="java.lang.String" />
	<parameter name="bill_item_dx" class="java.lang.String" />
	<parameter name="bill_item_amount" class="java.lang.String" />
	<parameter name="remit_to_phone" class="java.lang.String" />
	<background splitType="Stretch">
		</background>
	<title height="93" splitType="Stretch">
		<element kind="image" mode="Transparent" x="306" y="0" width="265" height="87" hAlign="Right">
			<expression><![CDATA[$P{clinic_logo}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="-1" y="0" width="320" height="23" forecolor="#666666" hTextAlign="Left" vTextAlign="Top" fontSize="16.0" bold="false" italic="false" blankWhenNull="true">
			<expression><![CDATA[$P{clinic_name}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="0" y="23" width="320" height="16" hTextAlign="Left" vTextAlign="Top" fontSize="12.0">
			<expression><![CDATA[$P{clinic_address}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="0" y="39" width="320" height="16" hTextAlign="Left" vTextAlign="Top" fontSize="12.0">
			<expression><![CDATA[$P{clinic_city} + ", " + $P{clinic_province}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="0" y="55" width="320" height="16" hTextAlign="Left" vTextAlign="Top" fontSize="12.0">
			<expression><![CDATA[$P{clinic_postal}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="0" y="71" width="320" height="16" hTextAlign="Left" fontSize="12.0" strikeThrough="false">
			<expression><![CDATA["Tel: " + $P{clinic_phone}]]></expression>
		</element>
	</title>
	<pageHeader height="274" splitType="Stretch">
		<element kind="rectangle" x="388" y="181" width="173" height="87">
			<graphicElement>
				<pen lineWidth="3.0" lineStyle="Double" />
			</graphicElement>
		</element>
		<element kind="textField" mode="Opaque" x="0" y="0" width="570" height="47" backcolor="#999999" hTextAlign="Left" vTextAlign="Top" fontSize="22.0" bold="true" blankWhenNull="true">
			<paragraph leftIndent="10" />
			<expression><![CDATA["Invoice - " + $P{invoice_no}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="40" y="83" width="208" height="20">
			<expression><![CDATA[$P{first_last_name}]]></expression>
		</element>
		<element kind="staticText" mode="Transparent" x="40" y="63" width="100" height="20" fontSize="12.0" underline="true">
			<text><![CDATA[Bill To:]]></text>
		</element>
		<element kind="staticText" mode="Transparent" x="346" y="63" width="100" height="20" fontSize="12.0" underline="true">
			<text><![CDATA[Remit To:]]></text>
		</element>
		<element kind="textField" mode="Transparent" x="40" y="103" width="208" height="20">
			<expression><![CDATA[$P{address_street_number_and_name}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="40" y="123" width="208" height="20">
			<expression><![CDATA[$P{city}+","+$P{province}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="40" y="143" width="208" height="20">
			<expression><![CDATA[$P{postal}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="38" y="208" width="208" height="20">
			<expression><![CDATA["Email: " + $P{email}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="38" y="228" width="208" height="20">
			<expression><![CDATA["Tel: "+ $P{phone}]]></expression>
		</element>
		<element kind="textField" mode="Transparent" x="38" y="248" width="208" height="20">
			<expression><![CDATA["Chart No: " + $P{chartno}]]></expression>
		</element>
		<element kind="textField" mode="Opaque" x="0" y="29" width="569" height="24" backcolor="#999999" hTextAlign="Left" vTextAlign="Middle" fontSize="12.0">
			<paragraph leftIndent="10" />
			<expression><![CDATA["Print Date: " + $P{billing_print_date}]]></expression>
		</element>
		<element kind="textField" mode="Opaque" x="306" y="0" width="264" height="53" backcolor="#999999" hTextAlign="Right" vTextAlign="Middle" fontSize="12.0" bold="true" italic="false">
			<paragraph rightIndent="10" />
			<expression><![CDATA["Due Date: " + $P{billing_due_date}]]></expression>
		</element>
		<element kind="textField" x="398" y="188" width="163" height="20">
			<expression><![CDATA["Total: " + $P{fee_total}]]></expression>
		</element>
		<element kind="textField" x="398" y="208" width="163" height="20">
			<expression><![CDATA["Payments: "+ $P{payment_total}]]></expression>
		</element>
		<element kind="textField" x="398" y="228" width="163" height="20">
			<expression><![CDATA["Refunds: " + $P{refund_total}]]></expression>
		</element>
		<element kind="textField" x="398" y="248" width="163" height="20" bold="true">
			<expression><![CDATA["Balance Due: "+$P{balance_owing}]]></expression>
		</element>
		<element kind="textField" x="346" y="83" width="226" height="20">
			<expression><![CDATA[$P{clinic_name}]]></expression>
		</element>
		<element kind="textField" x="346" y="103" width="225" height="20">
			<expression><![CDATA[$P{clinic_address}]]></expression>
		</element>
		<element kind="textField" x="346" y="123" width="225" height="20">
			<expression><![CDATA[$P{clinic_city}+", " + $P{clinic_province}]]></expression>
		</element>
		<element kind="textField" x="346" y="143" width="225" height="20">
			<expression><![CDATA[$P{clinic_postal}]]></expression>
		</element>
		<element kind="textField" x="346" y="161" width="228" height="20">
			<expression><![CDATA["Tel: " + $P{remit_to_phone}]]></expression>
		</element>
	</pageHeader>
	<columnHeader height="84">
		<element kind="staticText" x="26" y="12" width="100" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Service Date]]></text>
		</element>
		<element kind="staticText" x="168" y="12" width="100" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Practitioner]]></text>
		</element>
		<element kind="line" x="0" y="55" width="572" height="1" />
		<element kind="textField" x="0" y="32" width="140" height="20" hTextAlign="Center">
			<expression><![CDATA[$P{service_date}]]></expression>
		</element>
		<element kind="textField" x="140" y="32" width="146" height="20" hTextAlign="Center">
			<expression><![CDATA[$P{practitioner}]]></expression>
		</element>
		<element kind="textField" x="284" y="32" width="149" height="20" hTextAlign="Center">
			<expression><![CDATA[$P{payee}]]></expression>
		</element>
		<element kind="line" x="2" y="0" width="570" height="1" />
		<element kind="staticText" x="444" y="12" width="100" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Ref. Doctor]]></text>
		</element>
		<element kind="textField" x="433" y="32" width="136" height="20" hTextAlign="Center">
			<expression><![CDATA[$P{ref_doctor}]]></expression>
		</element>
		<element kind="staticText" x="306" y="12" width="100" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Payee]]></text>
		</element>
		<element kind="staticText" x="2" y="61" width="49" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Item No.]]></text>
		</element>
		<element kind="staticText" x="151" y="60" width="100" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Description]]></text>
		</element>
		<element kind="staticText" x="338" y="60" width="79" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Service Code]]></text>
		</element>
		<element kind="staticText" x="417" y="60" width="27" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Qty]]></text>
		</element>
		<element kind="staticText" x="452" y="60" width="28" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Dx]]></text>
		</element>
		<element kind="staticText" x="498" y="60" width="56" height="20" hTextAlign="Center" fontSize="12.0" bold="true">
			<text><![CDATA[Amount]]></text>
		</element>
	</columnHeader>
	<detail>
		<band height="162">
			<element kind="textField" x="2" y="0" width="49" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_number}]]></expression>
			</element>
			<element kind="textField" x="51" y="0" width="295" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_description}]]></expression>
			</element>
			<element kind="textField" x="346" y="0" width="65" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_service_code}]]></expression>
			</element>
			<element kind="textField" x="411" y="0" width="35" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_qty}]]></expression>
			</element>
			<element kind="textField" x="446" y="0" width="40" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_dx}]]></expression>
			</element>
			<element kind="textField" x="486" y="0" width="86" height="162" hTextAlign="Center" markup="styled" textAdjust="StretchHeight">
				<paragraph lineSpacing="1_1_2" />
				<expression><![CDATA[$P{bill_item_amount}]]></expression>
			</element>
		</band>
	</detail>
	<pageFooter height="50">
		<element kind="textField" x="206" y="20" width="80" height="20" hTextAlign="Right">
			<expression><![CDATA["Page "+$V{PAGE_NUMBER}+" of"]]></expression>
		</element>
		<element kind="textField" x="286" y="20" width="40" height="20" evaluationTime="Report">
			<expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression>
		</element>
		<element kind="line" x="-1" y="13" width="573" height="4" />
	</pageFooter>
</jasperReport>