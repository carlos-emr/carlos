// ============================================================================
// CARLOS EMR - INR Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for the INR (International Normalized
//   Ratio) measurement. These rules evaluate the CURRENT VALUE of an INR
//   reading against therapeutic thresholds and colour-code the result in
//   the flowsheet UI.
//
// Clinical Context:
//   INR measures the anticoagulation level. The standard therapeutic
//   range is 2.0-3.0. Values outside these ranges indicate:
//     - INR <2.0 (sub-therapeutic)
//     - INR 4.0-4.9 (supra-therapeutic): elevated bleeding risk
//     - INR >=5.0 (critically high): serious hemorrhage risk
//
//   Note: The therapeutic range 2.0-3.9 produces no colour alert (displayed
//   as normal/in-range). Only sub-therapeutic and supra-therapeutic values
//   trigger visual indicators.
//
// Colour Indicator Mapping:
//   "LOW"    = sub-therapeutic (INR <2.0) - yellow/orange indicator
//   "HIGH"   = supra-therapeutic (INR 4.0-4.9) - red indicator
//   "HIGH 1" = critically supra-therapeutic (INR >=5.0) - dark red indicator
//
// How It Works:
//   Unlike the flowsheet timeliness rules (which use MeasurementInfo), these
//   per-item rules use MeasurementDSHelper, which provides:
//     - getDataAsDouble(): the numeric measurement value
//     - setIndicationColor(color): sets the visual indicator in the UI
//   The MeasurementDSHelper fact is inserted by MeasurementFlowSheet.java
//   when rendering individual measurement cells.
//
// Referenced By:
//   - XML config: inrFlowsheet.xml, <item> element with ds_rules="INR.drl"
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//   - See also: inrFlowsheet.drl for timeliness rules (when INR is overdue)
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package INR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Sub-therapeutic INR (INR < 2.0)
// Sets indication colour to "LOW" when INR is below 2.
// ---------------------------------------------------------------------------
rule "INR 1"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() < 2 )
        eval( !m.hasProblem() )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end

// ---------------------------------------------------------------------------
// Supra-therapeutic INR (4.0 <= INR < 5.0)
// Sets indication colour to "HIGH" when INR is between 4.0 and 5.0.
// ---------------------------------------------------------------------------
rule "INR 2"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 4 )
        eval( m.getDataAsDouble() < 5 )
        eval( !m.hasProblem() )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Critically elevated INR (INR >= 5.0)
// Sets indication colour to "HIGH 1" (more severe than "HIGH")
// when INR is 5.0 or above.
// ---------------------------------------------------------------------------
rule "INR 3"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 5 )
        eval( !m.hasProblem() )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end
