// ============================================================================
// CARLOS EMR - ACR (Albumin-to-Creatinine Ratio) Value-Based Decision
//              Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for the ACR measurement. These rules
//   evaluate ACR values against sex-specific thresholds for detecting
//   diabetic nephropathy (kidney damage from diabetes).
//
// Clinical Context:
//   ACR measures urinary albumin relative to creatinine, screening for
//   microalbuminuria - the earliest sign of diabetic nephropathy.
//   Diabetes Canada sex-specific thresholds for abnormal ACR:
//     - Male: ACR >= 2.0 mg/mmol (indicates albuminuria)
//     - Female: ACR >= 2.0 mg/mmol (same threshold used here)
//   Note: Some guidelines use 2.0 for males and 2.8 for females.
//   The XML flowsheet guideline text shows "M &lt;2.0 F &lt;2.8" but
//   both rules here use the same 2.0 threshold.
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, chf.xml
//     (<item> elements with ds_rules="diab-ACR.drl")
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//   - See also: diab.drl/ckd.drl for ACR timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesACR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Elevated ACR - Male (ACR >= 2.0 mg/mmol)
// Indicates microalbuminuria in male patients.
// ---------------------------------------------------------------------------
rule "ACR 1"
    when
        m : MeasurementDSHelper()
        eval( m.isMale() == true )
        eval( m.getDataAsDouble() >= 2.0 )
        eval( !m.hasProblem() )
    then
        m.log("ACR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Elevated ACR - Female (ACR >= 2.0 mg/mmol)
// Indicates microalbuminuria in female patients.
// Note: Both male and female rules use the same 2.0 threshold despite
// some guidelines recommending 2.8 for females.
// ---------------------------------------------------------------------------
rule "ACR 2"
    when
        m : MeasurementDSHelper()
        eval( m.isFemale() == true )
        eval( m.getDataAsDouble() >= 2.0 )
        eval( !m.hasProblem() )
    then
        m.log("ACR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
