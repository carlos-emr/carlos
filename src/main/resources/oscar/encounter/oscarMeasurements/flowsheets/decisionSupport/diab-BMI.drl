// ============================================================================
// CARLOS EMR - BMI (Body Mass Index) Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for the BMI measurement. These rules
//   evaluate BMI values against WHO/Health Canada weight categories and
//   colour-code the result in the flowsheet UI.
//
// Clinical Context:
//   BMI classification (WHO/Health Canada):
//     - <18.5: Underweight (flagged LOW - malnutrition risk)
//     - 18.5-24.9: Normal weight (no indicator)
//     - 25.0-29.9: Overweight (flagged HIGH - increased metabolic risk)
//     - >=30.0: Obese (flagged HIGH 1 - high risk for diabetes complications)
//
// Colour Indicator Mapping:
//   "LOW"    = underweight (BMI <18.5)
//   "HIGH"   = overweight (BMI 25.0-29.9)
//   "HIGH 1" = obese (BMI >30.0) - more severe indicator
//
// Referenced By:
//   - XML config: diabetesFlowsheet.xml (<item> with ds_rules="diab-BMI.drl")
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//   - See also: diab.drl for BMI timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesBMI;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Overweight (25.0 <= BMI < 30.0)
// Sets indication colour to "HIGH" when BMI is between 25.0 and 30.0.
// ---------------------------------------------------------------------------
rule "BMI 1"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() >= 25.0 )
        eval( m.getDataAsDouble() < 30 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Obese (BMI > 30.0)
// Sets indication colour to "HIGH 1" when BMI exceeds 30.
// ---------------------------------------------------------------------------
rule "BMI 2"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() > 30 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end

// ---------------------------------------------------------------------------
// Underweight (BMI < 18.5)
// Sets indication colour to "LOW" when BMI is below 18.5.
// ---------------------------------------------------------------------------
rule "BMI 3"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() < 18.5 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end
