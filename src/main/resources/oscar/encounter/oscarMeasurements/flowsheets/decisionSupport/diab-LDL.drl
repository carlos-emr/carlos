// ============================================================================
// CARLOS EMR - LDL Cholesterol Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for LDL cholesterol. Evaluates LDL
//   values against CCS (Canadian Cardiovascular Society) risk-stratified
//   targets for patients with diabetes.
//
// Clinical Context:
//   CCS lipid guidelines for diabetic patients:
//     - LDL <2.0 mmol/L: optimal for high-risk patients (no indicator)
//     - LDL 2.0-3.4 mmol/L: above primary target (HIGH)
//     - LDL >=3.5 mmol/L: significantly elevated (HIGH 1)
//
// Colour Indicator Mapping:
//   "HIGH"   = LDL 2.0-3.4 mmol/L (above target, moderate concern)
//   "HIGH 1" = LDL >=3.5 mmol/L (significantly elevated, urgent)
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, chf.xml
//     (<item> elements with ds_rules="diab-LDL.drl")
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//   - See also: diab.drl for LDL timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesLDL;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Above primary target (LDL 2.0-3.4 mmol/L)
// Sets indication colour to "HIGH" when LDL is between 2.0 and 3.5.
// ---------------------------------------------------------------------------
rule "LDL 1"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() >= 2.0 )
        eval( m.getDataAsDouble() < 3.5 )
    then
        m.log("LDL 1 RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Significantly elevated (LDL >= 3.5 mmol/L)
// Sets indication colour to "HIGH 1" when LDL is 3.5 or above.
// ---------------------------------------------------------------------------
rule "LDL 2"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() >= 3.5 )
    then
        m.log("LDL 2 RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end
