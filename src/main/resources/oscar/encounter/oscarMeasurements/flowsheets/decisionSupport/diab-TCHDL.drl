// ============================================================================
// CARLOS EMR - TC/HDL Ratio Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for the Total Cholesterol to HDL
//   ratio. Evaluates the TC/HDL ratio against cardiovascular risk thresholds
//   used in the Framingham Risk Score calculation.
//
// Clinical Context:
//   The TC/HDL ratio is a validated predictor of cardiovascular risk used
//   in Canadian risk calculators. For diabetic patients:
//     - Ratio <4.0: target/ideal (no indicator)
//     - Ratio 4.0-4.9: above target (HIGH - moderate CV risk)
//     - Ratio >=5.0: significantly elevated (HIGH 1 - high CV risk)
//   A high TC/HDL ratio indicates an unfavorable balance of atherogenic
//   to protective lipoproteins.
//
// Colour Indicator Mapping:
//   "HIGH"   = TC/HDL ratio 4.0-4.9 (above target)
//   "HIGH 1" = TC/HDL ratio >=5.0 (significantly elevated CV risk)
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, chf.xml
//     (<item> elements with ds_rules="diab-TCHDL.drl")
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//   - See also: diab.drl for TCHD timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesHCHDL;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Above target ratio (TC/HDL 4.0-4.9)
// Moderate cardiovascular risk - consider lifestyle modification and
// lipid-lowering therapy review.
// ---------------------------------------------------------------------------
rule "HCHDL 1"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() >= 4.0 )
        eval( m.getDataAsDouble() < 5.0 )
    then
        m.log("HCHDL 1 RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Significantly elevated ratio (TC/HDL >= 5.0)
// High cardiovascular risk - aggressive lipid management needed.
// ---------------------------------------------------------------------------
rule "HCHDL 2"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.getDataAsDouble() >= 5.0 )
    then
        m.log("HCHDL 2 RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end
