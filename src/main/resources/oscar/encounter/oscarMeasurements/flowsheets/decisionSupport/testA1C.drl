// ============================================================================
// CARLOS EMR - Clinical Report Numerator: A1C Below 7.0% (At Target)
// ============================================================================
//
// Purpose:
//   Population health reporting rule used by the Clinical Reports module
//   to count patients whose most recent A1C is at or below the Diabetes
//   Canada target of 7.0% (or 0.07 in fraction format).
//
// Clinical Context:
//   This rule is a NUMERATOR test - it determines whether a given patient
//   should be counted in the numerator of a population health indicator.
//   The indicator "a1clt0p071" counts diabetic patients who have achieved
//   glycemic control (A1C <7.0%). This is used for:
//     - Practice-level quality reporting
//     - Clinical audit and performance measurement
//     - Identifying patients needing intervention
//
// How It Works:
//   Unlike flowsheet decision support rules that colour-code individual
//   measurements, clinical report rules evaluate across a patient's
//   measurement history. The key methods:
//     - setMeasurement("A1C"): loads the patient's latest A1C value;
//       returns true if a value exists, false if never recorded
//     - setInRange(true): marks this patient as meeting the criteria
//       (counted in the numerator)
//   The DroolsNumerator Java class inserts a MeasurementDSHelper fact
//   for each patient in the denominator and fires these rules.
//
// Referenced By:
//   - XML config: ClinicalReports.xml
//     <Numerator id="a1clt0p071" name="A1C lower than 0.07" type="DROOLS"
//      file="testA1C.drl"/>
//   - Java: DroolsNumerator (in oscarReport package) compiles and fires
//   - Displayed in: Clinical Reports interface (population health reports)
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package ReportA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// A1C at target - percentage format (<7.0%, values >=2.0 to exclude fractions)
rule "A1C_1"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() < 7.0 )
        eval( m.getDataAsDouble() >= 2.0 )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setInRange(true);
end

// A1C at target - fraction format (<0.07, i.e., <7.0% expressed as decimal)
rule "A1C_2"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() < 0.07 )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setInRange(true);
end
