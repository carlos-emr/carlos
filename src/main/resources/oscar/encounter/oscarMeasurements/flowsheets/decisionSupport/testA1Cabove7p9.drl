// ============================================================================
// CARLOS EMR - Clinical Report Numerator: A1C Above 7.9% (Poorly Controlled)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with A1C >7.9%
//   (or >0.079 in fraction format), indicating poor glycemic control.
//   Used to identify patients at higher risk for microvascular complications.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="a1cgt0p079"
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface
//
// Fact: MeasurementDSHelper - setMeasurement("A1C") loads latest value,
//   setInRange(true) counts the patient in the numerator.
// ============================================================================
package ReportA1CAbove7p9;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// A1C >7.9% in percentage format (values >7.9 are clearly percentages)
// No recency window - counts any A1C on file regardless of recording date.
rule "A1C_1"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() > 7.9 )
        eval( !m.hasProblem() )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setInRange(true);
end

// A1C >0.079 in fraction format (<=2.0 guard excludes percentage values)
rule "A1C_2"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() <= 2.0 )
        eval( m.getDataAsDouble() > 0.079 )
        eval( !m.hasProblem() )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setInRange(true);
end
