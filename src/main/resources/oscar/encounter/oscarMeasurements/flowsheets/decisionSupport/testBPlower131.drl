// ============================================================================
// CARLOS EMR - Clinical Report Numerator: BP Systolic Below 131 mmHg
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with last recorded
//   systolic BP <131 mmHg (at or below diabetes target of 130). Simpler
//   than testBPlower130_80.drl - checks only systolic, no recency window.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="bplt131"
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface
//
// Fact: MeasurementDSHelper - getNumberFromSplit("/",0) extracts systolic.
// ============================================================================
package ReportBPLower131;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// Systolic <131 only (no diastolic check, no recency window).
// Simpler variant of testBPlower130_80.drl for systolic-only reporting.
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) < 131 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setInRange(true);
end
