// ============================================================================
// CARLOS EMR - Clinical Report Numerator: BP Below 140/90 (7-Month Window)
// ============================================================================
//
// Purpose:
//   Variant of testBPlower140_90.drl with a stricter 7-month recency
//   window instead of 13 months. Same BP threshold (<=140/90).
//
// ORPHANED: This file is NOT referenced by any XML config or Java code.
//   Candidate for deletion if confirmed unused.
//
// Fact: MeasurementDSHelper - same as testBPlower140_90.drl.
// ============================================================================
package ReportBPLower140_90_1;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// Both systolic <141 AND diastolic <91 with stricter 7-month recency window.
// Same logic as testBPlower140_90.drl but with <7 month window instead of <13.
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) < 141 )
        eval( m.getNumberFromSplit("/",1) < 91 )
        eval( m.getLastDateRecordedInMths() < 7 )
        eval( !m.hasProblem() )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setInRange(true);
end
