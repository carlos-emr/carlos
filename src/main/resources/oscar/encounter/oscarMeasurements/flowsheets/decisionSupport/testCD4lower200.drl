// ============================================================================
// CARLOS EMR - Clinical Report Numerator: CD4 Below 200 (AIDS-Defining)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting HIV patients with CD4 <200
//   cells/uL. Sets inRange=true when CD4 count is below 200.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="cd4lt200"
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface (HIV program reports)
//
// Fact: MeasurementDSHelper - setMeasurement("CD4") loads latest CD4 count.
// ============================================================================
package ReportCD4;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// CD4 <200 cells/uL: AIDS-defining threshold per CDC criteria.
// No recency window - counts any CD4 on file. No diastolic/split needed
// since CD4 is a single numeric value (not compound like BP).
rule "CD4"
    when
        m : MeasurementDSHelper()
        eval( !m.hasProblem() )
        eval( m.setMeasurement("CD4") == true )
        eval( m.getDataAsDouble() < 200 )
    then
        m.log("CD4 RULES IS GETTING RUN");
        m.setInRange(true);
end
