<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="practSum" pageWidth="535" pageHeight="842" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.data.*" />
	<import value="io.github.carlos_emr.carlos.billings.MSP.*" />
	<parameter name="payeeNo" class="java.lang.String" isForPrompting="false" />
	<parameter name="s21id" class="java.lang.String" isForPrompting="false" />
	<parameter name="subS23" class="net.sf.jasperreports.engine.JasperReport" isForPrompting="false" />
	<parameter name="adj" class="net.sf.jasperreports.engine.JasperReport" isForPrompting="false" />
	<queryString>
		<![CDATA[select t_payment,t_practitionerno,t_practitionername,t_amtbilled,t_amtpaid from teleplanS22 where t_payeeno = $P{payeeNo} and s21_id=$P{s21id}  and t_s22type<>'D' order by s22_id]]>
	</queryString>
	<field name="t_payment" class="java.lang.String" />
	<field name="t_practitionerno" class="java.lang.String" />
	<field name="t_practitionername" class="java.lang.String" />
	<field name="t_amtbilled" class="java.lang.String" />
	<field name="t_amtpaid" class="java.lang.String" />
	<variable name="test" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["test"]]></variableExpression>
		<initialValueExpression><![CDATA["test"]]></initialValueExpression>
	</variable>
	<background splitType="Stretch">
		</background>
	<title height="26" splitType="Stretch">
		<element kind="staticText" mode="Transparent" x="0" y="0" width="412" height="18" forecolor="#000000" backcolor="#FFFFFF" key="staticText" hTextAlign="Left" vTextAlign="Top" fontSize="14.0" rotation="None">
			<paragraph lineSpacing="Single" />
			<box>
				<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
			</box>
			<text><![CDATA[Practioner Summary]]></text>
		</element>
		<element kind="line" mode="Opaque" x="0" y="22" width="534" height="1" forecolor="#000000" backcolor="#FFFFFF" key="line">
			<graphicElement fill="Solid">
				<pen lineWidth="2.0" lineStyle="Solid" />
			</graphicElement>
		</element>
	</title>
	<pageHeader splitType="Stretch">
		</pageHeader>
	<columnHeader splitType="Stretch">
		</columnHeader>
	<detail>
		<band height="76" splitType="Stretch">
			<element kind="rectangle" mode="Opaque" x="1" y="0" width="534" height="17" forecolor="#000000" backcolor="#999999" key="element-22" radius="0">
				<graphicElement fill="Solid">
					<pen lineWidth="0.5" lineStyle="Solid" />
				</graphicElement>
			</element>
			<element kind="line" mode="Opaque" x="0" y="18" width="535" height="1" forecolor="#000000" backcolor="#FFFFFF" key="element-89" direction="BottomUp">
				<graphicElement fill="Solid">
					<pen lineWidth="0.5" lineStyle="Solid" />
				</graphicElement>
			</element>
			<element kind="staticText" mode="Transparent" x="0" y="2" width="82" height="12" forecolor="#FFFFFF" backcolor="#FFFFFF" key="element-90" hTextAlign="Left" vTextAlign="Middle" rotation="None">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<text><![CDATA[Date]]></text>
			</element>
			<element kind="staticText" mode="Transparent" x="86" y="2" width="107" height="12" forecolor="#FFFFFF" backcolor="#FFFFFF" key="element-90" hTextAlign="Left" vTextAlign="Middle" rotation="None">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<text><![CDATA[Practitioner]]></text>
			</element>
			<element kind="staticText" mode="Transparent" x="250" y="2" width="107" height="12" forecolor="#FFFFFF" backcolor="#FFFFFF" key="element-90" hTextAlign="Right" vTextAlign="Middle" rotation="None">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<text><![CDATA[Billed]]></text>
			</element>
			<element kind="staticText" mode="Transparent" x="357" y="2" width="107" height="12" forecolor="#FFFFFF" backcolor="#FFFFFF" key="element-90" hTextAlign="Right" vTextAlign="Middle" rotation="None">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<text><![CDATA[Paid]]></text>
			</element>
			<element kind="textField" mode="Transparent" x="0" y="20" width="82" height="15" forecolor="#000000" backcolor="#FFFFFF" key="textField" hTextAlign="Left" vTextAlign="Top" rotation="None" textAdjust="StretchHeight" blankWhenNull="true" pattern="dd-MMM-yy">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<expression><![CDATA[new SimpleDateFormat("yyyyMMdd").parse($F{t_payment})]]></expression>
			</element>
			<element kind="textField" mode="Transparent" x="86" y="20" width="164" height="15" forecolor="#000000" backcolor="#FFFFFF" key="textField" hTextAlign="Left" vTextAlign="Top" rotation="None" textAdjust="StretchHeight" blankWhenNull="true" pattern="">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<expression><![CDATA[$F{t_practitionername} + "(" + $F{t_practitionerno} + ")"]]></expression>
			</element>
			<element kind="textField" mode="Transparent" x="250" y="20" width="107" height="15" forecolor="#000000" backcolor="#FFFFFF" key="textField" hTextAlign="Right" vTextAlign="Top" rotation="None" textAdjust="StretchHeight" blankWhenNull="true" pattern="">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<expression><![CDATA["$"+MSPReconcile.convCurValue($F{t_amtbilled})]]></expression>
			</element>
			<element kind="textField" mode="Transparent" x="357" y="20" width="107" height="15" forecolor="#000000" backcolor="#FFFFFF" key="textField" hTextAlign="Right" vTextAlign="Top" rotation="None" textAdjust="StretchHeight" blankWhenNull="true" pattern="">
				<paragraph lineSpacing="Single" />
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000" />
				</box>
				<expression><![CDATA["$"+MSPReconcile.convCurValue($F{t_amtpaid})]]></expression>
			</element>
			<element kind="subreport" mode="Opaque" x="0" y="38" width="367" height="36" forecolor="#000000" backcolor="#FFFFFF" key="subreport-1" usingCache="true">
				<parameter name="s21id">
					<expression><![CDATA[$P{s21id}]]></expression>
				</parameter>
				<parameter name="providerNo">
					<expression><![CDATA[$F{t_practitionerno}]]></expression>
				</parameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<expression><![CDATA[$P{adj}]]></expression>
			</element>
		</band>
	</detail>
	<columnFooter splitType="Stretch">
		</columnFooter>
	<pageFooter splitType="Stretch">
		</pageFooter>
	<summary splitType="Stretch">
