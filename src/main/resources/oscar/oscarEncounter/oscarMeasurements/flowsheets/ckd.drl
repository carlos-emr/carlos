// ============================================================================
// CARLOS EMR - Chronic Kidney Disease (CKD) Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide clinical decision support for the CKD management
//   flowsheet. They monitor whether key renal function measurements are
//   overdue and generate yellow "recommendation" or red "warning" alerts
//   in the flowsheet UI.
//
// Clinical Context:
//   Chronic Kidney Disease (CKD) is staged by eGFR and albuminuria (ACR)
//   per KDIGO guidelines. CKD is triggered in CARLOS by ICD-9 code 585
//   or the internal OscarCode CKDSCREEN. Regular monitoring of renal
//   biomarkers is essential to detect disease progression and guide
//   treatment decisions (e.g., referral to nephrology, medication adjustment).
//
//   Note: This is a minimal CKD ruleset monitoring only ACR and eGFR.
//   The full CKD flowsheet XML (ckdFlowsheet.xml) defines additional
//   measurement items (e.g., ACE-I/ARB use, BP, potassium, hemoglobin)
//   that do not have timeliness rules in this file - those items rely on
//   per-item decision support rules (diab-*.drl files) or have no
//   automated alerting.
//
// How It Works:
//   A MeasurementInfo fact object is inserted into the Drools working memory
//   by MeasurementFlowSheet.java. Each rule checks months since last recorded:
//     - getLastDateRecordedInMonths(type) returns months, or -1 if never recorded
//     - addRecommendation(type, msg) shows a YELLOW alert (approaching deadline)
//     - addWarning(type, msg) shows a RED alert (past deadline or never recorded)
//
// Measurement Monitoring Schedule:
//   10-month cycle (annual): ACR, EGFR
//
// Referenced By:
//   - XML config: ckdFlowsheet.xml (ds_rules="ckd.drl",
//     triggered by ICD-9 code 585 or OscarCode:CKDSCREEN)
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - Displayed in: E-Chart encounter view, Measurement Flowsheet panel
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package ckdFlowSheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Albumin-to-Creatinine Ratio (ACR)
// Urine ACR is the primary marker of kidney damage (albuminuria).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "ACR 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") >= 10 )
        eval( m.getLastDateRecordedInMonths("ACR") < 12 )
    then
        m.log("ACR 1 getting called");
        m.addRecommendation("ACR","An Alb: creat ratio value hasn't been recorded in "+m.getLastDateRecordedInMonths("ACR")+" months");
end

rule "ACR 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") >= 12 )
    then
        m.log("ACR 2 getting called");
        m.addWarning("ACR","An Alb: creat ratio value hasn't been recorded in "+m.getLastDateRecordedInMonths("ACR")+" months");
end

rule "ACR 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") ==  -1 )
    then
        m.log("ACR 3 getting called");
        m.addWarning("ACR","An Alb: creat ratio value has not been recorded");
end

// ---------------------------------------------------------------------------
// Estimated Glomerular Filtration Rate (eGFR)
// eGFR is the primary measure of kidney function and determines CKD stage:
//   Stage 1: eGFR >= 90 (normal, but with other evidence of kidney damage)
//   Stage 2: eGFR 60-89 (mildly decreased)
//   Stage 3a: eGFR 45-59, Stage 3b: eGFR 30-44 (moderately decreased)
//   Stage 4: eGFR 15-29 (severely decreased)
//   Stage 5: eGFR <15 (kidney failure)
// Annual monitoring recommended; more frequent if declining rapidly.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "EGFR 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") >= 10 )
        eval( m.getLastDateRecordedInMonths("EGFR") < 12 )
    then
        m.log("EGFR 1 getting called");
        m.addRecommendation("EGFR","An eGFR value hasn't been recorded in "+m.getLastDateRecordedInMonths("EGFR")+" months");
end

rule "EGFR 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") >= 12 )
    then
        m.log("EGFR 2 getting called");
        m.addWarning("EGFR","An eGFR value hasn't been recorded in "+m.getLastDateRecordedInMonths("EGFR")+" months");
end

rule "EGFR 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") ==  -1 )
    then
        m.log("EGFR 3 getting called");
        m.addWarning("EGFR","An eGFR value has not been recorded");
end
