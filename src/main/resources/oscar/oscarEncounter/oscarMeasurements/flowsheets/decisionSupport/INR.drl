// ============================================================================
// CARLOS EMR - INR Target Range Decision Support Rules
// ============================================================================
//
// Evaluates INR measurement values against therapeutic ranges and sets
// colour-coded indicators (LOW/HIGH/VERYHIGH) for anticoagulation management.
//
// Fact: MeasurementDSHelper - bound as "m", provides getDataAsDouble()
// Consequences: setIndicationColor() to flag out-of-range values
//
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package INR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "INR 1"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() < 2 )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end

rule "INR 2"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 4 )
        eval( m.getDataAsDouble() < 5 )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

rule "INR 3"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 5 )
    then
        m.log("INR RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end
