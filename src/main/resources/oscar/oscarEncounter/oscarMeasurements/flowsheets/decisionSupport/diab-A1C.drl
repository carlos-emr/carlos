// ============================================================================
// CARLOS EMR - Diabetes A1C Target Range Decision Support Rules
// ============================================================================
//
// Evaluates A1C (glycated hemoglobin) values against target ranges for
// diabetes management. Sets colour indicators for clinical review.
//
// Fact: MeasurementDSHelper - bound as "m", provides getDataAsDouble()
// Consequences: setIndicationColor() to flag out-of-target values
//
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package DiabetesA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "A1C"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 7 )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

rule "A1C2"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() <= 2 )
        eval( m.getDataAsDouble() >= 0.07 )
    then
        m.log("A1C RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
