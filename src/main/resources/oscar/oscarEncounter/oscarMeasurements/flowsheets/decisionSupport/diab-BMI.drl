// ============================================================================
// CARLOS EMR - Diabetes BMI Target Range Decision Support Rules
// ============================================================================
//
// Evaluates Body Mass Index (BMI) values against healthy ranges for
// diabetes weight management. Sets colour indicators for clinical review.
//
// Fact: MeasurementDSHelper - bound as "m", provides getDataAsDouble()
// Consequences: setIndicationColor() to flag out-of-range BMI values
//
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package DiabetesBMI;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "BMI 1"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 25.0 )
        eval( m.getDataAsDouble() < 30 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

rule "BMI 2"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() > 30 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end

rule "BMI 3"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() < 18.5 )
    then
        m.log("BMI RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end
