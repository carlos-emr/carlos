// ============================================================================
// CARLOS EMR - Blood Pressure Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rules for blood pressure. These rules evaluate
//   systolic and diastolic BP against diabetes/CKD-specific targets and
//   colour-code the result in the flowsheet UI.
//
// Clinical Context:
//   Diabetes Canada recommends BP target <130/80 mmHg for patients with
//   diabetes (lower than the general population target of <140/90).
//
//   BP is stored as a single string "systolic/diastolic" (e.g., "135/85").
//   The getNumberFromSplit("/", index) method parses this:
//     - index 0 = systolic (top number)
//     - index 1 = diastolic (bottom number)
//
//   Three rules capture all out-of-range combinations:
//     - Both high: systolic >130 AND diastolic >80 (HIGH 1 - severe)
//     - Systolic normal, diastolic high: <=130 AND >80 (HIGH)
//     - Systolic high, diastolic normal: >130 AND <=80 (HIGH)
//   When both are in range (<=130 AND <=80), no rule fires (normal).
//
// Colour Indicator Mapping:
//   "HIGH"   = one component above target (isolated systolic or diastolic)
//   "HIGH 1" = both components above target (more severe)
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, diabetesQueensFlowsheet.xml,
//     omdDiabetesFlowsheet.xml, omdChf.xml, chf.xml
//     (<item> elements with ds_rules="diab-BP.drl")
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - See also: diab.drl for BP timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesBP;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Both systolic AND diastolic above target (>130/80)
// Most severe indication - both components elevated.
// ---------------------------------------------------------------------------
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) > 130 )
        eval( m.getNumberFromSplit("/",1) > 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end

// ---------------------------------------------------------------------------
// Isolated diastolic hypertension (systolic <=130, diastolic >80)
// ---------------------------------------------------------------------------
rule "BP 2"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) <= 130 )
        eval( m.getNumberFromSplit("/",1) > 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

// ---------------------------------------------------------------------------
// Isolated systolic hypertension (systolic >130, diastolic <=80)
// More common in elderly patients due to arterial stiffness.
// ---------------------------------------------------------------------------
rule "BP 3"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) > 130 )
        eval( m.getNumberFromSplit("/",1) <= 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
