// ============================================================================
// CARLOS EMR - Diabetes Blood Pressure Target Range Decision Support Rules
// ============================================================================
//
// Evaluates systolic and diastolic blood pressure against diabetes-specific
// targets. Uses getNumberFromSplit("/", index) to parse "systolic/diastolic".
//
// Fact: MeasurementDSHelper - bound as "m"
// Methods: getNumberFromSplit(delimiter, index), setIndicationColor()
//
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package DiabetesBP;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) > 130 )
        eval( m.getNumberFromSplit("/",1) > 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH 1");
end

rule "BP 2"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) <= 130 )
        eval( m.getNumberFromSplit("/",1) > 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end

rule "BP 3"
    when
        m : MeasurementDSHelper()
        eval( m.getNumberFromSplit("/",0) > 130 )
        eval( m.getNumberFromSplit("/",1) <= 80 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
