// ============================================================================
// CARLOS EMR - Diabetes Complication Indicator (No = High Risk) Rules
// ============================================================================
//
// Evaluates whether a clinical indicator value of "No" represents a
// high-risk finding requiring clinical attention in diabetes management.
//
// Fact: MeasurementDSHelper - bound as "m"
// Methods: isDataEqualTo(value), setIndicationColor()
//
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package DiabetesFGLC;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "FGLC"
    when
        m : MeasurementDSHelper()
        eval( m.isDataEqualTo("No") )
    then
        m.log("FGLC RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
