// ============================================================================
// CARLOS EMR - Generic "No = Concerning" Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   A generic per-item decision support rule for Yes/No measurements where
//   answering "No" indicates a CONCERNING finding. Used by multiple items
//   in the diabetes and CHF flowsheets where "No" means a recommended
//   action has NOT been completed.
//
// Clinical Context:
//   Several flowsheet items ask Yes/No questions where "No" is the
//   undesirable answer. Examples from diabetesFlowsheet.xml:
//     - FGLC: "Flu shot given?" - No = patient not vaccinated (risk)
//     - EYEE: "Eye exam done?" - No = retinopathy screening gap
//     - FTE:  "Foot exam done?" - No = neuropathy/ulcer screening gap
//     - FTLS: "Foot sensation normal?" - No = possible neuropathy
//   And from chf.xml:
//     - FGLC, EYEE, FTE, FTLS: same Yes/No items
//
//   When the value is "No", the flowsheet cell is highlighted to draw
//   the clinician's attention to the uncompleted screening/action.
//
// Note on Package/Rule Naming:
//   The package "DiabetesFGLC" and rule name "FGLC" are historical artifacts
//   from when this file only served the flu shot (FGLC) item. Despite the
//   name, this file is now used generically by ANY item where "No" = bad.
//   The rule name doesn't need to match the measurement type because each
//   <item> in the XML has its own ds_rules attribute that points here.
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml (FGLC, EYEE, FTE, FTLS items),
//     chf.xml (same items) - all with ds_rules="diab-C-no-is-high.drl"
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesFGLC;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// "No" answer = concerning finding
// When the measurement data equals "No", flag it as HIGH to indicate
// the recommended action/screening has not been completed.
// ---------------------------------------------------------------------------
rule "FGLC"
    when
        m : MeasurementDSHelper()
        eval( m.isDataEqualTo("No") )
    then
        m.log("FGLC RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
