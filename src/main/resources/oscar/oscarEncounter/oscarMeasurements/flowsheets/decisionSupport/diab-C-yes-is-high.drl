// ============================================================================
// CARLOS EMR - Generic "Yes = Concerning" Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   A generic per-item decision support rule for Yes/No measurements where
//   answering "Yes" indicates a CONCERNING finding. The inverse of
//   diab-C-no-is-high.drl. Used by items where "Yes" is the undesirable answer.
//
// Clinical Context:
//   Some flowsheet items ask Yes/No questions where "Yes" is the alarming
//   answer. Examples from diabetesFlowsheet.xml:
//     - PANE: "Peripheral neuropathy symptoms?" - Yes = nerve damage
//     - EDGI: "Erectile dysfunction?" - Yes = autonomic neuropathy/vascular
//   And from chf.xml:
//     - PANE, EDGI: same Yes/No items
//
//   When the value is "Yes", the flowsheet cell is highlighted to draw
//   clinical attention to the positive finding that requires follow-up.
//
// Note on Package/Rule Naming:
//   Same as diab-C-no-is-high.drl - the "DiabetesFGLC" package and "FGLC"
//   rule name are historical artifacts. This file is used generically by
//   any item where "Yes" = concerning.
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml (PANE, EDGI items),
//     chf.xml (PANE, EDGI items) - all with ds_rules="diab-C-yes-is-high.drl"
//   - Java: MeasurementFlowSheet.loadMeasurementRuleBase(String) compiles this DRL
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesFGLC;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// "Yes" answer = concerning finding
// When the measurement data equals "Yes", flag it as HIGH to indicate
// a positive finding that needs clinical attention (e.g., symptoms present).
// ---------------------------------------------------------------------------
rule "FGLC"
    when
        m : MeasurementDSHelper()
        eval( m.isDataEqualTo("Yes") )
    then
        m.log("FGLC RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
