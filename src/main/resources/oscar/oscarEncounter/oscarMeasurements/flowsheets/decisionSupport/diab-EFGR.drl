// ============================================================================
// CARLOS EMR - Diabetes eGFR Target Range Decision Support Rules
// ============================================================================
//
// Evaluates estimated Glomerular Filtration Rate (eGFR) for diabetic
// nephropathy staging. Sets colour indicators based on CKD staging thresholds.
//
// Fact: MeasurementDSHelper - bound as "m", provides getDataAsDouble()
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package DiabetesEFGR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "EFGR"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() <= 60 )
    then
        m.log("ACR RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end
