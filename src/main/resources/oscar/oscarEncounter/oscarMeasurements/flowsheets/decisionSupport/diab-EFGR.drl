package DiabetesEFGR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "EFGR"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() <= 60 )
    then
        m.log("ACR RULES IS GETTING RUN");
        m.setIndicationColor("LOW");
end
