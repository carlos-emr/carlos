// ============================================================================
// CARLOS EMR - eGFR Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rule for the eGFR measurement. Evaluates
//   the current eGFR value against the CKD stage 3 threshold (60 mL/min)
//   and colour-codes values indicating reduced kidney function.
//
// Clinical Context:
//   eGFR (estimated Glomerular Filtration Rate) measures kidney function.
//   KDIGO CKD stages based on eGFR:
//     - >=90: Stage 1 (normal or high)
//     - 60-89: Stage 2 (mildly decreased)
//     - 45-59: Stage 3a (mild-to-moderately decreased)
//     - 30-44: Stage 3b (moderately-to-severely decreased)
//     - 15-29: Stage 4 (severely decreased)
//     - <15: Stage 5 (kidney failure)
//
//   This rule flags eGFR <=60 by setting the indication colour to "LOW".
//
// Note on Log Message:
//   The log message says "ACR RULES" - this is a copy-paste artifact from
//   the original rules and does not affect functionality.
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, chf.xml
//     (<item> elements with ds_rules="diab-EFGR.drl")
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - See also: diab.drl/ckd.drl for EGFR timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesEFGR;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Reduced eGFR (eGFR <= 60 mL/min/1.73m2)
// Indicates CKD stage 3 or worse. Sets indication colour to "LOW".
// ---------------------------------------------------------------------------
rule "EFGR"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() <= 60 )
    then
        m.log("EFGR/eGFR RULE IS GETTING RUN");
        m.setIndicationColor("LOW");
end
