// ============================================================================
// CARLOS EMR - Triglycerides Value-Based Decision Support Rules
// ============================================================================
//
// Purpose:
//   Per-item decision support rule for triglyceride measurements. Evaluates
//   TG values against the CCS target for diabetic patients.
//
// Clinical Context:
//   Hypertriglyceridemia is common in diabetes due to insulin resistance
//   and is part of the metabolic syndrome. CCS guidelines:
//     - TG <1.5-2.0 mmol/L: target range (no indicator)
//     - TG >=2.0 mmol/L: elevated (HIGH - lifestyle modification, consider
//       fibrate therapy)
//   Note: only a single threshold is used (no two-tier HIGH/HIGH 1).
//   Severe hypertriglyceridemia (>10 mmol/L) carries pancreatitis risk
//   but is not separately flagged by this rule.
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, chf.xml
//     (<item> elements with ds_rules="diab-TG.drl")
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - See also: diab.drl for TG timeliness rules
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesTG;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// ---------------------------------------------------------------------------
// Elevated triglycerides (TG >= 2.0 mmol/L)
// Sets indication colour to "HIGH" when triglycerides are 2.0 or above.
// ---------------------------------------------------------------------------
rule "TG 1"
    when
        m : MeasurementDSHelper()
        eval( m.getDataAsDouble() >= 2.0 )
    then
        m.log("TG RULES IS GETTING RUN");
        m.setIndicationColor("HIGH");
end
