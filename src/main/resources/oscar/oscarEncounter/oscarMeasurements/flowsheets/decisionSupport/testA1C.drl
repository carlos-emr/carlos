// ============================================================================
// CARLOS EMR - Clinical Report: A1C Threshold Test Rules
// ============================================================================
//
// Used by DroolsNumerator for clinical reporting. Evaluates if a patient's
// A1C measurement falls within a specified range, setting isInRange flag.
//
// Fact: MeasurementDSHelper - bound as "m"
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package ReportA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "A1C_1"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() < 7.0 )
        eval( m.getDataAsDouble() >= 2.0 )
    then
        m.log("A1C RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end

rule "A1C_2"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() < 0.07 )
    then
        m.log("A1C RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
