// CARLOS EMR - Clinical Report: A1C Above 7.9 Threshold Test
// Fact: MeasurementDSHelper. Converted from Drools 2.0 XML to 7.x DRL.
package ReportA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "A1C_1"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() > 7.9 )
    then
        m.log("A1C RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end

rule "A1C_2"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("A1C") == true )
        eval( m.getDataAsDouble() <= 2.0 )
        eval( m.getDataAsDouble() > 0.079 )
    then
        m.log("A1C RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
