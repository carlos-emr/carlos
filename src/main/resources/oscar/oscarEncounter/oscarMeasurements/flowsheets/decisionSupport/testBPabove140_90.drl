// ============================================================================
// CARLOS EMR - Clinical Report Numerator: BP Above 140/90 (13-Month Window)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with BP >140/90
//   AND measurement recorded within the last 13 months (general
//   hypertension threshold, not the stricter diabetes target of 130/80).
//
// ORPHANED: This file is NOT referenced by any XML config or Java code.
//   It was likely created for a custom report that was later removed.
//   Candidate for deletion if confirmed unused.
//
// Fact: MeasurementDSHelper - getNumberFromSplit("/",0/1) for systolic/
//   diastolic, getLastDateRecordedInMths() for recency check.
// ============================================================================
package ReportBPAbove140_90;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// Both systolic >140 AND diastolic >90 with 13-month recency window.
// setMeasurement("BP") loads latest BP; getNumberFromSplit parses sys/dia.
// getLastDateRecordedInMths() <13 ensures only recent readings count.
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) > 140 )
        eval( m.getNumberFromSplit("/",1) > 90 )
        eval( m.getLastDateRecordedInMths() < 13 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setInRange(true);
end
