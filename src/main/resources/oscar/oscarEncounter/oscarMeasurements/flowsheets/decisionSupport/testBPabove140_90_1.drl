// CARLOS EMR - Clinical Report: BP Above 140/90 Threshold Test (Variant 1)
// Fact: MeasurementDSHelper. Converted from Drools 2.0 XML to 7.x DRL.
package ReportA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) > 140 )
        eval( m.getNumberFromSplit("/",1) > 90 )
        eval( m.getLastDateRecordedInMths() < 7 )
    then
        m.log("BP RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
