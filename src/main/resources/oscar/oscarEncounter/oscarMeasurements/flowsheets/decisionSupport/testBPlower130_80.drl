// ============================================================================
// CARLOS EMR - Clinical Report Numerator: BP At or Below 130/80 (DM Target)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with last recorded
//   BP <131/81 (i.e., <=130/80, the diabetes-specific target) AND measured
//   within the last 13 months. This is a quality indicator for diabetic
//   BP control. The 13-month window ensures only current readings count.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="bplt130_80"
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface
//
// Fact: MeasurementDSHelper - getNumberFromSplit("/",0/1) parses systolic/
//   diastolic, getLastDateRecordedInMths() checks recency.
// ============================================================================
package ReportBPLower130_80;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// BP <=130/80: Checks BOTH systolic (<131) AND diastolic (<81) components.
// Also requires recording within 13 months (getLastDateRecordedInMths < 13).
// Patient must pass ALL four conditions to be counted in the numerator.
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) < 131 )
        eval( m.getNumberFromSplit("/",1) < 81 )
        eval( m.getLastDateRecordedInMths() < 13 )
    then
        m.log("BP RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
