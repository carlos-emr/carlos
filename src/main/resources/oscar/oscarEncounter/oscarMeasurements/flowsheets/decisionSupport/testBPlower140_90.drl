// ============================================================================
// CARLOS EMR - Clinical Report Numerator: BP Below 140/90 (13-Month Window)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with BP <141/91
//   (i.e., <=140/90, the general hypertension target) AND measured
//   within the last 13 months.
//
// ORPHANED: This file is NOT referenced by any XML config or Java code.
//   Candidate for deletion if confirmed unused.
//
// Fact: MeasurementDSHelper - getNumberFromSplit("/",0/1) for systolic/
//   diastolic, getLastDateRecordedInMths() for recency check.
// ============================================================================
package ReportBPLower140_90;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// Both systolic <141 AND diastolic <91 (i.e., <=140/90) with 13-month window.
// General hypertension target (not diabetes-specific <130/80).
rule "BP"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("BP") == true )
        eval( m.getNumberFromSplit("/",0) < 141 )
        eval( m.getNumberFromSplit("/",1) < 91 )
        eval( m.getLastDateRecordedInMths() < 13 )
    then
        m.log("BP RULES IS GETTING RUN");
        m.setInRange(true);
end
