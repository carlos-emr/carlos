// ============================================================================
// CARLOS EMR - Clinical Report Numerator: CD4 Between 200-350 (Moderate
//              Immunosuppression)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting HIV patients with CD4 200-350
//   cells/uL. Sets inRange=true when CD4 count is between 200 and 350.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="cd4lt2t350"
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface (HIV program reports)
//
// Fact: MeasurementDSHelper - setMeasurement("CD4") loads latest CD4 count.
// ============================================================================
package ReportCD4;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// CD4 200-350 cells/uL: Range check using >=200 AND <=350.
// Inclusive on both bounds. No recency window.
rule "CD4"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("CD4") == true )
        eval( m.getDataAsDouble() >= 200 )
        eval( m.getDataAsDouble() <= 350 )
    then
        m.log("CD4 RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
