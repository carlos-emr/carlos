// ============================================================================
// CARLOS EMR - Clinical Report Numerator: LDL Below 2.0 mmol/L (At Target)
// ============================================================================
//
// Purpose:
//   Population health reporting rule counting patients with LDL <2.0 mmol/L
//   (the CCS high-risk target). Despite the filename "testLDLlower2p6",
//   the actual threshold in the code is 2.0, not 2.6 - this is a naming
//   inconsistency inherited from the original rules.
//
// Referenced By:
//   - XML: ClinicalReports.xml, Numerator id="ldllt2.6"
//     (name says "LDL lower than 2.5" - another inconsistency)
//   - Java: DroolsNumerator compiles and fires for each denominator patient
//   - Displayed in: Clinical Reports interface
//
// Fact: MeasurementDSHelper - setMeasurement("LDL") loads latest LDL value.
// ============================================================================
package ReportLDLLower2p6;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

// LDL <2.0 mmol/L: At high-risk CCS target. No recency window.
// THRESHOLD MISMATCH: Filename says 2.6, XML says 2.5, code uses 2.0.
rule "LDL"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("LDL") == true )
        eval( m.getDataAsDouble() < 2.0 )
    then
        m.log("LDL RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
