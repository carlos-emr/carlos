// CARLOS EMR - Clinical Report: LDL Lower Than 2.6 Threshold Test
// Fact: MeasurementDSHelper. Converted from Drools 2.0 XML to 7.x DRL.
package ReportA1C;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.util.MeasurementDSHelper;

rule "LDL"
    when
        m : MeasurementDSHelper()
        eval( m.setMeasurement("LDL") == true )
        eval( m.getDataAsDouble() < 2.0 )
    then
        m.log("LDL RULES IS GETTING RUN"+m.getDataAsDouble());
        m.setInRange(true);
end
