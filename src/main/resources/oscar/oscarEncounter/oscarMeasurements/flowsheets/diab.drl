        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") >= 12 )
    then
        m.log("EGFR 2 getting called");
        m.addWarning("EGFR","An eGFR value hasn't been recorded in "+m.getLastDateRecordedInMonths("EGFR")+" months");
