// ============================================================================
// CARLOS EMR - Diabetes Mellitus Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide clinical decision support for the Diabetes Management
//   flowsheet - the most widely used flowsheet in CARLOS EMR. They monitor
//   whether key diabetes-related measurements are overdue and generate
//   yellow "recommendation" or red "warning" alerts in the flowsheet UI.
//
// Clinical Context:
//   Diabetes mellitus (Type 1 and Type 2) requires systematic, ongoing
//   monitoring of glycemic control, cardiovascular risk factors, and
//   microvascular/macrovascular complications. The Canadian Diabetes
//   Association (Diabetes Canada) Clinical Practice Guidelines recommend
//   specific monitoring intervals for each measurement tracked here.
//
//   This is the MOST REUSED flowsheet DRL in CARLOS. It is referenced by
//   7 different flowsheet XML configurations, not just the diabetes flowsheet:
//     - diabetesFlowsheet.xml (primary diabetes flowsheet, ICD-9: 250)
//     - diabetesQueensFlowsheet.xml (CDM Indicators variant)
//     - omdDiabetesFlowsheet.xml (Ontario MD diabetes flowsheet variant)
//     - physicalFunctionFlowsheet.xml (physical function assessment)
//     - omdAsthmaFlowsheet.xml (asthma, uses diabetes rules for shared metrics)
//     - omdChf.xml (CHF variant, reuses diabetes monitoring schedule)
//     - omdCOPDFlowsheet.xml (COPD, uses diabetes rules for shared metrics)
//
// How It Works:
//   A MeasurementInfo fact object is inserted into the Drools working memory
//   by MeasurementFlowSheet.java. Each rule checks months since last recorded:
//     - getLastDateRecordedInMonths(type) returns months, or -1 if never recorded
//     - getLastValueAsInt(type) returns the last recorded integer value
//     - addRecommendation(type, msg) shows a YELLOW alert (approaching deadline)
//     - addWarning(type, msg) shows a RED alert (past deadline or never recorded)
//
// Alert Severity Tiers:
//   For each measurement type, there are typically 3 rules:
//     Rule "X 1" - RECOMMENDATION: moderately overdue (approaching deadline)
//     Rule "X 2" - WARNING: severely overdue (past deadline)
//     Rule "X 3" - WARNING: measurement has NEVER been recorded (-1)
//
// Measurement Monitoring Schedule:
//   3-month cycle (quarterly):  REBG, A1C, DMED, BP, BMED, BMI, DIER, NOSK
//   10-month cycle (annual):    LDL, TCHD, TG, LMED, FGLC, EYEE, ACR, EGFR,
//                                FTE, FTLS, PANE, EDGI, DMME, DMSM
//
// Referenced By:
//   - XML configs: diabetesFlowsheet.xml, diabetesQueensFlowsheet.xml,
//     omdDiabetesFlowsheet.xml, physicalFunctionFlowsheet.xml,
//     omdAsthmaFlowsheet.xml, omdChf.xml, omdCOPDFlowsheet.xml
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - Displayed in: E-Chart encounter view, Measurement Flowsheet panel
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created ~2006 as Drools 2.0 XML rules (Jay Gallagher, McMaster)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package DiabetesFlowSheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Blood Glucose Monitoring (REBG) - Random/Review Blood Glucose
// Quarterly review of blood glucose levels. In diabetes, regular glucose
// monitoring ensures glycemic control between A1C tests.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "REBG 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("REBG") >= 3 )
        eval( m.getLastDateRecordedInMonths("REBG") < 6 )
    then
        m.log("REBG 1 getting called");
        m.addRecommendation("REBG","Blood Glucose hasn't been reviewed in "+m.getLastDateRecordedInMonths("REBG")+" months");
end

rule "REBG 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("REBG") >= 6 )
    then
        m.log("REBG 2 getting called");
        m.addWarning("REBG","Blood Glucose hasn't been reviewed in "+m.getLastDateRecordedInMonths("REBG")+" months");
end

rule "REBG 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("REBG") ==  -1 )
    then
        m.log("REBG 3 getting called");
        m.addWarning("REBG","Blood Glucose hasn't been reviewed");
end

// ---------------------------------------------------------------------------
// Hemoglobin A1C (A1C)
// The gold standard for assessing glycemic control over the past 2-3 months.
// Diabetes Canada target: A1C <= 7.0% (0.07) for most adults with diabetes.
// A1C >= 7.0% (or >= 0.07 in decimal notation) triggers HIGH in diab-A1C.drl.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "A1C 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("A1C") >= 3 )
        eval( m.getLastDateRecordedInMonths("A1C") < 6 )
    then
        m.log("A1C 1 getting called");
        m.addRecommendation("A1C","An A1C hasn't been recorded in "+m.getLastDateRecordedInMonths("A1C")+" months");
end

rule "A1C 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("A1C") >= 6 )
    then
        m.log("A1C 2 getting called");
        m.addWarning("A1C","An A1C hasn't been recorded in "+m.getLastDateRecordedInMonths("A1C")+" months");
end

rule "A1C 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("A1C") ==  -1 )
    then
        m.log("A1C 3 getting called");
        m.addWarning("A1C","no A1C values has been recorded");
end

// ---------------------------------------------------------------------------
// Diabetes Medication Changes (DMED)
// Tracks whether diabetes medication changes have been recorded.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "DMED 1"
    when
