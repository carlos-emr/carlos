// ---------------------------------------------------------------------------
// Smoking Status - Number of Cigarettes (NOSK)
// Smoking dramatically increases cardiovascular risk in diabetic patients.
// Rules only fire for current smokers (last value != 0). If never recorded,
// prompts clinician to enter zero for non-smokers to establish baseline.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "NOSK 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") >= 3 )
        eval( m.getLastDateRecordedInMonths("NOSK") < 6 )
        eval( m.getLastValueAsInt("NOSK") != 0 )
    then
        m.log("NOSK 1 getting called");
        m.addRecommendation("NOSK","Number of Cigarettes hasn't been recorded in "+m.getLastDateRecordedInMonths("NOSK")+" months");
end

rule "NOSK 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") >= 6 )
        eval( m.getLastValueAsInt("NOSK") != 0 )
    then
        m.log("NOSK 2 getting called");
        m.addWarning("NOSK","Number of Cigarettes hasn't been recorded in "+m.getLastDateRecordedInMonths("NOSK")+" months");
end

rule "NOSK 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") ==  -1 )
    then
        m.log("NOSK 3 getting called");
        m.addWarning("NOSK","Number of Cigarrettes has never been recorded, if non smoker enter zero");
end

// ---------------------------------------------------------------------------
// LDL Cholesterol (LDL)
// Low-density lipoprotein is a primary cardiovascular risk factor.
// Diabetes Canada target: LDL <2.0 mmol/L for diabetic patients.
// See also: diab-LDL.drl for value-based alerting (HIGH >= 2.0, HIGH 1 >= 3.5).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "LDL 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LDL") >= 10 )
        eval( m.getLastDateRecordedInMonths("LDL") < 12 )
    then
        m.log("LDL 1 getting called");
        m.addRecommendation("LDL","LDL hasn't been recorded in "+m.getLastDateRecordedInMonths("LDL")+" months");
end

rule "LDL 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LDL") >= 12 )
    then
        m.log("LDL 2 getting called");
        m.addWarning("LDL","LDL hasn't been recorded in "+m.getLastDateRecordedInMonths("LDL")+" months");
end

rule "LDL 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LDL") ==  -1 )
    then
        m.log("LDL 3 getting called");
        m.addWarning("LDL","LDL has not been recorded");
end

// ---------------------------------------------------------------------------
// Total Cholesterol to HDL Ratio (TCHD)
// TC/HDL ratio is a strong predictor of cardiovascular risk. A ratio >4.0
// indicates elevated risk. See also: diab-TCHDL.drl for value-based alerting
// (HIGH >= 4.0, HIGH 1 >= 5.0).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "TCHD 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TCHD") >= 10 )
        eval( m.getLastDateRecordedInMonths("TCHD") < 12 )
    then
        m.log("TCHD 1 getting called");
        m.addRecommendation("TCHD","TC/HDL hasn't been recorded in "+m.getLastDateRecordedInMonths("TCHD")+" months");
end

rule "TCHD 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TCHD") >= 12 )
    then
        m.log("TCHD 2 getting called");
        m.addWarning("TCHD","TC/HDL hasn't been recorded in "+m.getLastDateRecordedInMonths("TCHD")+" months");
end

rule "TCHD 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TCHD") ==  -1 )
    then
        m.log("TCHD 3 getting called");
        m.addWarning("TCHD","TC/HDL has not been recorded");
end

