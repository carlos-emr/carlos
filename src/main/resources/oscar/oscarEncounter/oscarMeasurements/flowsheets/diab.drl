// ---------------------------------------------------------------------------
// Diabetes Education (DMME)
// Tracks whether the patient has received diabetes self-management education.
// Diabetes Canada recommends structured education programs covering blood
// glucose monitoring, medication management, nutrition, and physical activity.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "DMME 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMME") >= 10 )
        eval( m.getLastDateRecordedInMonths("DMME") < 12 )
    then
        m.log("DMME 1 getting called");
        m.addRecommendation("DMME","A value for Diabetes Education hasn't been recorded in "+m.getLastDateRecordedInMonths("DMME")+" months");
end

rule "DMME 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMME") >= 12 )
    then
        m.log("DMME 2 getting called");
        m.addWarning("DMME","A value for Diabetes Education hasn't been recorded in "+m.getLastDateRecordedInMonths("DMME")+" months");
end

rule "DMME 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMME") ==  -1 )
    then
        m.log("DMME 3 getting called");
        m.addWarning("DMME","A value for Diabetes Education has not been recorded");
end

// ---------------------------------------------------------------------------
// Diabetes Self-Management Goals (DMSM)
// Tracks whether personalized self-management goals have been reviewed
// and updated with the patient. This is distinct from DMME (diabetes
// education) - DMSM focuses on individual goal-setting and action plans
// developed collaboratively between patient and provider.
// Note: Rule "DMSM 1" message text says "Diabetes Education" but this is
// a display message inconsistency; the measurement type is DMSM (Self-Mgmt).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "DMSM 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMSM") >= 10 )
        eval( m.getLastDateRecordedInMonths("DMSM") < 12 )
    then
        m.log("DMSM 1 getting called");
        m.addRecommendation("DMSM","A value for Diabetes Education hasn't been recorded in "+m.getLastDateRecordedInMonths("DMSM")+" months");
end

rule "DMSM 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMSM") >= 12 )
    then
        m.log("DMSM 2 getting called");
        m.addWarning("DMSM","A value for Diabetes Self Management Goals hasn't been recorded in "+m.getLastDateRecordedInMonths("DMSM")+" months");
end

rule "DMSM 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMSM") ==  -1 )
    then
        m.log("DMSM 3 getting called");
        m.addWarning("DMSM","A value for Diabetes Self Management Goals has not been recorded");
end
