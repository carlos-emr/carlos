// ---------------------------------------------------------------------------
// Fasting Glucose Meter/Lab Comparison (FGLC)
// Compares home glucose meter readings to laboratory values to ensure
// meter accuracy. Important for patients self-monitoring blood glucose.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "FGLC 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FGLC") >= 10 )
        eval( m.getLastDateRecordedInMonths("FGLC") < 12 )
    then
        m.log("FGLC 1 getting called");
        m.addRecommendation("FGLC","Fasting glucose meter/lab comparison hasn't been recorded in  "+m.getLastDateRecordedInMonths("FGLC")+" months");
end

rule "FGLC 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FGLC") >= 12 )
    then
        m.log("FGLC 2 getting called");
        m.addWarning("FGLC","Fasting glucose meter/lab comparison hasn't been recorded in  "+m.getLastDateRecordedInMonths("FGLC")+" months");
end

rule "FGLC 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FGLC") ==  -1 )
    then
        m.log("FGLC 3 getting called");
        m.addWarning("FGLC","Fasting glucose meter/lab comparison has not been recorded");
end

// ---------------------------------------------------------------------------
// Ophthalmologist/Optometrist Eye Exam (EYEE)
// Annual dilated eye exam to screen for diabetic retinopathy, the leading
// cause of blindness in working-age adults. Diabetes Canada recommends
// screening within 5 years of Type 1 diagnosis, at diagnosis for Type 2,
// then annually.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "EYEE 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EYEE") >= 10 )
        eval( m.getLastDateRecordedInMonths("EYEE") < 12 )
    then
        m.log("EYEE 1 getting called");
        m.addRecommendation("EYEE","An Opthalmologist/ Optometrist exam hasn't been recorded in  "+m.getLastDateRecordedInMonths("EYEE")+" months");
end

rule "EYEE 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EYEE") >= 12 )
    then
        m.log("EYEE 2 getting called");
        m.addWarning("EYEE","An Opthalmologist/ Optometrist exam hasn't been recorded in  "+m.getLastDateRecordedInMonths("EYEE")+" months");
end

rule "EYEE 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EYEE") ==  -1 )
    then
        m.log("EYEE 3 getting called");
        m.addWarning("EYEE","An Opthalmologist/ Optometrist exam has not been recorded");
end

// ---------------------------------------------------------------------------
// Albumin-to-Creatinine Ratio (ACR)
// Urine ACR screens for diabetic nephropathy (kidney damage from diabetes).
// See also: diab-ACR.drl for value-based alerting (HIGH if >= 2.0 mg/mmol).
// Diabetes Canada recommends annual screening starting at diagnosis for Type 2.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "ACR 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") >= 10 )
        eval( m.getLastDateRecordedInMonths("ACR") < 12 )
    then
        m.log("ACR 1 getting called");
        m.addRecommendation("ACR","An Alb: creat ratio value hasn't been recorded in "+m.getLastDateRecordedInMonths("ACR")+" months");
end

rule "ACR 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") >= 12 )
    then
        m.log("ACR 2 getting called");
        m.addWarning("ACR","An Alb: creat ratio value hasn't been recorded in "+m.getLastDateRecordedInMonths("ACR")+" months");
end

rule "ACR 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ACR") ==  -1 )
    then
        m.log("ACR 3 getting called");
        m.addWarning("ACR","An Alb: creat ratio value has not been recorded");
end

// ---------------------------------------------------------------------------
// Estimated Glomerular Filtration Rate (eGFR)
// Tracks whether eGFR has been recorded.
// See also: diab-EFGR.drl for value-based alerting (LOW if <= 60).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "EGFR 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") >= 10 )
        eval( m.getLastDateRecordedInMonths("EGFR") < 12 )
