        eval( m.getLastDateRecordedInMonths("DMED") >= 3 )
        eval( m.getLastDateRecordedInMonths("DMED") < 6 )
    then
        m.log("DMED 1 getting called");
        m.addRecommendation("DMED","DM Med changes haven't been recorded in "+m.getLastDateRecordedInMonths("DMED")+" months");
end

rule "DMED 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMED") >= 6 )
    then
        m.log("DMED 2 getting called");
        m.addWarning("DMED","DM Med changes haven't been recorded in "+m.getLastDateRecordedInMonths("DMED")+" months");
end

rule "DMED 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("DMED") ==  -1 )
    then
        m.log("DMED 3 getting called");
        m.addWarning("DMED","no DM Med changes have been recorded");
end

// ---------------------------------------------------------------------------
// Blood Pressure (BP)
// Hypertension is extremely common in diabetes and accelerates both
// macrovascular (heart attack, stroke) and microvascular (nephropathy,
// retinopathy) complications. Diabetes Canada target: <130/80 mmHg.
// See also: diab-BP.drl for value-based threshold alerting.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "BP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") >= 3 )
        eval( m.getLastDateRecordedInMonths("BP") < 6 )
    then
        m.log("BP 1 getting called");
        m.addRecommendation("BP","BP hasn't been recorded in "+m.getLastDateRecordedInMonths("BP")+" months");
end

rule "BP 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") >= 6 )
    then
        m.log("BP 2 getting called");
        m.addWarning("BP","BP hasn't been recorded in "+m.getLastDateRecordedInMonths("BP")+" months");
end

rule "BP 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") ==  -1 )
    then
        m.log("BP 3 getting called");
        m.addWarning("BP","no BP has been recorded");
end

