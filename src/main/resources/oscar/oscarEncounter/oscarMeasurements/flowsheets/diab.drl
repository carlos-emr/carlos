        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EGFR") ==  -1 )
    then
        m.log("EGFR 3 getting called");
        m.addWarning("EGFR","An eGFR value has not been recorded");
end

// ---------------------------------------------------------------------------
// Lower Extremity Exam / Foot Exam (FTE)
// Annual comprehensive foot exam for diabetic patients to detect peripheral
// vascular disease, neuropathy, deformities, and skin breakdown. Diabetic
// foot ulcers are a leading cause of non-traumatic lower limb amputation.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "FTE 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTE") >= 10 )
        eval( m.getLastDateRecordedInMonths("FTE") < 12 )
    then
        m.log("FTE 1 getting called");
        m.addRecommendation("FTE","A Lower Extremity Exam hasn't been recorded in "+m.getLastDateRecordedInMonths("FTE")+" months");
end

rule "FTE 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTE") >= 12 )
    then
        m.log("FTE 2 getting called");
        m.addWarning("FTE","A Lower Extremity Exam hasn't been recorded in "+m.getLastDateRecordedInMonths("FTE")+" months");
end

rule "FTE 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTE") ==  -1 )
    then
        m.log("FTE 3 getting called");
        m.addWarning("FTE","A Lower Extremity Exam has not been recorded");
end

// ---------------------------------------------------------------------------
// Loss of Sensation Test (FTLS) - Monofilament Testing
// 10g monofilament test to detect peripheral neuropathy (loss of protective
// sensation). Loss of sensation is the primary risk factor for diabetic
// foot ulceration. Should be tested at each annual foot exam.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "FTLS 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTLS") >= 10 )
        eval( m.getLastDateRecordedInMonths("FTLS") < 12 )
    then
        m.log("FTLS 1 getting called");
        m.addRecommendation("FTLS","A loss of sensation test hasn't been recorded in "+m.getLastDateRecordedInMonths("FTLS")+" months");
end

rule "FTLS 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTLS") >= 12 )
    then
        m.log("FTLS 2 getting called");
        m.addWarning("FTLS","A loss of sensation test hasn't been recorded in "+m.getLastDateRecordedInMonths("FTLS")+" months");
end

rule "FTLS 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTLS") ==  -1 )
    then
        m.log("FTLS 3 getting called");
        m.addWarning("FTLS","A loss of sensation test has not been recorded");
end

// ---------------------------------------------------------------------------
// Painful Neuropathy (PANE)
// Tracks whether painful neuropathy assessment has been recorded.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "PANE 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("PANE") >= 10 )
        eval( m.getLastDateRecordedInMonths("PANE") < 12 )
    then
        m.log("PANE 1 getting called");
        m.addRecommendation("PANE","A value for Painful Neuropathy hasn't been recorded in "+m.getLastDateRecordedInMonths("PANE")+" months");
end

rule "PANE 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("PANE") >= 12 )
    then
        m.log("PANE 2 getting called");
        m.addWarning("PANE","A value for Painful Neuropathy hasn't been recorded in "+m.getLastDateRecordedInMonths("PANE")+" months");
end

rule "PANE 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("PANE") ==  -1 )
    then
        m.log("PANE 3 getting called");
        m.addWarning("PANE","A value for Painful Neuropathy has not been recorded");
end

