// ============================================================================
// CARLOS EMR - Financial Assessment Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide decision support for the Financial Assessment
//   flowsheet, part of the CAISI (Client Access to Integrated Services and
//   Information) community health module. They monitor whether key financial
//   and social determinant questions have been answered within the past year.
//
// Clinical Context:
//   Social determinants of health, including financial stability, employment,
//   and access to benefits programs, significantly impact health outcomes.
//   This flowsheet is used by community health centres (CHCs) and programs
//   serving marginalized populations (homeless, underhoused, mental health,
//   substance use). It tracks eligibility and enrollment in Canadian social
//   assistance programs:
//     - OW: Ontario Works (provincial social assistance)
//     - ODSP: Ontario Disability Support Program
//     - CPP: Canada Pension Plan (federal pension)
//     - OAS: Old Age Security (federal seniors benefit)
//     - GAIN: Guaranteed Annual Income for Need
//     - Empl: Employment status/income
//     - FTHR: Family/Third-Party financial support
//     - PGT: Public Guardian and Trustee
//     - SPDT: Spending/budgeting assessment
//     - Fsup: Financial support services referral
//
// How It Works:
//   Unlike the clinical flowsheets which have 3 tiers per measurement, this
//   flowsheet uses a simpler 2-rule pattern per question:
//     Rule "X 1" - WARNING: question not answered in 12+ months
//     Rule "X 2" - WARNING: question has NEVER been answered (-1)
//   There are no "recommendation" tier alerts - only warnings at 12 months.
//
// Referenced By:
//   - XML config: financesFlowsheet.xml (ds_rules="finances.drl",
//     is_universal="true", is_medical="false")
//   - Java: MeasurementFlowSheet.loadRuleBase(String) compiles this DRL
//   - Displayed in: E-Chart encounter view, CAISI community health programs
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created for CAISI community health module (McMaster)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package FinancesFlowsheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Ontario Works (OW)
// Provincial social assistance program providing financial and employment
// assistance to people in need in Ontario.
// Warning at 12 months.
// ---------------------------------------------------------------------------
rule "OW 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OW") >= 12 )
    then
        m.addWarning("OW","Question not answered in "+m.getLastDateRecordedInMonths("OW")+" months");
end

rule "OW 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OW") == -1 )
    then
        m.addWarning("OW","Question not answered");
end

// Ontario Disability Support Program (ODSP)
// Provincial disability income support for people with disabilities in Ontario.
rule "ODSP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ODSP") >= 12 )
    then
        m.addWarning("ODSP","Question not answered in "+m.getLastDateRecordedInMonths("ODSP")+" months");
end

rule "ODSP 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("ODSP") == -1 )
    then
        m.addWarning("ODSP","Question not answered");
end

// Canada Pension Plan (CPP)
// Federal retirement/disability pension. CPP Disability is available to
// contributors who cannot work due to a severe and prolonged disability.
rule "CPP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("CPP") >= 12 )
    then
        m.addWarning("CPP","Question not answered in "+m.getLastDateRecordedInMonths("CPP")+" months");
end

rule "CPP 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("CPP") == -1 )
    then
        m.addWarning("CPP","Question not answered");
end

// Old Age Security (OAS)
// Federal pension program for Canadians aged 65+. Includes Guaranteed
// Income Supplement (GIS) for low-income seniors.
rule "OAS 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OAS") >= 12 )
    then
        m.addWarning("OAS","Question not answered in "+m.getLastDateRecordedInMonths("OAS")+" months");
end

rule "OAS 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OAS") == -1 )
    then
        m.addWarning("OAS","Question not answered");
end

// Guaranteed Annual Income for Need (GAIN)
// Provincial income supplement programs for low-income individuals.
rule "GAIN 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("GAIN") >= 12 )
    then
        m.addWarning("GAIN","Question not answered in "+m.getLastDateRecordedInMonths("GAIN")+" months");
end

rule "GAIN 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("GAIN") == -1 )
    then
        m.addWarning("GAIN","Question not answered");
end

// Employment Status (Empl)
// Tracks current employment status and income sources.
rule "Empl 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Empl") >= 12 )
    then
        m.addWarning("Empl","Question not answered in "+m.getLastDateRecordedInMonths("Empl")+" months");
end

rule "Empl 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Empl") == -1 )
    then
        m.addWarning("Empl","Question not answered");
end

// Family/Third-Party Financial Support (FTHR)
// Whether the client receives financial support from family or other parties.
rule "FTHR 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTHR") >= 12 )
    then
        m.addWarning("FTHR","Question not answered in "+m.getLastDateRecordedInMonths("FTHR")+" months");
end

rule "FTHR 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("FTHR") == -1 )
    then
        m.addWarning("FTHR","Question not answered");
end

// Public Guardian and Trustee (PGT)
// Whether the client's finances are managed by the Office of the Public
// Guardian and Trustee, typically for individuals who are incapable of
// managing their own financial affairs.
rule "PGT 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("PGT") >= 12 )
    then
        m.addWarning("PGT","Question not answered in "+m.getLastDateRecordedInMonths("PGT")+" months");
end

rule "PGT 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("PGT") == -1 )
    then
        m.addWarning("PGT","Question not answered");
end

// Spending/Budgeting Assessment (SPDT)
// Assessment of the client's ability to manage spending and budgeting.
rule "SPDT 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SPDT") >= 12 )
    then
        m.addWarning("SPDT","Question not answered in "+m.getLastDateRecordedInMonths("SPDT")+" months");
end

rule "SPDT 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SPDT") == -1 )
    then
        m.addWarning("SPDT","Question not answered");
end

// Financial Support Services (Fsup)
// Whether the client has been connected with financial support services
// (e.g., financial counselling, tax filing assistance, benefits navigation).
rule "Fsup 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Fsup") >= 12 )
    then
        m.addWarning("Fsup","Question not answered in "+m.getLastDateRecordedInMonths("Fsup")+" months");
end

rule "Fsup 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Fsup") == -1 )
    then
        m.addWarning("Fsup","Question not answered");
end
