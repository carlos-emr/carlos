// ---------------------------------------------------------------------------
// HIV Testing / Partner Notification (UHTP)
// Tracks whether HIV testing and partner notification status has been
// reviewed. Includes re-testing of indeterminate results, confirmatory
// testing, and documentation of partner notification/contact tracing
// as required by Canadian public health guidelines for reportable STIs.
// Recommendation at 6 months, warning at 9 months.
// ---------------------------------------------------------------------------
rule "UHTP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("UHTP") >= 6 )
        eval( m.getLastDateRecordedInMonths("UHTP") < 9 )
    then
        m.log("UHTP 1 getting called");
        m.addRecommendation("UHTP","UHTP hasn't been recorded in "+m.getLastDateRecordedInMonths("UHTP")+" months");
end

