        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("UHTP") ==  -1 )
    then
        m.log("UHTP 3 getting called");
        m.addWarning("UHTP","no UHTP has been recorded");
end

// ---------------------------------------------------------------------------
// Vitamin B12 (VB12)
// Tracks whether Vitamin B12 has been recorded.
// Note: Uses 12mo/18mo schedule (annual monitoring, longer than lipids).
// Recommendation at 12 months, warning at 18 months.
// ---------------------------------------------------------------------------
rule "VB12 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("VB12") >= 12 )
        eval( m.getLastDateRecordedInMonths("VB12") < 18 )
    then
        m.log("VB12 1 getting called");
        m.addRecommendation("VB12","Vit B12 hasn't been recorded in "+m.getLastDateRecordedInMonths("VB12")+" months");
