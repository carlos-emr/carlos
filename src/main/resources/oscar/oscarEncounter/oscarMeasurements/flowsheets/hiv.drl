// ============================================================================
// CARLOS EMR - HIV/AIDS Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide clinical decision support for the HIV/AIDS management
//   flowsheet. They monitor whether key HIV-related laboratory tests,
//   co-infection screenings, and metabolic assessments are overdue.
//
// Clinical Context:
//   HIV-positive patients on antiretroviral therapy (ART) require regular
//   monitoring of viral suppression (viral load), immune status (CD4 count),
//   organ function (liver, kidney), metabolic parameters (glucose, lipids),
//   and screening for common co-infections (Hepatitis A/B/C, CMV, syphilis,
//   toxoplasmosis). These rules encode the Canadian HIV/AIDS monitoring
//   schedule as used by community health centres and HIV specialty clinics.
//
//   This is one of the LARGEST rule files in CARLOS with 25 measurement
//   types monitored across immunological, virological, metabolic, hepatic,
//   renal, and co-infection screening domains.
//
// Measurement Types Monitored:
//   Quarterly (3mo recommend / 6mo warn):
//     CD4  - CD4+ T-lymphocyte count (immune status)
//     VLOA - Viral Load (HIV RNA copies/mL)
//   Annual (10mo recommend / 12mo warn):
//     Hb   - Hemoglobin (anemia screening)
//     ALT  - Alanine aminotransferase (liver function)
//     FBS  - Fasting blood sugar (metabolic screening)
//     TCHL - Total cholesterol
//     LDL  - LDL cholesterol
//     HDL  - HDL cholesterol
//     TG   - Triglycerides
//     URBH - Urea/BUN (renal function)
//     USSH - Serum creatinine/eGFR (renal function)
//     UDUS - Urinalysis/dipstick (proteinuria screening)
//     UAIP - Urine albumin/protein (nephropathy screening)
//     UHTP - HIV testing/partner notification
//     VB12 - Vitamin B12
//     FTST - Fasting testosterone
//     VDRL - Syphilis screening (VDRL/RPR)
//     TOXP - Toxoplasma gondii serology
//     HpAI - Hepatitis A IgG antibody
//     HpBS - Hepatitis B surface antigen
//     HpBA - Hepatitis B surface antibody
//     HpCA - Hepatitis C antibody
//     CMVI - Cytomegalovirus (CMV) IgG
//     G6PD - Glucose-6-Phosphate Dehydrogenase
//
// Referenced By:
//   - XML config: hivFlowsheet.xml (ds_rules="hiv.drl")
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - Displayed in: E-Chart encounter view, Measurement Flowsheet panel
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster/community health)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package HIVFlowSheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// CD4+ T-Lymphocyte Count (CD4)
// Tracks whether CD4 count has been recorded.
// See also: testCD4*.drl for value-based clinical reporting thresholds.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "CD4 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("CD4") >= 3 )
        eval( m.getLastDateRecordedInMonths("CD4") < 6 )
    then
        m.log("CD4 1 getting called");
        m.addRecommendation("CD4","CD4 hasn't been reviewed in "+m.getLastDateRecordedInMonths("CD4")+" months");
end

rule "CD4 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("CD4") >= 6 )
    then
        m.log("CD4 2 getting called");
        m.addWarning("CD4","CD4 hasn't been reviewed in "+m.getLastDateRecordedInMonths("CD4")+" months");
end

rule "CD4 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("CD4") ==  -1 )
    then
        m.log("CD4 3 getting called");
        m.addWarning("CD4","CD4 hasn't been reviewed");
end

// ---------------------------------------------------------------------------
// HIV Viral Load (VLOA)
// Measures HIV RNA copies/mL in plasma. The primary marker of ART efficacy.
// Goal of treatment: undetectable viral load (<50 copies/mL). Detectable
// viral load suggests treatment failure, non-adherence, or drug resistance.
// Monitored quarterly along with CD4.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "VLOA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("VLOA") >= 3 )
        eval( m.getLastDateRecordedInMonths("VLOA") < 6 )
    then
        m.log("VLOA 1 getting called");
        m.addRecommendation("VLOA","A Viral Load hasn't been recorded in "+m.getLastDateRecordedInMonths("VLOA")+" months");
end

rule "VLOA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("VLOA") >= 6 )
    then
        m.log("VLOA 2 getting called");
        m.addWarning("VLOA","A Viral Load hasn't been recorded in "+m.getLastDateRecordedInMonths("VLOA")+" months");
end

rule "VLOA 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("VLOA") ==  -1 )
    then
        m.log("VLOA 3 getting called");
        m.addWarning("VLOA","no Viral Load values has been recorded");
end

