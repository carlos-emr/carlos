// ---------------------------------------------------------------------------
// Triglycerides (TG)
// Elevated triglycerides are part of the metabolic syndrome cluster
// (hypertension, dyslipidemia, insulin resistance, central obesity).
// Hypertriglyceridemia is an independent cardiovascular risk factor.
// Target: <1.7 mmol/L (fasting).
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "TG 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TG") >= 10 )
        eval( m.getLastDateRecordedInMonths("TG") < 12 )
    then
        m.log("TG 1 getting called");
        m.addRecommendation("TG","Triglycerides hasn't been recorded in "+m.getLastDateRecordedInMonths("TG")+" months");
end

rule "TG 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TG") >= 12 )
    then
        m.log("TG 2 getting called");
        m.addWarning("TG","Triglycerides hasn't been recorded in "+m.getLastDateRecordedInMonths("TG")+" months");
end

rule "TG 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("TG") ==  -1 )
    then
        m.log("TG 3 getting called");
        m.addWarning("TG","Triglycerides has not been recorded");
end

