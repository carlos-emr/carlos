// ---------------------------------------------------------------------------
// Body Mass Index (BMI)
// BMI correlates with cardiovascular risk. Target BMI 18.5-24.9 kg/m2.
// Overweight (BMI 25-29.9) and obese (BMI >=30) patients benefit from
// structured weight management as part of hypertension treatment.
// See also: diab-BMI.drl for value-based BMI threshold rules.
// Recommendation at 10 months, warning at 12 months.
// ---------------------------------------------------------------------------
rule "BMI 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BMI") >= 10 )
        eval( m.getLastDateRecordedInMonths("BMI") < 12 )
    then
        m.log("BMI 1 getting called");
        m.addRecommendation("BMI","BMI hasn't been recorded in "+m.getLastDateRecordedInMonths("BMI")+" months");
end

rule "BMI 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BMI") >= 12 )
    then
        m.log("BMI 2 getting called");
        m.addWarning("BMI","BMI hasn't been recorded in "+m.getLastDateRecordedInMonths("BMI")+" months");
end

rule "BMI 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BMI") ==  -1 )
    then
        m.log("BMI 3 getting called");
        m.addWarning("BMI","no BMI has been recorded");
end

