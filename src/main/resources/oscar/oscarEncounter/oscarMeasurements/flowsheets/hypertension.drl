// ============================================================================
// CARLOS EMR - Hypertension Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide clinical decision support for the Hypertension
//   management flowsheet. They monitor whether key blood pressure, lifestyle,
//   and cardiovascular risk measurements are overdue and generate yellow
//   "recommendation" or red "warning" alerts in the flowsheet UI.
//
// Clinical Context:
//   Hypertension affects approximately 1 in 4 Canadian adults and is the
//   leading modifiable risk factor for stroke, heart failure, and chronic
//   kidney disease. Hypertension Canada guidelines recommend regular
//   monitoring of BP, lifestyle factors (diet, exercise, sodium, alcohol,
//   smoking, weight), and end-organ damage markers (ACR, eGFR, lipids).
//
// Measurement Types Monitored:
//   Quarterly (3mo recommend / 6mo warn):
//     BP   - Blood pressure (systolic/diastolic)
//     NOSK - Number of cigarettes smoked per day (conditional: only if >0)
//     DIER - Diet and exercise counselling
//     SODI - Sodium/salt intake assessment
//     DRPW - Alcoholic drinks per week
//     WT   - Body weight
//   Annual (10mo recommend / 12mo warn):
//     BMI  - Body Mass Index
//     ACR  - Albumin-to-creatinine ratio (kidney damage screening)
//     TCHD - Total cholesterol to HDL ratio (cardiovascular risk)
//     LDL  - LDL cholesterol
//     TG   - Triglycerides
//     EGFR - Estimated glomerular filtration rate (kidney function)
//
// Referenced By:
//   - XML config: hypertensionFlowsheet.xml (ds_rules="hypertension.drl",
//     triggered by ICD-9 code 401)
//   - XML config: omdHypertensionFlowsheet.xml (ds_rules="hypertension.drl",
//     Ontario-MD variant)
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - Displayed in: E-Chart encounter view, Measurement Flowsheet panel
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created as Drools 2.0 XML rules (McMaster University)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package HypertensionFlowSheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Blood Pressure (BP)
// The primary measurement for hypertension management. Hypertension Canada
// targets: <140/90 for most adults, <130/80 for diabetes or CKD.
// Quarterly monitoring ensures treatment adherence and titration.
// See also: diab-BP.drl for value-based BP threshold rules.
// Recommendation at 3 months, warning at 6 months.
// ---------------------------------------------------------------------------
rule "BP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") >= 3 )
        eval( m.getLastDateRecordedInMonths("BP") < 6 )
    then
        m.log("BP 1 getting called");
        m.addRecommendation("BP","BP hasn't been reviewed in "+m.getLastDateRecordedInMonths("BP")+" months");
end

rule "BP 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") >= 6 )
    then
        m.log("BP 2 getting called");
        m.addWarning("BP","BP hasn't been reviewed in "+m.getLastDateRecordedInMonths("BP")+" months");
end

rule "BP 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BP") ==  -1 )
    then
        m.log("BP 3 getting called");
        m.addWarning("BP","BP hasn't been reviewed");
end

// ---------------------------------------------------------------------------
// Number of Cigarettes Smoked per Day (NOSK)
// Smoking is a major modifiable cardiovascular risk factor. Hypertension +
// smoking dramatically increases stroke and MI risk. Note the conditional
// logic: NOSK 1 and NOSK 2 only fire if the last recorded value was >0
// (i.e., the patient is a smoker). Non-smokers (value=0) won't get alerts.
// NOSK 3 fires if smoking status has NEVER been recorded (prompts initial
// assessment regardless of smoking status).
// Recommendation at 3 months, warning at 6 months (smokers only).
// ---------------------------------------------------------------------------
rule "NOSK 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") >= 3 )
        eval( m.getLastDateRecordedInMonths("NOSK") < 6 )
        eval( m.getLastValueAsInt("NOSK") != 0 )
    then
        m.log("NOSK 1 getting called");
        m.addRecommendation("NOSK","Number of Cigarettes hasn't been recorded in "+m.getLastDateRecordedInMonths("NOSK")+" months");
end

rule "NOSK 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") >= 6 )
        eval( m.getLastValueAsInt("NOSK") != 0 )
    then
        m.log("NOSK 2 getting called");
        m.addWarning("NOSK","Number of Cigarettes hasn't been recorded in "+m.getLastDateRecordedInMonths("NOSK")+" months");
end

rule "NOSK 3"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("NOSK") ==  -1 )
    then
        m.log("NOSK 3 getting called");
        m.addWarning("NOSK","Number of Cigarrettes has never been recorded, if non smoker enter zero");
end

