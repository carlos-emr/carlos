// ============================================================================
// CARLOS EMR - Patient Identification Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide decision support for the Patient Identification
//   flowsheet, part of the CAISI (Client Access to Integrated Services and
//   Information) community health module. They monitor whether key
//   identification and immigration-related documents have been verified
//   within the past year.
//
// Clinical Context:
//   For marginalized populations served by community health centres - including
//   homeless individuals, refugees, and undocumented persons - maintaining
//   current identification documents is critical for accessing healthcare,
//   social assistance, housing, and employment. Many clients lack standard
//   government ID, which creates barriers to care. This flowsheet tracks
//   document status to support navigation and advocacy services.
//
//   Measurement Types Monitored:
//     - OHIP: Ontario Health Insurance Plan card (provincial health coverage)
//     - SIN:  Social Insurance Number (federal tax/benefits identification)
//     - BCRT: Birth Certificate (foundational identity document)
//     - LAND: Landed Immigrant / Permanent Resident status
//     - Citz: Canadian Citizenship status
//     - Othi: Other Identification documents (e.g., passport, photo ID)
//     - Isup: Identification Support services (referral for ID procurement)
//
// Known Bug:
//   Rules "Citz 1", "Othi 1", and "Isup 1" incorrectly pass "LAND" as the
//   measurement type to addWarning() instead of their own codes. This means
//   warnings for citizenship, other ID, and ID support overdue status will
//   appear in the LAND row of the flowsheet rather than their correct rows.
//   This is an inherited upstream bug from the original OSCAR CAISI rules.
//
// How It Works:
//   Uses the simple 2-rule pattern per question (warning only, no recommendation):
//     Rule "X 1" - WARNING: question not answered in 12+ months
//     Rule "X 2" - WARNING: question has NEVER been answered (-1)
//
// Referenced By:
//   - XML config: identificationFlowsheet.xml (ds_rules="identification.drl",
//     is_universal="true", is_medical="false")
//   - Java: MeasurementFlowSheet.loadRuleBase(String) compiles this DRL
//   - Displayed in: E-Chart encounter view, CAISI community health programs
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created for CAISI community health module (McMaster)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package IdentificationFlowsheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Ontario Health Insurance Plan (OHIP)
// OHIP card provides access to publicly funded healthcare in Ontario.
// Many marginalized clients lose or lack OHIP cards, creating barriers
// to primary care, prescriptions, and specialist referrals. Annual
// verification ensures the card is current and valid.
// Warning at 12 months.
// ---------------------------------------------------------------------------
rule "OHIP 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OHIP") >= 12 )
    then
        m.addWarning("OHIP","Question not answered in "+m.getLastDateRecordedInMonths("OHIP")+" months");
end

rule "OHIP 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("OHIP") == -1 )
    then
        m.addWarning("OHIP","Question not answered");
end

// Social Insurance Number (SIN)
// Required for employment, tax filing, and accessing federal benefits
// (EI, CPP, OAS, child benefits). Helps connect clients to income support.
rule "SIN 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SIN") >= 12 )
    then
        m.addWarning("SIN","Question not answered in "+m.getLastDateRecordedInMonths("SIN")+" months");
end

rule "SIN 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SIN") == -1 )
    then
        m.addWarning("SIN","Question not answered");
end

// Birth Certificate (BCRT)
// Foundational identity document needed to obtain other government ID.
// Many homeless and marginalized clients lack birth certificates, which
// must be ordered from the province/territory of birth.
rule "BCRT 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BCRT") >= 12 )
    then
        m.addWarning("BCRT","Question not answered in "+m.getLastDateRecordedInMonths("BCRT")+" months");
end

rule "BCRT 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("BCRT") == -1 )
    then
        m.addWarning("BCRT","Question not answered");
end

// Landed Immigrant / Permanent Resident Status (LAND)
// PR card status for non-citizens. Permanent residents have OHIP eligibility
// after the 3-month waiting period. Tracking PR status helps with healthcare
// coverage navigation and citizenship application timelines.
rule "LAND 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LAND") >= 12 )
    then
        m.addWarning("LAND","Question not answered in "+m.getLastDateRecordedInMonths("LAND")+" months");
end

rule "LAND 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LAND") == -1 )
    then
        m.addWarning("LAND","Question not answered");
end

// Canadian Citizenship Status (Citz)
// Tracks citizenship status or application progress. Citizenship provides
// full access to Canadian services and the right to vote.
// BUG: Rule "Citz 1" passes "LAND" instead of "Citz" to addWarning().
rule "Citz 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Citz") >= 12 )
    then
        m.addWarning("LAND","Question not answered in "+m.getLastDateRecordedInMonths("Citz")+" months");
end

rule "Citz 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Citz") == -1 )
    then
        m.addWarning("Citz","Question not answered");
end

// Other Identification Documents (Othi)
// Tracks other forms of ID such as passport, provincial photo ID card,
// driver's licence, or refugee claimant document.
// BUG: Rule "Othi 1" passes "LAND" instead of "Othi" to addWarning().
rule "Othi 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Othi") >= 12 )
    then
        m.addWarning("LAND","Question not answered in "+m.getLastDateRecordedInMonths("Othi")+" months");
end

rule "Othi 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Othi") == -1 )
    then
        m.addWarning("Othi","Question not answered");
end

// Identification Support Services (Isup)
// Whether the client has been connected with ID procurement services
// (e.g., help obtaining birth certificates, OHIP applications, photo ID).
// BUG: Rule "Isup 1" passes "LAND" instead of "Isup" to addWarning().
rule "Isup 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Isup") >= 12 )
    then
        m.addWarning("LAND","Question not answered in "+m.getLastDateRecordedInMonths("Isup")+" months");
end

rule "Isup 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Isup") == -1 )
    then
        m.addWarning("Isup","Question not answered");
end
