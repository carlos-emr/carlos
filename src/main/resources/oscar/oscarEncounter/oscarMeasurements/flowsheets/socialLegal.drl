// ============================================================================
// CARLOS EMR - Social/Legal Assessment Flowsheet Rules
// ============================================================================
//
// Rules for the social and legal assessment flowsheet used in community
// health settings. Evaluates when social/legal assessments need updating.
//
// Fact: MeasurementInfo - bound as "m"
// Converted from Drools 2.0 XML to Drools 7.x DRL format.
// ============================================================================
package SocialLegalFlowsheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

rule "HltA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("HltA") >= 12 )
    then
        m.addWarning("HltA","Question not answered in "+m.getLastDateRecordedInMonths("HltA")+" months");
end

rule "HltA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("HltA") == -1 )
    then
        m.addWarning("HltA","Question not answered");
end

