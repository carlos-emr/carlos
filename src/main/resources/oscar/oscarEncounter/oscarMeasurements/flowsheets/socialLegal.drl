// ============================================================================
// CARLOS EMR - Social/Legal Assessment Flowsheet Timeliness Rules
// ============================================================================
//
// Purpose:
//   These rules provide decision support for the Social and Legal Assessment
//   flowsheet, part of the CAISI (Client Access to Integrated Services and
//   Information) community health module. They monitor whether key social
//   determinant and legal status questions have been reviewed within the
//   past year.
//
// Clinical Context:
//   Social and legal factors profoundly impact health outcomes for
//   marginalized populations. Clients in community health programs may face
//   concurrent mental health issues, substance use disorders, legal
//   problems (criminal charges, custody issues, immigration hearings),
//   and barriers to education and employment. This flowsheet provides a
//   structured assessment to identify these needs and connect clients
//   with appropriate services.
//
//   Measurement Types Monitored:
//     - HltA: Health Assessment (overall health status review)
//     - MHA:  Mental Health Assessment (psychiatric symptom screening)
//     - SUA:  Substance Use Assessment (alcohol/drug use screening)
//     - Lwil: Living Will / Advance Directives (end-of-life planning)
//     - SoCm: Social/Community connections and supports
//     - EdTr: Education/Training status and goals
//     - EmpA: Employment Assessment (work readiness, barriers)
//     - LegA: Legal Assessment (outstanding legal issues, court dates)
//     - Osup: Other Support services (referrals to additional services)
//
// How It Works:
//   Uses the simple 2-rule pattern per question (warning only, no recommendation):
//     Rule "X 1" - WARNING: question not answered in 12+ months
//     Rule "X 2" - WARNING: question has NEVER been answered (-1)
//
// Referenced By:
//   - XML config: socialLegalFlowsheet.xml (ds_rules="socialLegal.drl",
//     is_universal="true", is_medical="false")
//   - Java: MeasurementFlowSheet.loadFlowsheetRuleBase() compiles this DRL
//   - Displayed in: E-Chart encounter view, CAISI community health programs
//
// Fact Class:
//   io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo
//   Bound as variable "m" in all rules.
//
// History:
//   - Originally created for CAISI community health module (McMaster)
//   - Converted to Drools 7.x DRL format as part of the Drools migration (2026)
// ============================================================================
package SocialLegalFlowsheet;

import io.github.carlos_emr.carlos.encounter.oscarMeasurements.MeasurementInfo;

// ---------------------------------------------------------------------------
// Health Assessment (HltA)
// Annual review of overall health status including chronic conditions,
// medications, and healthcare access. For marginalized clients, this may
// be the only structured health review they receive outside of acute care.
// Warning at 12 months.
// ---------------------------------------------------------------------------
rule "HltA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("HltA") >= 12 )
    then
        m.addWarning("HltA","Question not answered in "+m.getLastDateRecordedInMonths("HltA")+" months");
end

rule "HltA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("HltA") == -1 )
    then
        m.addWarning("HltA","Question not answered");
end

// Mental Health Assessment (MHA)
// Screens for psychiatric symptoms, diagnoses, and treatment status.
// Common conditions in this population include schizophrenia, bipolar
// disorder, PTSD, depression, and anxiety. Links to mental health
// case management and psychiatric follow-up.
rule "MHA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("MHA") >= 12 )
    then
        m.addWarning("MHA","Question not answered in "+m.getLastDateRecordedInMonths("MHA")+" months");
end

rule "MHA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("MHA") == -1 )
    then
        m.addWarning("MHA","Question not answered");
end

// Substance Use Assessment (SUA)
// Tracks whether substance use assessment has been recorded.
rule "SUA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SUA") >= 12 )
    then
        m.addWarning("SUA","Question not answered in "+m.getLastDateRecordedInMonths("SUA")+" months");
end

rule "SUA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SUA") == -1 )
    then
        m.addWarning("SUA","Question not answered");
end

// Living Will / Advance Directives (Lwil)
// Documents whether the client has a living will, power of attorney for
// personal care, or other advance directives. Important for clients with
// serious chronic illness, mental health conditions, or aging in place.
rule "Lwil 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Lwil") >= 12 )
    then
        m.addWarning("Lwil","Question not answered in "+m.getLastDateRecordedInMonths("Lwil")+" months");
end

rule "Lwil 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Lwil") == -1 )
    then
        m.addWarning("Lwil","Question not answered");
end

// Social/Community Connections (SoCm)
// Assesses the client's social support network and community engagement.
// Social isolation is a significant risk factor for poor health outcomes.
// BUG: Rule "SoCm 1" passes "Lwil" instead of "SoCm" to addWarning().
rule "SoCm 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SoCm") >= 12 )
    then
        m.addWarning("SoCm","Question not answered in "+m.getLastDateRecordedInMonths("SoCm")+" months");
end

rule "SoCm 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("SoCm") == -1 )
    then
        m.addWarning("SoCm","Question not answered");
end

// Education/Training (EdTr)
// Tracks educational attainment, current enrollment in training programs,
// literacy level, and barriers to education. Education is a key social
// determinant affecting employment, health literacy, and self-management.
rule "EdTr 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EdTr") >= 12 )
    then
        m.addWarning("EdTr","Question not answered in "+m.getLastDateRecordedInMonths("EdTr")+" months");
end

rule "EdTr 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EdTr") == -1 )
    then
        m.addWarning("EdTr","Question not answered");
end

// Employment Assessment (EmpA)
// Evaluates work readiness, employment barriers (criminal record, gaps,
// health limitations), and job search support needs. Employment is
// foundational for housing stability and financial independence.
rule "EmpA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EmpA") >= 12 )
    then
        m.addWarning("EmpA","Question not answered in "+m.getLastDateRecordedInMonths("EmpA")+" months");
end

rule "EmpA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("EmpA") == -1 )
    then
        m.addWarning("EmpA","Question not answered");
end

// Legal Assessment (LegA)
// Identifies outstanding legal issues: criminal charges, bail conditions,
// probation/parole, custody matters, immigration hearings, or civil suits.
// Legal problems create significant stress and barriers to care. Referral
// to legal aid or duty counsel may be needed.
rule "LegA 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LegA") >= 12 )
    then
        m.addWarning("LegA","Question not answered in "+m.getLastDateRecordedInMonths("LegA")+" months");
end

rule "LegA 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("LegA") == -1 )
    then
        m.addWarning("LegA","Question not answered");
end

// Other Support Services (Osup)
// Whether the client has been connected with additional support services
// not covered by other flowsheet categories (e.g., peer support, spiritual
// care, cultural services, recreation programs, food banks).
rule "Osup 1"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Osup") >= 12 )
    then
        m.addWarning("Osup","Question not answered in "+m.getLastDateRecordedInMonths("Osup")+" months");
end

rule "Osup 2"
    when
        m : MeasurementInfo()
        eval( m.getLastDateRecordedInMonths("Osup") == -1 )
    then
        m.addWarning("Osup","Question not answered");
end
