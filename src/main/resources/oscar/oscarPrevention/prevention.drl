end

rule "HPV-CERVIX 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 75 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") >= 58 )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") <= 60 )
        eval( !prev.isPreventionNever("HPV-CERVIX") )
        eval( !prev.isNextDateSet("HPV-CERVIX") )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 1");
        prev.addReminder("HPV-CERVIX repeat is coming due for this patient");
end

rule "HPV-CERVIX 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") > 60 )
        eval( !prev.isPreventionNever("HPV-CERVIX") )
        eval( !prev.isNextDateSet("HPV-CERVIX") )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 2");
        prev.addWarning("HPV-CERVIX", "HPV-CERVIX is overdue for this patient");
end

rule "HPV-CERVIX 3"
