        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("PAP") == -1 )
        eval( !prev.isInelligible("PAP") )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") == -1 )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 3");
        prev.addWarning("HPV-CERVIX", "Neighter HPV-CERVIX nor PAP records can be found for this patient");
end

rule "PAP 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.isPreventionNever("HPV-CERVIX") )
        eval( prev.getHowManyMonthsSinceLast("PAP") >= 34 )
        eval( prev.getHowManyMonthsSinceLast("PAP") <= 36 )
        eval( !prev.isPreventionNever("PAP") )
        eval( !prev.isNextDateSet("PAP") )
        eval( !prev.isInelligible("PAP") )
    then
        prev.log("PAP 1");
        prev.addReminder("PAP is coming due for this patient");
end

