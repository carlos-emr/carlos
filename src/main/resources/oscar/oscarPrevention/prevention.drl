// ============================================================================
// CARLOS EMR - Immunization/Prevention Schedule Decision Support Rules
// ============================================================================
//
// This DRL file defines the immunization schedule rules for the CARLOS EMR
// prevention module. Rules evaluate a patient's age, vaccination history,
// and prevention status to generate appropriate clinical warnings.
//
// APPLICATION CONTEXT:
//   Called from: PreventionDSImpl.java (io.github.carlos_emr.carlos.prevention)
//   Purpose: Powers the Prevention module's clinical decision support warnings
//     shown on the prevention summary page (oscarPrevention/index.jsp).
//   Loading: Three-tier priority:
//     1. Filesystem path from PREVENTION_FILE property in carlos.properties
//     2. Database ResourceStorage (active PREVENTION_RULES record)
//     3. Classpath fallback: /oscar/oscarPrevention/prevention.drl (this file)
//   Execution: PreventionDSImpl.getMessages(Prevention) creates a KieSession,
//     inserts a Prevention fact, fires all rules, then disposes the session.
//     Warnings/reminders are collected from the Prevention object afterward.
//
// Fact object: Prevention (io.github.carlos_emr.carlos.prevention.Prevention)
//   - Bound as "prev" in all rules
//   - Key methods:
//     Age:       getAgeInMonths(), getAgeInYears()
//     History:   getNumberOfPreventionType(String), getHowManyMonthsSinceLast(String),
//                getHowManyDaysSinceLast(String), getAgeInMonthsLastPreventionTypeGiven(String)
//     Status:    isPreventionNever(String), isNextDateSet(String), isPassedNextDate(String),
//                isInelligible(String), isLastPreventionWithinRange(String, String, String),
//                isTodayinDateRange(String, String)
//     Smoking:   isCurrentlySmoking(String), getRefusedStatus(String)
//                NOTE: isPreventionNever("Smoking") is INCORRECT for smoking checks — the
//                "never" column is always 0 for all smoking states (Yes/No/Previous).
//                The smoking answer is stored in the "refused" column:
//                  0=Yes (current smoker), 1=No (non-smoker), 2=Previous (ex-smoker).
//                Use isCurrentlySmoking("Smoking") to check for active smoking status.
//     Sex:       isMale(), isFemale()
//
// Consequence methods:
//   - prev.addWarning(preventionType, message) - adds clinical WARNING (red indicator)
//   - prev.addReminder(message) - adds clinical REMINDER (yellow/info indicator)
//   - prev.log(ruleName) - logs rule activation for debugging
//
// RULE NAMING CONVENTION:
//   "<VaccineCode> N"   - Age-window rule for dose N (fires when age is within window)
//   "<VaccineCode> N.1" - Next-date override rule for dose N (fires when isPassedNextDate)
//   "X debug"           - Informational reminder showing months since last prevention
//   "X Set Date"        - Generic next-date-passed catch-all for type X
//
// SCHEDULE REFERENCE (based on NACI Canadian Immunization Schedule):
//   Childhood (2-18 months):  DTaP-IPV (5 doses), Hib (3-4 doses), Pneu-C (4 doses),
//                              Rota (2 doses), MMR (2 doses), MMR-Var (1 dose), Var (1 dose)
//   School-age (4-6 years):   DTaP-IPV booster, Tdap-IPV, Var catch-up
//   Adolescent (12-18 years): Men-C-C, HPV (3 doses)
//   Adult:                    Tdap (10-year booster), Td (10-year repeat), Inf (annual 65+)
//   Women's health:           HPV-CERVIX (5-year cycle, 25-69), PAP (3-year cycle, 25-69),
//                              MAM (2-year cycle, 40-74)
//   Colorectal screening:     FOBT/FIT (2-year cycle, 50-74), Colonoscopy (10-year)
//   General wellness:         Smoking assessment (13+), BMD (65+), PHV (annual),
//                              Annual Physical (annual), Obesity screening (annual)
//
// KNOWN QUIRKS:
//   - Inf 1: Hardcoded 2005-2006 flu season date range (historical, not updated)
//   - "Rota 1"/"Rota 2" use System.out.println() instead of prev.log()
//   - DTaP-IPV 4.1: Conditions duplicate DTaP-IPV 3.1 (checks count==2, not count==3)
//   - DTaP-IPV 5/6: Warning says "Needs Third" but these are 5th/6th dose rules
//   - Men-C-C 1: Log message says "Pneu-C 4" (copy-paste artifact)
//   - HPV-CERVIX 3: Typo in message "Neighter" should be "Neither"
//   - "FOBT Inelligible": Misspelling of "Ineligible" in rule name and message
//   - isInelligible(): Method name also misspelled (matches rule convention)
//   - PAP rules require HPV-CERVIX to be "never" before activating (prioritizes HPV-CERVIX)
//
// Converted from Drools 2.0 XML format to Drools 7.x DRL text format.
// Original XML used <rule-set>, <parameter>, <java:condition>, <java:consequence>.
// ============================================================================
package prevention.rules;

import io.github.carlos_emr.carlos.prevention.Prevention;

// --------------------------------------------------------------------------
// DTaP-IPV: Diphtheria-Tetanus-Pertussis-Polio (6 age-window rules + 3 next-date overrides)
// NACI Schedule: 2mo, 4mo, 6mo, 18mo booster, 4-6yr booster
// Age range: 2-72 months (6 years) for primary series
// Also checks DTaP-IPV-Hib combination vaccine count (rules 1, 4)
// Minimum intervals: 2 months between doses 1-3, 12 months before dose 4
// Rules 5-6: Catch-up logic for 4-6yr and 14-16yr if last dose was before 48 months
// QUIRK: Rules 4.1 duplicates 3.1 conditions (count==2); rules 5-6 say "Needs Third"
//   but are actually for 5th/6th doses (copy-paste artifacts from original XML)
// --------------------------------------------------------------------------
rule "DTaP-IPV 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 2 )
        eval( prev.getAgeInMonths() < 72 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 0 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV-Hib") == 0 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 1");
        prev.addWarning("DTaP-IPV", "Needs First DTaP-IPV /HIB");
end

rule "DTaP-IPV 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 4 )
        eval( prev.getAgeInMonths() <= 72 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 1 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 2 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
        eval( prev.isNextDateSet("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 2");
        prev.addWarning("DTaP-IPV", "Needs Second DTaP-IPV /HIB");
end

rule "DTaP-IPV 2.1"
    when
        prev : Prevention()
        eval( prev.isPassedNextDate("DTaP-IPV") )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 1 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 2 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 2");
        prev.addWarning("DTaP-IPV", "Needs Second DTaP-IPV /HIB");
end

rule "DTaP-IPV 3"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 6 )
        eval( prev.getAgeInMonths() < 72 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 2 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 2 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 3");
        prev.addWarning("DTaP-IPV", "Needs Third DTaP-IPV /HIB");
end

rule "DTaP-IPV 3.1"
    when
        prev : Prevention()
        eval( prev.isPassedNextDate("DTaP-IPV") )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 2 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 2 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 2.1");
        prev.addWarning("DTaP-IPV", "Needs Third DTaP-IPV /HIB");
end

rule "DTaP-IPV 4"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 18 )
        eval( prev.getAgeInMonths() < 72 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 3 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 12 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 4");
        prev.addWarning("DTaP-IPV", "Needs Fourth DTaP-IPV /HIB");
end

rule "DTaP-IPV 4.1"
    when
        prev : Prevention()
        eval( prev.isPassedNextDate("DTaP-IPV") )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 2 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 2 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 2.1");
        prev.addWarning("DTaP-IPV", "Needs Third DTaP-IPV /HIB");
end

rule "DTaP-IPV 5"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 48 )
        eval( prev.getAgeInMonths() < 72 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 4 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 1 )
        eval( prev.getAgeInMonthsLastPreventionTypeGiven("DTaP-IPV") <= 48 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 3");
        prev.addWarning("DTaP-IPV", "Needs Third DTaP-IPV /HIB");
end

rule "DTaP-IPV 6"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 168 )
        eval( prev.getAgeInMonths() < 192 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV") == 4 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 1 )
        eval( prev.getAgeInMonthsLastPreventionTypeGiven("DTaP-IPV") <= 48 )
        eval( !prev.isPreventionNever("DTaP-IPV") )
    then
        prev.log("DTaP-IPV 3");
        prev.addWarning("DTaP-IPV", "Needs Third DTaP-IPV /HIB");
end

// --------------------------------------------------------------------------
// Tdap-IPV: Tetanus-Diphtheria-Pertussis-Polio booster (1 rule)
// NACI Schedule: Single dose at 4-6 years (school entry booster)
// Reduced antigen formulation compared to DTaP-IPV childhood doses
// --------------------------------------------------------------------------
rule "Tdap-IPV 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 48 )
        eval( prev.getAgeInMonths() <= 72 )
        eval( prev.getNumberOfPreventionType("Tdap-IPV") == 0 )
        eval( !prev.isPreventionNever("Tdap-IPV") )
    then
        prev.log("Tdap-IPV 1");
        prev.addWarning("Tdap-IPV", "Needs Tdap-IPV vaccine");
end

// --------------------------------------------------------------------------
// Rota: Rotavirus vaccine (2 rules)
// NACI Schedule: 2 doses at 2mo and 4mo (must complete by 8 months of age)
// Strict upper age limits: dose 1 by 5mo, dose 2 by 6mo
// QUIRK: Uses System.out.println() instead of prev.log() (original code)
// Uses isNextDateSet() for dose 2 sequencing
// MULTI-TYPE NOTE: Rule 1 counts Rota-1 (Rotarix) and Rota-5 (RotaTeq) as
//   equivalent to generic Rota for the first-dose check. This allows records
//   entered with product-specific codes to satisfy the rule.
// --------------------------------------------------------------------------
rule "Rota 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 2 )
        eval( prev.getAgeInMonths() < 5 )
        eval( prev.getNumberOfPreventionType("Rota")
            + prev.getNumberOfPreventionType("Rota-1")
            + prev.getNumberOfPreventionType("Rota-5")
            == 0 )
        eval( !prev.isPreventionNever("Rota") )
    then
        System.out.println("Rota 1");
        prev.addWarning("Rota", "Needs First Rota vaccine");
end

rule "Rota 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 4 )
        eval( prev.getAgeInMonths() <= 6 )
        eval( prev.getNumberOfPreventionType("Rota")
            + prev.getNumberOfPreventionType("Rota-1")
            + prev.getNumberOfPreventionType("Rota-5")
            == 1 )
        eval( prev.getHowManyMonthsSinceLast("Rota") >= 1 )
        eval( !prev.isPreventionNever("Rota") )
        eval( prev.isNextDateSet("Rota") )
    then
        System.out.println("Rota 2");
        prev.addWarning("Rota", "Needs Second Rota vaccine");
end

// --------------------------------------------------------------------------
// Hib: Haemophilus influenzae type b (6 rules)
// NACI Schedule: Primary series at 2, 4, 6 months + booster at 12-15 months
// Rules 1-3: Standard infant series (2-12mo), 2-month minimum intervals
// Rules 4-5: Catch-up schedule for 12-24mo (fewer doses needed if starting late)
// Rule 6: Single dose catch-up for 24-60mo (toddlers who missed all doses)
// Also checks DTaP-IPV-Hib combination count (rules 1, 4)
// QUIRK: Rule 6 warning says "Needs second Hib" but is for first-ever dose
// --------------------------------------------------------------------------
rule "Hib 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 2 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Hib") == 0 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV-Hib") == 0 )
    then
        prev.log("Hib 1");
        prev.addWarning("Hib", "Needs first Hib");
end

rule "Hib 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 4 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Hib") == 1 )
        eval( prev.getHowManyMonthsSinceLast("Hib") >= 2 )
    then
        prev.log("Hib 2");
        prev.addWarning("Hib", "Needs second Hib");
end

rule "Hib 3"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 6 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Hib") == 2 )
        eval( prev.getHowManyMonthsSinceLast("Hib") >= 2 )
    then
        prev.log("Hib 3");
        prev.addWarning("Hib", "Needs third Hib");
end

rule "Hib 4"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 12 )
        eval( prev.getAgeInMonths() < 24 )
        eval( prev.getNumberOfPreventionType("Hib") == 0 )
        eval( prev.getNumberOfPreventionType("DTaP-IPV-Hib") == 0 )
    then
        prev.log("Hib 4");
        prev.addWarning("Hib", "Needs first Hib");
end

rule "Hib 5"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 12 )
        eval( prev.getAgeInMonths() < 24 )
        eval( prev.getNumberOfPreventionType("Hib") == 1 )
        eval( prev.getHowManyMonthsSinceLast("Hib") >= 2 )
    then
        prev.log("Hib 5");
        prev.addWarning("Hib", "Needs second Hib");
end

rule "Hib 6"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 24 )
        eval( prev.getAgeInMonths() < 60 )
        eval( prev.getNumberOfPreventionType("Hib") == 0 )
    then
        prev.log("Hib 6");
        prev.addWarning("Hib", "Needs second Hib");
end

// --------------------------------------------------------------------------
// Pneu-C: Pneumococcal Conjugate vaccine (6 rules)
// NACI Schedule: 3-dose infant series at 2, 4, 6mo + booster at 15mo
// Rules 1-4: Standard infant series (2-12mo) + booster (15-24mo)
// Rules 5-6: Catch-up schedule for 12-24mo (fewer doses if starting late)
// Minimum intervals: 2 months between primary doses, 6 months before booster
// MULTI-TYPE NOTE: Rule 1 counts all pediatric conjugate valences (Pneu-C-7, -10, -13, -15)
//   as equivalent to Pneu-C for the purpose of determining if a first dose has been given.
//   Note: Pneu-C-20 is adult formulation and should NOT count for the infant series.
// --------------------------------------------------------------------------
rule "Pneu-C 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 2 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 0 )
    then
        prev.log("Pneu-C 1");
        prev.addWarning("Pneu-C", "Needs First Pneu-C");
end

rule "Pneu-C 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 4 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 1 )
        eval( prev.getHowManyMonthsSinceLast("Pneu-C") >= 2 )
    then
        prev.log("Pneu-C 2");
        prev.addWarning("Pneu-C", "Needs Second Pneu-C");
end

rule "Pneu-C 3"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 6 )
        eval( prev.getAgeInMonths() < 12 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 2 )
        eval( prev.getHowManyMonthsSinceLast("Pneu-C") >= 2 )
    then
        prev.log("Pneu-C 3");
        prev.addWarning("Pneu-C", "Needs Third Pneu-C");
end

rule "Pneu-C 4"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 15 )
        eval( prev.getAgeInMonths() < 24 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 3 )
        eval( prev.getHowManyMonthsSinceLast("Pneu-C") >= 6 )
    then
        prev.log("Pneu-C 4");
        prev.addWarning("Pneu-C", "Needs Fourth Pneu-C");
end

rule "Pneu-C 5"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 12 )
        eval( prev.getAgeInMonths() < 24 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 0 )
    then
        prev.log("Pneu-C 5");
        prev.addWarning("Pneu-C", "Needs First Pneu-C");
end

rule "Pneu-C 6"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 14 )
        eval( prev.getAgeInMonths() < 24 )
        eval( prev.getNumberOfPreventionType("Pneu-C")
            + prev.getNumberOfPreventionType("Pneu-C-7")
            + prev.getNumberOfPreventionType("Pneu-C-10")
            + prev.getNumberOfPreventionType("Pneu-C-13")
            + prev.getNumberOfPreventionType("Pneu-C-15")
            == 1 )
        eval( prev.getHowManyMonthsSinceLast("Pneu-C") >= 2 )
    then
        prev.log("Pneu-C 6");
        prev.addWarning("Pneu-C", "Needs Second Pneu-C");
end

// --------------------------------------------------------------------------
// MMR / MMR-Var: Measles-Mumps-Rubella (2 rules) + Varicella combo (1 rule)
// NACI Schedule: Dose 1 at 12mo, Dose 2 at 4-6yr (or as MMR-Var)
// MMR 1: First dose, checks both MMR and MMR-Var counts (either satisfies)
// MMR 2: Second MMR-component dose at 48mo+; uses total component count
//        (MMR + MMR-Var) to avoid false positives when MMR-Var was given
// MMR-Var 1: Comprehensive 2-dose coverage check at 48mo for BOTH MMR and
//   Var components. MMR-Var counts toward both component totals:
//     MMR component total = count(MMR) + count(MMR-Var)
//     Var component total = count(Var) + count(MMR-Var)
//   Typical schedule: MMR@12mo + Var@15mo + MMR-Var@48mo → fully covered
//   Warning specifies exactly which component(s) are still needed.
// Age range: 12 months to 10 years
// --------------------------------------------------------------------------
rule "MMR 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 12 )
        eval( prev.getAgeInYears() < 10 )
        eval( prev.getNumberOfPreventionType("MMR") == 0 )
        eval( prev.getNumberOfPreventionType("MMR-Var") == 0 )
    then
        prev.log("MMR 1");
        prev.addWarning("MMR", "Needs First MMR or MMR-Var");
end

rule "MMR 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 48 )
        eval( prev.getAgeInYears() < 10 )
        // Use total MMR component count (MMR + MMR-Var) to avoid false
        // positives when a combined MMR-Var dose has already been given
        eval( prev.getNumberOfPreventionType("MMR") + prev.getNumberOfPreventionType("MMR-Var") == 1 )
        eval( prev.getNumberOfPreventionType("MMR-Var") == 0 )
    then
        prev.log("MMR 2");
        prev.addWarning("MMR", "Needs Second MMR or MMR-Var");
end

// MMR-Var 1: At 48mo, check full 2-dose coverage for both MMR and Var
// components. Any combination that totals 2 doses per component is valid:
//   - 2x MMR + 2x Var (all separate)
//   - 1x MMR + 1x Var + 1x MMR-Var (typical schedule — no warning)
//   - 2x MMR-Var
//   - etc.
rule "MMR-Var 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 48 )
        eval( prev.getAgeInYears() < 10 )
        eval( (prev.getNumberOfPreventionType("MMR") + prev.getNumberOfPreventionType("MMR-Var") < 2)
           || (prev.getNumberOfPreventionType("Var") + prev.getNumberOfPreventionType("MMR-Var") < 2) )
    then
        prev.log("MMR-Var 1");
        int mmrTotal = prev.getNumberOfPreventionType("MMR") + prev.getNumberOfPreventionType("MMR-Var");
        int varTotal = prev.getNumberOfPreventionType("Var") + prev.getNumberOfPreventionType("MMR-Var");
        if (mmrTotal < 2 && varTotal < 2) {
            prev.addWarning("MMR-Var", "Needs MMR and Var immunization to complete series");
        } else if (mmrTotal < 2) {
            prev.addWarning("MMR-Var", "Needs MMR immunization to complete series");
        } else {
            prev.addWarning("MMR-Var", "Needs Var immunization to complete series");
        }
end

// --------------------------------------------------------------------------
// Men-C-C: Meningococcal C Conjugate (3 rules)
// NACI Schedule: Dose at 12mo, catch-up at 12yr for school programs
// Rule 1: Primary dose at 12mo-24yr (broad catch-up window)
// Rule 2: School-age catch-up at age 12-13yr
// Rule 3: Adolescent catch-up at 15-19yr
// QUIRK: Rule 1 log message says "Pneu-C 4" (copy-paste from Pneu-C section)
// --------------------------------------------------------------------------
rule "Men-C-C 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 12 )
        eval( prev.getAgeInYears() < 24 )
        eval( prev.getNumberOfPreventionType("Men-C-C") == 0 )
    then
        prev.log("Pneu-C 4");
        prev.addWarning("Men-C-C", "Needs Men-C-C");
end

rule "Men-C-C 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 12 )
        eval( prev.getAgeInYears() < 13 )
        eval( prev.getNumberOfPreventionType("Men-C-C") == 0 )
    then
        prev.log("Men-C-C 2");
        prev.addWarning("Men-C-C", "Needs Men-C-C");
end

// --------------------------------------------------------------------------
// HPV: Human Papillomavirus vaccine (1 rule)
// NACI Schedule: 2-3 dose series at age 12-18 (school-based programs)
// Checks Health Canada standard type codes: HPV-9, HPV-4, HPV (generic), HPV-2
// Also checks legacy names from O19 migration for backward compatibility
// Sums all product counts to determine if any HPV dose has been given
// Age range: 12-18 years
// --------------------------------------------------------------------------
rule "HPV 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 12 )
        eval( prev.getAgeInYears() < 19 )
        eval( prev.getNumberOfPreventionType("HPV-9")
            + prev.getNumberOfPreventionType("HPV-4")
            + prev.getNumberOfPreventionType("HPV-2")
            + prev.getNumberOfPreventionType("HPV")
            + prev.getNumberOfPreventionType("HPV Vaccine")
            == 0 )
    then
        prev.log("HPV 1");
        prev.addWarning("HPV", "Needs HPV");
end

rule "Men-C-C 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 15 )
        eval( prev.getAgeInYears() <= 19 )
        eval( prev.getNumberOfPreventionType("Men-C-C") == 0 )
    then
        prev.log("Men-C-C 3");
        prev.addWarning("Men-C-C", "Needs Men-C-C");
end

// --------------------------------------------------------------------------
// Var: Varicella (Chickenpox) vaccine (4 rules)
// NACI Schedule: Dose 1 at 15mo, catch-up at 4-6yr
// Rules 1-2: First dose at 15-24mo, requiring 28+ days since last MMR
//   Rule 1: Normal case (>=28 days since MMR - safe to give live vaccine)
//   Rule 2: No MMR on record (days since last == 0, meaning never given)
// Rules 3-4: Catch-up at 4-6 years with same MMR spacing logic
// Live vaccine interval: Must wait 28 days after MMR (both are live vaccines)
// --------------------------------------------------------------------------
rule "Var 1"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 15 )
        eval( prev.getAgeInMonths() <= 24 )
        eval( prev.getNumberOfPreventionType("Var") == 0 )
        eval( prev.getHowManyDaysSinceLast("MMR") >= 28 )
    then
        prev.log("Var 1");
        prev.addWarning("Var", "Needs Var");
end

rule "Var 2"
    when
        prev : Prevention()
        eval( prev.getAgeInMonths() >= 15 )
        eval( prev.getAgeInMonths() <= 24 )
        eval( prev.getNumberOfPreventionType("Var") == 0 )
        eval( prev.getHowManyDaysSinceLast("MMR") == 0 )
    then
        prev.log("Var 2");
        prev.addWarning("Var", "Needs Var");
end

rule "Var 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 4 )
        eval( prev.getAgeInYears() <= 6 )
        eval( prev.getNumberOfPreventionType("Var") == 0 )
        eval( prev.getHowManyDaysSinceLast("MMR") >= 28 )
    then
        prev.log("Var 3");
        prev.addWarning("Var", "Needs Var");
end

rule "Var 4"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 4 )
        eval( prev.getAgeInYears() <= 6 )
        eval( prev.getNumberOfPreventionType("Var") == 0 )
        eval( prev.getHowManyDaysSinceLast("MMR") == 0 )
    then
        prev.log("Var 4");
        prev.addWarning("Var", "Needs Var");
end

// --------------------------------------------------------------------------
// Tdap / Td: Adult Tetanus-Diphtheria boosters (3 rules)
// NACI Schedule: Tdap once in adulthood, then Td every 10 years
// Tdap 1: First adult acellular pertussis booster, >=120mo (10yr) since last DTaP-IPV
// Td 1: First tetanus-diphtheria booster, >=120mo since last Tdap
// Td 2: Repeat Td booster every 10 years; checks ALL tetanus-containing vaccines:
//   Tdap, Td, Td-IPV, TdP-IPV-Hib, Tdap-IPV (any resets the 10-year clock)
// NOTE: No age restrictions on adult boosters - applies to all ages
// --------------------------------------------------------------------------
rule "Tdap 1"
    when
        prev : Prevention()
        eval( prev.getNumberOfPreventionType("Tdap") == 0 )
        eval( prev.getHowManyMonthsSinceLast("DTaP-IPV") >= 120 )
    then
        prev.log("Tdap 1");
        prev.addWarning("Tdap", "Needs Tdap");
end

rule "Td 1"
    when
        prev : Prevention()
        eval( prev.getNumberOfPreventionType("Td") == 0 )
        eval( prev.getHowManyMonthsSinceLast("Tdap") >= 120 )
    then
        prev.log("Td 1");
        prev.addWarning("Td", "Needs Td");
end

rule "Td 2"
    when
        prev : Prevention()
        eval( prev.getNumberOfPreventionType("Td") >= 1 )
        eval( prev.getHowManyMonthsSinceLast("Td") >= 120 )
        eval( prev.getHowManyMonthsSinceLast("Tdap") >= 120 )
        eval( prev.getHowManyMonthsSinceLast("Td-IPV") >= 120 )
        eval( prev.getHowManyMonthsSinceLast("TdP-IPV-Hib") >= 120 )
        eval( prev.getHowManyMonthsSinceLast("Tdap-IPV") >= 120 )
    then
        prev.log("Td 2");
        prev.addWarning("Td", "Needs repeat Td");
end

// --------------------------------------------------------------------------
// Inf: Influenza vaccine (4 rules)
// NACI Schedule: Annual vaccination, especially for 65+ and high-risk groups
// Rule "Inf 1": HARDCODED 2005-2006 flu season (historical, not dynamically updated)
//   Uses isTodayinDateRange/isLastPreventionWithinRange for season-specific check
// Rules "Inf 2"/"Inf 3": Age 65+ annual check (12-month interval)
//   Inf 2: Has previous flu shot but >12 months ago
//   Inf 3: Never had a flu shot (months since last == -1, meaning no record)
// "Inf Set Date": Generic next-date-passed catch-all for any age
// QUIRK: Inf 1 date range is never updated; effectively dead code after 2006
// Also checks legacy "Flu" type for backward compatibility with pre-migration records
// --------------------------------------------------------------------------
rule "Inf 1"
    when
        prev : Prevention()
        eval( prev.isTodayinDateRange("2005-10-01","2006-01-29") )
        eval( !prev.isLastPreventionWithinRange("Inf","2005-10-01","2006-01-29") )
    then
        prev.log("Inf 1");
        prev.addWarning("Inf", "Needs Flu Shot ");
end

rule "Inf 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >=65 )
        eval( prev.getHowManyMonthsSinceLast("Inf") >= 12 )
        eval( prev.getHowManyMonthsSinceLast("Flu") >= 12 )
    then
        prev.log("Inf 2");
        prev.addWarning("Inf", "Needs Flu Shot ");
end

rule "Inf 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >=65 )
        eval( prev.getHowManyMonthsSinceLast("Inf") == -1 )
        eval( prev.getHowManyMonthsSinceLast("Flu") == -1 )
    then
        prev.log("Inf 3");
        prev.addWarning("Inf", "Needs Flu Shot ");
end

rule "Inf Set Date"
    when
        prev : Prevention()
        eval( prev.isNextDateSet("Inf") )
        eval( prev.isPassedNextDate("Inf") )
    then
        prev.log("Inf 1");
        prev.addWarning("Inf", "Needs Flu Shot ");
end

// --------------------------------------------------------------------------
// HPV-CERVIX: HPV-based cervical cancer screening (3 rules)
// Canadian guideline: HPV primary screening every 5 years, ages 25-69
// Rule 1: REMINDER at 58-60 months (coming due in next 2 months)
// Rule 2: WARNING at >60 months (overdue for screening)
// Rule 3: WARNING if neither HPV-CERVIX nor PAP records exist (new patient)
// Exclusions: isPreventionNever(), isNextDateSet(), isInelligible()
// QUIRK: Rule 3 message has typo "Neighter" (should be "Neither")
// HPV-CERVIX takes priority over PAP: PAP rules only fire if HPV-CERVIX is "never"
// --------------------------------------------------------------------------
rule "HPV-CERVIX 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 75 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") >= 58 )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") <= 60 )
        eval( !prev.isPreventionNever("HPV-CERVIX") )
        eval( !prev.isNextDateSet("HPV-CERVIX") )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 1");
        prev.addReminder("HPV-CERVIX repeat is coming due for this patient");
end

rule "HPV-CERVIX 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") > 60 )
        eval( !prev.isPreventionNever("HPV-CERVIX") )
        eval( !prev.isNextDateSet("HPV-CERVIX") )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 2");
        prev.addWarning("HPV-CERVIX", "HPV-CERVIX is overdue for this patient");
end

rule "HPV-CERVIX 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("PAP") == -1 )
        eval( !prev.isInelligible("PAP") )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") == -1 )
        eval( !prev.isInelligible("HPV-CERVIX") )
    then
        prev.log("HPV-CERVIX 3");
        prev.addWarning("HPV-CERVIX", "Neighter HPV-CERVIX nor PAP records can be found for this patient");
end

// --------------------------------------------------------------------------
// PAP: Pap smear cervical screening (4 rules + 1 debug)
// Canadian guideline: Pap test every 3 years, ages 25-69 (when HPV-CERVIX not used)
// Rule 1: REMINDER at 34-36 months (coming due) - ONLY if HPV-CERVIX is "never"
// Rule 2: WARNING at >36 months (overdue) - also requires no HPV-CERVIX records
// Rule 4: WARNING when past next scheduled date (any age, female)
// "PAP debug": Informational reminder showing months since last PAP
// Exclusions: isPreventionNever(), isNextDateSet(), isInelligible()
// NOTE: PAP rules require isPreventionNever("HPV-CERVIX") to fire (HPV-CERVIX preferred)
// Rule numbering: No "PAP 3" exists (gap in original numbering)
// --------------------------------------------------------------------------
rule "PAP 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.isPreventionNever("HPV-CERVIX") )
        eval( prev.getHowManyMonthsSinceLast("PAP") >= 34 )
        eval( prev.getHowManyMonthsSinceLast("PAP") <= 36 )
        eval( !prev.isPreventionNever("PAP") )
        eval( !prev.isNextDateSet("PAP") )
        eval( !prev.isInelligible("PAP") )
    then
        prev.log("PAP 1");
        prev.addReminder("PAP is coming due for this patient");
end

rule "PAP 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("PAP") > 36 )
        eval( !prev.isPreventionNever("PAP") )
        eval( !prev.isNextDateSet("PAP") )
        eval( !prev.isInelligible("PAP") )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") == -1 )
    then
        prev.log("PAP 2");
        prev.addWarning("PAP", "PAP is overdue for this patient");
end

rule "PAP 4"
    when
        prev : Prevention()
        eval( prev.isFemale() )
        eval( prev.isNextDateSet("PAP") )
        eval( prev.isPassedNextDate("PAP") )
        eval( !prev.isInelligible("PAP") )
    then
        prev.log("PAP 4");
        prev.addWarning("PAP", "PAP is overdue for this patient");
end

rule "PAP debug"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 25 )
        eval( prev.getAgeInYears() < 70 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("PAP") != -1 )
        eval( prev.getHowManyMonthsSinceLast("HPV-CERVIX") != -1 )
        eval( !prev.isInelligible("HPV-CERVIX") )
        eval( !prev.isInelligible("PAP") )
    then
        prev.log("PAP debug");
        prev.addReminder("Last PAP was done "+prev.getHowManyMonthsSinceLast("PAP")+" month(s) ago");
end

// --------------------------------------------------------------------------
// MAM: Mammogram breast cancer screening (5 rules + 1 debug)
// Canadian guideline (ON/BC): Mammography every 2 years, ages 40-74
// Rule 1: REMINDER at 22-24 months (coming due in next 2 months)
// Rule 2: WARNING at >24 months (overdue)
// Rule 3: WARNING if no mammogram records exist (new patient in age range)
// Rule 4: WARNING when past next scheduled date (any age, female)
// "MAM debug": Informational reminder showing months since last mammogram (18-74)
// Exclusions: isPreventionNever(), isNextDateSet(), isInelligible()
// --------------------------------------------------------------------------
rule "MAM 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 40 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("MAM") >= 22 )
        eval( prev.getHowManyMonthsSinceLast("MAM") <= 24 )
        eval( !prev.isPreventionNever("MAM") )
        eval( !prev.isNextDateSet("MAM") )
        eval( !prev.isInelligible("MAM") )
    then
        prev.log("MAM 1");
        prev.addReminder("Mammogram is coming due for this patient");
end

rule "MAM 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 40 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("MAM") > 24 )
        eval( !prev.isPreventionNever("MAM") )
        eval( !prev.isNextDateSet("MAM") )
        eval( !prev.isInelligible("MAM") )
    then
        prev.log("MAM 2");
        prev.addWarning("MAM", "Mammogram is overdue for this patient");
end

rule "MAM 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 40 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("MAM") == -1 )
        eval( !prev.isInelligible("MAM") )
    then
        prev.log("MAM 3");
        prev.addWarning("MAM", "No Mammogram records can be found for this patient");
end

rule "MAM 4"
    when
        prev : Prevention()
        eval( prev.isFemale() )
        eval( prev.isNextDateSet("MAM") )
        eval( prev.isPassedNextDate("MAM") )
        eval( !prev.isInelligible("MAM") )
    then
        prev.log("MAM 4");
        prev.addWarning("MAM", "MAM is overdue for this patient");
end

rule "MAM debug"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 18 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.isFemale() )
        eval( prev.getHowManyMonthsSinceLast("MAM") != -1 )
        eval( !prev.isInelligible("MAM") )
    then
        prev.log("MAM debug");
        prev.addReminder("Last Mammogram was done "+prev.getHowManyMonthsSinceLast("MAM")+" month(s) ago");
end

// --------------------------------------------------------------------------
// AAA: Screening for AAA by u/s (1 rule)
// Canadian guideline: one time screening for Men ages 65-80
// Ontario guideline: one time screening for either gender ages 65-80
// Rule 1: WARNING - AAA screen overdue no AAA screen on record
// --------------------------------------------------------------------------
rule "AAA 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 65 )
        eval( prev.getAgeInYears() <= 80 )
        eval( prev.isMale() )
        eval( prev.getHowManyMonthsSinceLast("AAA") == -1 )
    then
        prev.log("AAA 1 debug");
        prev.addWarning("AAA", "AAA is overdue for this patient");
end

// --------------------------------------------------------------------------
// FOBT / Colonoscopy: Colorectal cancer screening (4 rules)
// Canadian guideline: FIT/FOBT every 2 years ages 50-74; colonoscopy every 10 years
// Rule 1: WARNING - FIT overdue (>24mo since FOBT) AND no colonoscopy on record
// Rule 2: WARNING - No FIT/FOBT or colonoscopy records at all (ages 50-74)
// Rule 3: WARNING - Colonoscopy >10 years old (120 months) - needs repeat
// "FOBT Inelligible": REMINDER that colonoscopy makes FIT ineligible (any age)
// Logic: Colonoscopy supersedes FOBT - if colonoscopy exists, FOBT not needed
// QUIRK: Rule/method name "Inelligible" is misspelled (should be "Ineligible")
// --------------------------------------------------------------------------
rule "FOBT 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 50 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") == -1 )
        eval( prev.getHowManyMonthsSinceLast("FOBT") >= 24 )
    then
        prev.log("FOBT 1 debug");
        prev.addWarning("FOBT", "FIT is overdue for this patient");
end

rule "FOBT 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 50 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") == -1 )
        eval( prev.getHowManyMonthsSinceLast("FOBT") == -1 )
    then
        prev.log("FOBT 2 debug");
        prev.addWarning("FOBT", "FIT is overdue for this patient");
end

rule "FOBT 3"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 50 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") >= 120 )
    then
        prev.log("FOBT 3 debug");
        prev.addWarning("FOBT", "Colonoscopy is over 10 years old");
end

rule "FOBT Inelligible"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") != -1 )
    then
        prev.log("FOBT Inelligible debug");
        prev.addReminder("Colonoscopy makes FIT Ineligible");
end

// --------------------------------------------------------------------------
// Smoking: Tobacco use assessment (1 rule)
// Canadian guideline: Screen all patients 13+ for tobacco use
// Single rule: WARNING if no smoking assessment on record (ever)
// No repeat interval - only fires once to prompt initial assessment
// --------------------------------------------------------------------------
rule "Smoking"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 13 )
        eval( prev.getHowManyMonthsSinceLast("Smoking") == -1 )
    then
        prev.log("Smoking debug");
        prev.addReminder("Need to ask about Smoking");
end

// --------------------------------------------------------------------------
// BMD: Bone Mineral Density screening (1 rule)
// Canadian guideline (Osteoporosis Canada): Screen all adults 65+
// Single rule: REMINDER if no BMD test on record (ever)
// No repeat interval - only fires once to prompt initial screening
// --------------------------------------------------------------------------
rule "Bone Mineral Density"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 65 )
        eval( prev.getHowManyMonthsSinceLast("BMD") == -1 )
    then
        prev.log("BMD debug");
        prev.addReminder("Need Bone Mineral Density Test");
end

// --------------------------------------------------------------------------
// PHV: Periodic Health Visit (2 rules)
// Annual wellness check tracking
// Rule 1: WARNING if PHV has never been done (no record)
// Rule 2: WARNING if >11 months since last PHV (overdue for annual)
// No age restriction - applies to all patients
// --------------------------------------------------------------------------
rule "PHV"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("PHV") == -1 )
    then
        prev.log("PHV debug");
        prev.addWarning("PHV", "Periodic Health Visit has never been reviewed");
end

rule "PHV 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("PHV") > 11 )
    then
        prev.log("PHV debug");
        prev.addWarning("PHV", "Periodic Health Visit has not occurred in over a year");
end

// --------------------------------------------------------------------------
// Annual Physical: Annual physical examination (2 rules)
// Similar to PHV but tracked as a separate prevention type
// Rule 1: WARNING if never reviewed
// Rule 2: WARNING if >11 months since last (overdue for annual)
// No age restriction - applies to all patients
// --------------------------------------------------------------------------
rule "Annual Physical"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Annual Physical") == -1 )
    then
        prev.log("Annual Physical debug");
        prev.addWarning("Annual Physical", "Annual Physical has never been reviewed");
end

rule "Annual Physical 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Annual Physical") > 11 )
    then
        prev.log("Annual Physical 2 debug");
        prev.addWarning("Annual Physical", "Annual Physical has not occurred in over 12 months");
end

// --------------------------------------------------------------------------
// Obesity: Obesity screening assessment (2 rules)
// Annual obesity risk assessment tracking
// Rule 1: WARNING if obesity has never been reviewed
// Rule 2: WARNING if >11 months since last review (overdue for annual)
// No age restriction - applies to all patients
// --------------------------------------------------------------------------
rule "Obesity"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Obesity") == -1 )
    then
        prev.log("Obesity debug");
        prev.addWarning("Obesity", "Obesity has never been reviewed");
end

rule "Obesity 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Obesity") > 11 )
    then
        prev.log("Obesity 2 debug");
        prev.addWarning("Obesity", "Obesity check has not occurred in over 12 months");
end

// --------------------------------------------------------------------------
// LDCT: Low-Dose CT Lung Cancer Screening (2 rules)
// Canadian guideline (CTFPHC 2016): Annual LDCT for adults aged 55-74 who are
//   high-risk smokers (30+ pack-years or equivalent significant smoking history)
// Rule 1: WARNING if no LDCT on record for patients aged 55-74 who are current smokers
// Rule 2: WARNING if LDCT count is 1 or 2 and it is > 12 months old (annual x3 years)
//         LDCT 2 stops firing after 3rd annual screen (count >= 3).
//
// Smoking status check (LDCT 1):
//   The Smoking prevention type uses the "refused" column (NOT the "never" column) to
//   store the patient's smoking answer. The "never" column is always 0 for all smoking
//   states, so isPreventionNever("Smoking") cannot be used here.
//   Smoking refused column encoding:
//     0 = Yes (currently smoking)   <-- LDCT rule should fire
//     1 = No (not smoking)          <-- LDCT rule should NOT fire
//     2 = Previous (ex-smoker)      <-- LDCT rule should NOT fire
//   isCurrentlySmoking("Smoking") returns true only when refused = 0.
//
//   Note: Full heavy-smoker detection (pack-years, cigarettes/day) requires measurement
//   values (NOSK > 23, POSK > 0, SKST = yes, SMK = yes, SmkS > 23) which are stored in
//   the measurements table and are not accessible from the Prevention DRL fact object.
//   Extending the Prevention class to support measurement queries would enable this.
// --------------------------------------------------------------------------
rule "LDCT 1"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 55 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getNumberOfPreventionType("Smoking") > 0 )
        eval( prev.isCurrentlySmoking("Smoking") )
        eval( prev.getHowManyMonthsSinceLast("LDCT") == -1 )
        eval( !prev.isPreventionNever("LDCT") )
        eval( !prev.isInelligible("LDCT") )
    then
        prev.log("LDCT 1");
        prev.addWarning("LDCT", "LDCT lung cancer screening recommended for high-risk smoker aged 55-74 (no prior LDCT on record)");
end

rule "LDCT 2"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 55 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getNumberOfPreventionType("LDCT") >= 1 )
        eval( prev.getNumberOfPreventionType("LDCT") <= 2 )
        eval( prev.getHowManyMonthsSinceLast("LDCT") > 12 )
        eval( !prev.isPreventionNever("LDCT") )
        eval( !prev.isNextDateSet("LDCT") )
        eval( !prev.isInelligible("LDCT") )
    then
        prev.log("LDCT 2");
        prev.addWarning("LDCT", "LDCT lung cancer screening for older heavy smokers should be done annually for 3 years and is overdue");
end
