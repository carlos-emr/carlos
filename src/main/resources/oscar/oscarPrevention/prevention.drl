        prev : Prevention()
        eval( prev.getAgeInYears() >= 50 )
        eval( prev.getAgeInYears() <= 74 )
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") >= 120 )
    then
        prev.log("FOBT 3 debug");
        prev.addWarning("FOBT", "Colonoscopy is over 10 years old");
end

rule "FOBT Inelligible"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("COLONOSCOPY") != -1 )
    then
        prev.log("FOBT Inelligible debug");
        prev.addReminder("Colonoscopy makes FIT Ineligible");
end

rule "Smoking"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 13 )
        eval( prev.getHowManyMonthsSinceLast("Smoking") == -1 )
    then
        prev.log("Smoking debug");
        prev.addReminder("Need to ask about Smoking");
end

rule "Bone Mineral Density"
    when
        prev : Prevention()
        eval( prev.getAgeInYears() >= 65 )
        eval( prev.getHowManyMonthsSinceLast("BMD") == -1 )
    then
        prev.log("BMD debug");
        prev.addReminder("Need Bone Mineral Density Test");
end

rule "PHV"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("PHV") == -1 )
    then
        prev.log("PHV debug");
        prev.addWarning("PHV", "Periodic Health Visit has never been reviewed");
end

rule "PHV 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("PHV") > 11 )
    then
        prev.log("PHV debug");
        prev.addWarning("PHV", "Periodic Health Visit has not occurred in over a year");
end

rule "Annual Physical"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Annual Physical") == -1 )
    then
        prev.log("Annual Physical debug");
        prev.addWarning("Annual Physical", "Annual Physical has never been reviewed");
end

rule "Annual Physical 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Annual Physical") > 11 )
    then
        prev.log("Annual Physical 2 debug");
        prev.addWarning("Annual Physical", "Annual Physical has not occurred in over 12 months");
end

rule "Obesity"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Obesity") == -1 )
    then
        prev.log("Obesity debug");
        prev.addWarning("Obesity", "Obesity has never been reviewed");
end

rule "Obesity 2"
    when
        prev : Prevention()
        eval( prev.getHowManyMonthsSinceLast("Obesity") > 11 )
    then
