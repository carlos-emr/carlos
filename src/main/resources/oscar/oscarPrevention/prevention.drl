end

rule "Flu 1"
    when
        prev : Prevention()
        eval( prev.isTodayinDateRange("2005-10-01","2006-01-29") )
        eval( !prev.isLastPreventionWithinRange("Flu","2005-10-01","2006-01-29") )
    then
        prev.log("Flu 1");
        prev.addWarning("Flu", "Needs Flu Shot ");
end

