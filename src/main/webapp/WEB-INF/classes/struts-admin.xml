<!--
    CARLOS EMR - Administration Actions
    Contains action mappings for administration, system messages, lookup lists, and issue management.
-->
<struts>
    <package name="admin" namespace="/" extends="struts-default">

        <global-results>
            <result name="securityError">/WEB-INF/jsp/error/securityError.jsp</result>
        </global-results>

        <global-exception-mappings>
            <!-- Keep Spring method-security denials on the existing CARLOS security-error page.
                 Authorization still happens before the action body; this only normalizes
                 the user-facing error result to match legacy SecurityException handling. -->
            <exception-mapping exception="org.springframework.security.access.AccessDeniedException" result="securityError"/>
            <exception-mapping exception="java.lang.SecurityException" result="securityError"/>
        </global-exception-mappings>

        <action name="lookupListManagerAction" class="io.github.carlos_emr.carlos.admin.lookUpLists.LookupListManager2Action">
