        </action>
        <action name="SystemMessage" class="io.github.carlos_emr.carlos.www.SystemMessage2Action" method="execute">
            <result name="view">/WEB-INF/jsp/caisicore/SystemMessage.jsp</result>
            <result name="list">/WEB-INF/jsp/caisicore/SystemMessageList.jsp</result>
            <result name="edit">/WEB-INF/jsp/caisicore/SystemMessageForm.jsp</result>
        </action>
