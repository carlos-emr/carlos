<!--
    CARLOS EMR - Clinical Actions
    Contains action mappings for diagnosis research, prevention/immunization, case management notes, and clinical decision support.
-->
<struts>
    <package name="clinical" namespace="/" extends="struts-default">

        <global-results>
            <result name="securityError">/securityError.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </global-results>

        <global-exception-mappings>
            <exception-mapping exception="java.lang.SecurityException" result="securityError"/>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

        <action name="encounter/decisionSupport/guidelineAction" class="io.github.carlos_emr.carlos.decisionSupport.web.DSGuideline2Action" method="execute">
            <result name="guidelineList">/encounter/decisionSupport/guidelineList.jsp</result>
            <result name="guidelineDetail">/encounter/decisionSupport/guidelineDetail.jsp</result>
        </action>

        <!--
            Decision-support JSPs (annual review + antenatal planner/checklist/risk)
            all live under /WEB-INF/jsp/decision/ and route through
            ViewDecision2Action, which enforces _forms r on GET and _forms w +
            POST when the request carries a "Save*" submit parameter. The save
            logic remains embedded in the JSPs (scriptlet persistence to
            DesAnnualReviewPlan / Desaprisk / XML config files) and is now
            unreachable without POST + _forms w.
        -->
        <action name="decision/annualreview/annualreviewplanner" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/annualreview/annualreviewplanner.jsp</result>
        </action>
        <action name="decision/annualreview/annualreviewplannerprint" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/annualreview/annualreviewplannerprint.jsp</result>
        </action>
        <action name="decision/annualreview/checklistedit" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/annualreview/checklistedit.jsp</result>
        </action>
        <action name="decision/annualreview/riskedit" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/annualreview/riskedit.jsp</result>
        </action>
        <action name="decision/antenatal/antenatalplanner" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/antenatal/antenatalplanner.jsp</result>
        </action>
        <action name="decision/antenatal/antenatalplannerprint" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/antenatal/antenatalplannerprint.jsp</result>
        </action>
        <action name="decision/antenatal/obarchecklistedit_99_12" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/antenatal/obarchecklistedit_99_12.jsp</result>
        </action>
        <action name="decision/antenatal/obarriskedit_99_12" class="io.github.carlos_emr.carlos.decision.gate.ViewDecision2Action">
            <result name="success">/WEB-INF/jsp/decision/antenatal/obarriskedit_99_12.jsp</result>
        </action>

        <action name="encounter/MeasurementData" class="io.github.carlos_emr.carlos.measurements.web.MeasurementData2Action"/>
        <action name="oscarResearch/oscarDxResearch/setupDxResearch" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxSetupResearch2Action">
            <result name="success">/oscarResearch/oscarDxResearch/dxResearch.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </action>
        <action name="oscarResearch/dxresearch/setupDxResearch" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxSetupResearch2Action">
            <result name="success">/oscarResearch/oscarDxResearch/dxResearch.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearch" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearch2Action">
            <result name="codeSearch">/oscarResearch/oscarDxResearch/dxcodeSearch.do</result>
            <result name="success">/oscarResearch/oscarDxResearch/setupDxResearch.do</result>
            <result name="codeList">/oscarResearch/oscarDxResearch/quickCodeList.jsp</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearchCodeSearch" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchCodeSearch2Action">
            <result name="success">/WEB-INF/jsp/oscarResearch/oscarDxResearch/dxResearchCodeSearch.jsp</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearchUpdate" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchUpdate2Action">
            <result name="success">/oscarResearch/oscarDxResearch/setupDxResearch.do</result>
        </action>
        <action name="oscarResearch/dxresearch/dxResearchUpdate" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchUpdate2Action">
            <result name="success">/oscarResearch/oscarDxResearch/setupDxResearch.do</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearchLoadQuickList" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchLoadQuickList2Action">
            <result name="success">/WEB-INF/jsp/oscarResearch/oscarDxResearch/dxResearchSelectQuickList.jsp</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearchLoadQuickListItems" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchLoadQuickListItems2Action">
            <result name="success">/WEB-INF/jsp/oscarResearch/oscarDxResearch/dxResearchEditQuickList.jsp</result>
        </action>
        <action name="oscarResearch/oscarDxResearch/dxResearchUpdateQuickList" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchUpdateQuickList2Action">
            <result name="success">/oscarResearch/oscarDxResearch/dxResearchLoadQuickListItems.do</result>
            <result name="failure">/WEB-INF/jsp/oscarResearch/oscarDxResearch/dxResearchEditQuickList.jsp</result>
        </action>
        <action name="dxCodeSearchJSON" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxCodeSearchJSON2Action"/>
        <action name="oscarResearch/oscarDxResearch/dxResearchLoadAssociations" class="io.github.carlos_emr.carlos.dxresearch.pageUtil.dxResearchLoadAssociations2Action">
            <interceptor-ref name="defaultStack"/>
            <result name="success">/oscarResearch/oscarDxResearch/dxResearchSelectAssociations.jsp</result>
        </action>
        <action name="prevention/AddPrevention" class="io.github.carlos_emr.carlos.prevention.pageUtil.AddPrevention2Action">
            <result name="success">/WEB-INF/jsp/prevention/close.jsp</result>
            <result name="review">/WEB-INF/jsp/prevention/review.jsp</result>
            <result name="form">/WEB-INF/jsp/prevention/AddPreventionData.jsp</result>
        </action>
        <action name="prevention/PreventionReport" class="io.github.carlos_emr.carlos.prevention.pageUtil.PreventionReport2Action">
            <result name="success">/WEB-INF/jsp/prevention/PreventionReporting.jsp</result>
        </action>
        <action name="prevention/printPrevention" class="io.github.carlos_emr.carlos.prevention.pageUtil.PreventionPrint2Action">
            <result name="error">/WEB-INF/jsp/prevention/index.jsp</result>
        </action>
        <action name="CaseManagementView" class="io.github.carlos_emr.carlos.casemgmt.web.CaseManagementView2Action" method="execute">
            <result name="view">/casemgmt/CaseManagementView.jsp</result>
            <result name="ajaxView">/casemgmt/ChartNotes.jsp</result>
            <result name="ajaxDisplayNotes">/casemgmt/ChartNotesAjax.jsp</result>
            <result name="page.casemgmt.view">/casemgmt/encounterLayout.jsp</result>
            <result name="page.newcasemgmt.view">/casemgmt/newEncounterLayout.jsp</result>
            <result name="domain-error">/casemgmt/domain-error.jsp</result>
            <result name="clientNeverInTheProgramError">/casemgmt/clientNeverInTheProgramError.jsp</result>
            <result name="unlockForm">/casemgmt/unlockNoteForm.jsp</result>
            <result name="unlockSuccess">/casemgmt/unlockNoteSuccess.jsp</result>
            <result name="unlock_ajax">/casemgmt/unlockAjax.jsp</result>
            <result name="expired">/casemgmt/expired.jsp</result>
            <result name="listNotes">/casemgmt/viewNotes.jsp</result>
            <result name="displayNote">/casemgmt/displayNote.jsp</result>
            <result name="clientHistoryPrintPreview">/casemgmt/client_history_printPreview.jsp</result>
        </action>
        <action name="CaseManagementEntry" class="io.github.carlos_emr.carlos.casemgmt.web.CaseManagementEntry2Action" method="execute">
            <result name="setUpMainEncounterPage">/casemgmt/newEncounterLayout.jsp</result>
            <result name="view">/casemgmt/CaseManagementEntry.jsp</result>
            <result name="list">/CaseManagementView.do?method=view</result>
            <result name="listCPPNotes" type="redirect">
            <param name="location">${reloadUrl}</param>
        </result>
            <result name="IssueSearch">/casemgmt/IssueSearch.jsp</result>
            <result name="NoDemoERR">/casemgmt/noDemo.jsp</result>
            <result name="windowClose">/casemgmt/close.jsp</result>
            <result name="windowCloseError">/casemgmt/closeWithError.jsp</result>
            <result name="historyview">/casemgmt/historyview.jsp</result>
            <result name="showHistory">/casemgmt/showHistory.jsp</result>
            <result name="issueList_ajax">/casemgmt/noteIssueList.jsp</result>
            <result name="expired">/casemgmt/expired.jsp</result>
        </action>
        <action name="OscarChartPrint" class="io.github.carlos_emr.carlos.casemgmt.web.EChartPrint2Action"/>
        <action name="ClientImage" class="io.github.carlos_emr.carlos.casemgmt.web.ClientImage2Action" method="execute">
            <interceptor-ref name="defaultStack">
                <param name="actionFileUpload.allowedTypes">image/jpeg,image/gif</param>
            </interceptor-ref>
            <result name="success">/casemgmt/uploadimage.jsp</result>
        </action>
        <action name="casemgmt/ExtPrintRegistry" class="io.github.carlos_emr.carlos.casemgmt.web.ExtPrintRegistry2Action"/>

        <action name="ArchiveView" class="io.github.carlos_emr.carlos.casemgmt.web.ArchiveView2Action" method="execute">
            <result name="view">/provider/providercontrol.jsp</result>
        </action>


        <!-- ===== prevention JSP gating actions (migration slice) ===== -->
        <action name="prevention/ViewPreventionIndex" class="io.github.carlos_emr.carlos.prevention.gate.ViewPreventionIndex2Action">
            <result name="success">/WEB-INF/jsp/prevention/index.jsp</result>
        </action>
        <action name="prevention/ViewAddPreventionDataDisambiguate" class="io.github.carlos_emr.carlos.prevention.gate.ViewAddPreventionDataDisambiguate2Action">
            <result name="success">/WEB-INF/jsp/prevention/AddPreventionDataDisambiguate.jsp</result>
        </action>
        <action name="prevention/ViewPreventionManager" class="io.github.carlos_emr.carlos.prevention.gate.ViewPreventionManager2Action">
            <result name="success">/WEB-INF/jsp/prevention/PreventionManager.jsp</result>
        </action>
        <action name="prevention/ViewPreventionListManager" class="io.github.carlos_emr.carlos.prevention.gate.ViewPreventionListManager2Action">
            <result name="success">/WEB-INF/jsp/prevention/PreventionListManager.jsp</result>
        </action>
    </package>
</struts>
