<!--
    CARLOS EMR - Demographics Actions
    Contains action mappings for patient demographics, records, and health insurance number management.
-->
<struts>
    <package name="demographic" namespace="/" extends="struts-default">

        <global-results>
            <result name="securityError">/securityError.jsp</result>
            <result name="logout" type="redirect">/logout.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </global-results>

        <global-exception-mappings>
            <exception-mapping exception="java.lang.SecurityException" result="securityError"/>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

        <action name="admin/MergeRecords" class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicMergeRecord2Action">
            <result name="success">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=success</result>
            <result name="failure">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=failure</result>
            <result name="successUnMerge">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=successUnMerge</result>
            <result name="failureUnMerge">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=failureUnMerge</result>
            <result name="caisiSearch">/PMmodule/ClientSearch2.do</result>
        </action>
        <action name="demographic/printDemoLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoLabel2Action"/>
        <action name="demographic/printDemoAddressLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoAddressLabel2Action"/>
        <action name="demographic/printDemoChartLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoChartLabel2Action"/>
        <action name="demographic/printClientLabLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintClientLabLabel2Action"/>
        <action name="demographic/AddRelation" class="io.github.carlos_emr.carlos.demographic.pageUtil.AddDemographicRelationship2Action">
            <result name="success">/WEB-INF/jsp/demographic/AddAlternateContact.jsp</result>
            <result name="pmmClient">/PMmodule/ClientManager.do</result>
        </action>
        <action name="demographic/DeleteRelation" class="io.github.carlos_emr.carlos.demographic.pageUtil.DeleteDemographicRelationship2Action">
            <result name="success">/WEB-INF/jsp/demographic/AddAlternateContact.jsp</result>
        </action>
        <action name="form/importUpload" class="io.github.carlos_emr.carlos.demographic.pageUtil.ImportDemographicDataAction42Action">
            <interceptor-ref name="defaultStack"/>
            <result name="success">/WEB-INF/jsp/demographic/demographicImport.jsp</result>
        </action>
        <action name="form/importLogDownload" class="io.github.carlos_emr.carlos.demographic.pageUtil.ImportLogDownload2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicImport.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </action>
        <action name="demographic/DemographicExport" class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicExportAction42Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicExport.jsp</result>
            <result name="fail">/WEB-INF/jsp/demographic/demographicExport.jsp</result>
        </action>

        <action name="demographic/eRourkeExport" class="io.github.carlos_emr.carlos.demographic.pageUtil.RourkeExport2Action" method="execute">
            <result name="display">/WEB-INF/jsp/demographic/rourkeExport.jsp</result>
        </action>

        <action name="demographic/DemographicEdit"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicEdit2Action">
            <result name="success">/WEB-INF/jsp/demographic/edit.jsp</result>
        </action>

        <action name="demographic/DemographicAdd"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicAdd2Action">
            <result name="success">/WEB-INF/jsp/demographic/add.jsp</result>
        </action>

        <action name="demographic/DemographicSearch"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicsearchresults.jsp</result>
            <result name="apptResults">/WEB-INF/jsp/demographic/demographicsearch2apptresults.jsp</result>
        </action>

        <action name="demographic/DemographicApptHistory"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicApptHistory2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicappthistory.jsp</result>
        </action>

        <action name="demographic/DemographicUpdate"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicUpdate2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicupdatearecord.jsp</result>
            <result name="duplicate">/WEB-INF/jsp/demographic/demographicupdatearecord.jsp</result>
            <result name="methodNotAllowed" type="httpheader">
                <param name="status">405</param>
            </result>
        </action>

        <action name="demographic/DemographicAddRecord"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicAddRecord2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicaddarecord.jsp</result>
            <result name="duplicate">/WEB-INF/jsp/demographic/demographicaddarecord.jsp</result>
            <result name="methodNotAllowed" type="httpheader">
                <param name="status">405</param>
            </result>
        </action>

        <action name="demographic/DemographicPdfLabel"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicPdfLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicpdflabel.jsp</result>
        </action>

        <action name="demographic/DemographicLinkMsg"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicLinkMsg2Action">
            <result name="success">/WEB-INF/jsp/messenger/msgSearchDemo.jsp</result>
        </action>


        <!-- ===== demographic JSP gating actions (migration slice) ===== -->
        <action name="demographic/ViewEnrollmentHistory" class="io.github.carlos_emr.carlos.demographic.gate.ViewEnrollmentHistory2Action">
            <result name="success">/WEB-INF/jsp/demographic/EnrollmentHistory.jsp</result>
        </action>
        <action name="demographic/ViewAddDemoToPatientSet" class="io.github.carlos_emr.carlos.demographic.gate.ViewAddDemoToPatientSet2Action">
            <result name="success">/WEB-INF/jsp/demographic/addDemoToPatientSet.jsp</result>
        </action>
        <action name="demographic/ViewAddNewDemographicSwipe" class="io.github.carlos_emr.carlos.demographic.gate.ViewAddNewDemographicSwipe2Action">
            <result name="success">/WEB-INF/jsp/demographic/addnewdemographicswipe.jsp</result>
        </action>
        <action name="demographic/ViewContact" class="io.github.carlos_emr.carlos.demographic.gate.ViewContact2Action">
            <result name="success">/WEB-INF/jsp/demographic/contact.jsp</result>
        </action>
        <action name="demographic/ViewContactSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewContactSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/contactSearch.jsp</result>
        </action>
        <action name="demographic/ViewDemographicAudit" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicAudit2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicAudit.jsp</result>
        </action>
        <action name="demographic/ViewDemographicCohort" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicCohort2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicCohort.jsp</result>
        </action>
        <action name="demographic/ViewDemographicAddARecordHtm" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicAddARecordHtm2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicaddarecordhtm.jsp</result>
        </action>
        <action name="demographic/ViewDemographicEditDemographicJs" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicEditDemographicJs2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographiceditdemographic.js.jsp</result>
        </action>
        <action name="demographic/ViewDemographicLabelPrintSetting" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicLabelPrintSetting2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographiclabelprintsetting.jsp</result>
        </action>
        <action name="demographic/ViewDemographicPrintDemographic" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicPrintDemographic2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicprintdemographic.jsp</result>
        </action>
        <action name="demographic/ViewDemographicSearch2ReportResults" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicSearch2ReportResults2Action">
            <result name="success">/WEB-INF/jsp/demographic/demographicsearch2reportresults.jsp</result>
        </action>
        <action name="demographic/ViewPrintAddressLabel" class="io.github.carlos_emr.carlos.demographic.gate.ViewPrintAddressLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/printAddressLabel.jsp</result>
        </action>
        <action name="demographic/ViewPrintClientLabLabel" class="io.github.carlos_emr.carlos.demographic.gate.ViewPrintClientLabLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/printClientLabLabel.jsp</result>
        </action>
        <action name="demographic/ViewPrintDemoChartLabel" class="io.github.carlos_emr.carlos.demographic.gate.ViewPrintDemoChartLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/printDemoChartLabel.jsp</result>
        </action>
        <action name="demographic/ViewPrintDemoLabel" class="io.github.carlos_emr.carlos.demographic.gate.ViewPrintDemoLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/printDemoLabel.jsp</result>
        </action>
        <action name="demographic/ViewPrintEnvelope" class="io.github.carlos_emr.carlos.demographic.gate.ViewPrintEnvelope2Action">
            <result name="success">/WEB-INF/jsp/demographic/printEnvelope.jsp</result>
        </action>
        <action name="demographic/ViewProContact" class="io.github.carlos_emr.carlos.demographic.gate.ViewProContact2Action">
            <result name="success">/WEB-INF/jsp/demographic/procontact.jsp</result>
        </action>
        <action name="demographic/ViewProContactSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewProContactSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/procontactSearch.jsp</result>
        </action>
        <action name="demographic/ViewProfessionalSpecialistSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewProfessionalSpecialistSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/professionalSpecialistSearch.jsp</result>
        </action>
        <action name="demographic/ViewSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/search.jsp</result>
        </action>
        <action name="demographic/ViewZdemographicFullTitleSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewZdemographicFullTitleSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/zdemographicfulltitlesearch.jsp</result>
        </action>
        <action name="demographic/ViewZdemographicSwipe" class="io.github.carlos_emr.carlos.demographic.gate.ViewZdemographicSwipe2Action">
            <result name="success">/WEB-INF/jsp/demographic/zdemographicswipe.jsp</result>
        </action>
        <action name="demographic/ViewDisplayHealthCareTeam" class="io.github.carlos_emr.carlos.demographic.gate.ViewDisplayHealthCareTeam2Action">
            <result name="success">/WEB-INF/jsp/demographic/displayHealthCareTeam.jsp</result>
        </action>
        <action name="demographic/ViewManageHealthCareTeam" class="io.github.carlos_emr.carlos.demographic.gate.ViewManageHealthCareTeam2Action">
            <result name="success">/WEB-INF/jsp/demographic/manageHealthCareTeam.jsp</result>
        </action>
        <action name="demographic/ViewDisplayFirstNationsModule" class="io.github.carlos_emr.carlos.demographic.gate.ViewDisplayFirstNationsModule2Action">
            <result name="success">/WEB-INF/jsp/demographic/displayFirstNationsModule.jsp</result>
        </action>
        <action name="demographic/ViewManageFirstNationsModule" class="io.github.carlos_emr.carlos.demographic.gate.ViewManageFirstNationsModule2Action">
            <result name="success">/WEB-INF/jsp/demographic/manageFirstNationsModule.jsp</result>
        </action>
    </package>
</struts>
