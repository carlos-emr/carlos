<!--
    CARLOS EMR - Demographics Actions
    Contains action mappings for patient demographics, records, and health insurance number management.
-->
<struts>
    <package name="demographic" namespace="/" extends="struts-default">

        <global-results>
            <result name="securityError">/securityError.jsp</result>
            <result name="logout" type="redirect">/logout.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </global-results>

        <global-exception-mappings>
            <exception-mapping exception="java.lang.SecurityException" result="securityError"/>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

        <action name="admin/MergeRecords" class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicMergeRecord2Action">
            <result name="success">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=success</result>
            <result name="failure">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=failure</result>
            <result name="successUnMerge">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=successUnMerge</result>
            <result name="failureUnMerge">/WEB-INF/jsp/admin/demographicmergerecord.jsp?outcome=failureUnMerge</result>
            <result name="caisiSearch">/PMmodule/ClientSearch2.do</result>
        </action>
        <action name="demographic/printDemoLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoLabel2Action"/>
        <action name="demographic/printDemoAddressLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoAddressLabel2Action"/>
        <action name="demographic/printDemoChartLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintDemoChartLabel2Action"/>
        <action name="demographic/printClientLabLabelAction" class="io.github.carlos_emr.carlos.demographic.PrintClientLabLabel2Action"/>
        <action name="demographic/AddRelation" class="io.github.carlos_emr.carlos.demographic.pageUtil.AddDemographicRelationship2Action">
            <result name="success">/WEB-INF/jsp/demographic/AddRelation.do</result>
            <result name="pmmClient">/PMmodule/ClientManager.do</result>
        </action>
        <action name="demographic/DeleteRelation" class="io.github.carlos_emr.carlos.demographic.pageUtil.DeleteDemographicRelationship2Action">
            <result name="success">/WEB-INF/jsp/demographic/AddRelation.do</result>
        </action>
        <action name="form/importUpload" class="io.github.carlos_emr.carlos.demographic.pageUtil.ImportDemographicDataAction42Action">
            <interceptor-ref name="defaultStack"/>
            <result name="success">/WEB-INF/jsp/form/importUpload.do</result>
        </action>
        <action name="form/importLogDownload" class="io.github.carlos_emr.carlos.demographic.pageUtil.ImportLogDownload2Action">
            <result name="success">/WEB-INF/jsp/form/importUpload.do</result>
            <result name="error">/errorpage.jsp</result>
        </action>
        <action name="demographic/DemographicExport" class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicExportAction42Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicExport.do</result>
            <result name="fail">/WEB-INF/jsp/demographic/DemographicExport.do</result>
        </action>

        <action name="demographic/eRourkeExport" class="io.github.carlos_emr.carlos.demographic.pageUtil.RourkeExport2Action" method="execute">
            <result name="display">/WEB-INF/jsp/demographic/eRourkeExport.do</result>
        </action>

        <action name="demographic/DemographicEdit"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicEdit2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicEdit.do</result>
        </action>

        <action name="demographic/DemographicAdd"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicAdd2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicAdd.do</result>
        </action>

        <action name="demographic/DemographicSearch"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicSearch.do</result>
            <result name="apptResults">/WEB-INF/jsp/demographic/DemographicSearch.do</result>
        </action>

        <action name="demographic/DemographicApptHistory"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicApptHistory2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicApptHistory.do</result>
        </action>

        <action name="demographic/DemographicUpdate"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicUpdate2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicUpdate.do</result>
            <result name="duplicate">/WEB-INF/jsp/demographic/DemographicUpdate.do</result>
            <result name="methodNotAllowed" type="httpheader">
                <param name="status">405</param>
            </result>
        </action>

        <action name="demographic/DemographicAddRecord"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicAddRecord2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicAdd.do</result>
            <result name="duplicate">/WEB-INF/jsp/demographic/DemographicAdd.do</result>
            <result name="methodNotAllowed" type="httpheader">
                <param name="status">405</param>
            </result>
        </action>

        <action name="demographic/DemographicPdfLabel"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicPdfLabel2Action">
            <result name="success">/WEB-INF/jsp/demographic/DemographicPdfLabel.do</result>
        </action>

        <action name="demographic/DemographicLinkMsg"
                class="io.github.carlos_emr.carlos.demographic.pageUtil.DemographicLinkMsg2Action">
            <result name="success">/WEB-INF/jsp/messenger/msgSearchDemo.jsp</result>
        </action>


        <!-- ===== demographic JSP gating actions (migration slice) ===== -->
        <action name="demographic/ViewEnrollmentHistory" class="io.github.carlos_emr.carlos.demographic.gate.ViewEnrollmentHistory2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewEnrollmentHistory.do</result>
        </action>
        <action name="demographic/ViewAddDemoToPatientSet" class="io.github.carlos_emr.carlos.demographic.gate.ViewAddDemoToPatientSet2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewAddDemoToPatientSet.do</result>
        </action>
        <action name="demographic/ViewAddNewDemographicSwipe" class="io.github.carlos_emr.carlos.demographic.gate.ViewAddNewDemographicSwipe2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewAddNewDemographicSwipe.do</result>
        </action>
        <action name="demographic/ViewContact" class="io.github.carlos_emr.carlos.demographic.gate.ViewContact2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewContact.do</result>
        </action>
        <action name="demographic/ViewContactSearch" class="io.github.carlos_emr.carlos.demographic.gate.ViewContactSearch2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewContactSearch.do</result>
        </action>
        <action name="demographic/ViewDemographicAudit" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicAudit2Action">
            <result name="success">/WEB-INF/jsp/demographic/ViewDemographicAudit.do</result>
        </action>
        <action name="demographic/ViewDemographicCohort" class="io.github.carlos_emr.carlos.demographic.gate.ViewDemographicCohort2Action">
