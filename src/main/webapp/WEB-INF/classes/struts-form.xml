<!--
    CARLOS EMR - Forms & Dashboard Actions
    Contains action mappings for medical forms, dashboard displays, flowsheets, and vaccine management.
-->
<struts>
    <package name="form" namespace="/" extends="struts-default" strict-method-invocation="true">

        <action name="web/dashboard/display/DashboardDisplay" class="io.github.carlos_emr.carlos.dashboard.display.DisplayDashboard2Action">
            <result name="success">/WEB-INF/jsp/web/dashboard/display/DashboardDisplay.jsp</result>
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="web/dashboard/display/sharedOutcomesDashboard" class="io.github.carlos_emr.carlos.dashboard.display.gate.ViewSharedOutcomesDashboard2Action">
            <result name="success">/WEB-INF/jsp/web/dashboard/display/sharedOutcomesDashboard.jsp</result>
        </action>
        <action name="web/dashboard/display/DrilldownDisplay" class="io.github.carlos_emr.carlos.dashboard.display.DisplayDrilldown2Action">
            <result name="success">/WEB-INF/jsp/web/dashboard/display/DrilldownDisplay.jsp</result>
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="web/dashboard/display/AssignTickler" class="io.github.carlos_emr.carlos.dashboard.admin.AssignTickler2Action">
            <result name="success">/WEB-INF/jsp/web/dashboard/display/AssignTickler.jsp</result>
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="web/dashboard/display/ExportResults" class="io.github.carlos_emr.carlos.dashboard.admin.ExportResults2Action">
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="web/dashboard/display/DisplayIndicator" class="io.github.carlos_emr.carlos.dashboard.display.DisplayIndicator2Action">
            <result name="success">/WEB-INF/jsp/web/dashboard/display/IndicatorPanel.jsp</result>
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="web/dashboard/display/BulkPatientAction" class="io.github.carlos_emr.carlos.dashboard.admin.BulkPatientDashboard2Action">
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="formBPMH" class="io.github.carlos_emr.carlos.form.pharmaForms.formBPMH.web.BpmhFormRetrieve2Action">
            <result name="saved">/formBPMH?method=fetch</result>
            <result name="success">/WEB-INF/jsp/form/pharmaForms/formBPMH.jsp</result>
        </action>
        <action name="form/setupSelect" class="io.github.carlos_emr.carlos.form.pageUtil.FrmSetupSelect2Action">
            <result name="continue">/WEB-INF/jsp/form/formselect.jsp</result>
        </action>
        <action name="form/select" class="io.github.carlos_emr.carlos.form.pageUtil.FrmSelect2Action">
            <result name="success">/form/setupSelect</result>
        </action>
        <action name="form/xmlUpload" class="io.github.carlos_emr.carlos.form.pageUtil.FrmXmlUpload2Action">
            <result name="success">/WEB-INF/jsp/form/formXmlUpload.jsp</result>
        </action>
        <action name="form/formname" class="io.github.carlos_emr.carlos.form.Frm2Action">
            <result name="exit">/WEB-INF/jsp/encounter/close.jsp</result>
            <result name="printAll">/form/createpdf</result>
            <result name="printAllJasperReport">/form/formPdfJasperReport</result>
            <result name="printLabReq">/WEB-INF/jsp/form/formlabreqprint.jsp</result>
            <result name="print">/WEB-INF/jsp/error/errorpage.jsp</result>
            <result name="save">/form/forwardname</result>
            <result name="graph">/form/createpdf</result>
            <result name="failure">/WEB-INF/jsp/error/errorpage.jsp</result>
        </action>
        <action name="form/forwardshortcutname" class="io.github.carlos_emr.carlos.form.pageUtil.FormForward2Action"/>
        <action name="form/forwardname" class="io.github.carlos_emr.carlos.form.pageUtil.FormForwardNamed2Action"/>
        <action name="form/SetupForm" class="io.github.carlos_emr.carlos.form.pageUtil.FrmSetupForm2Action"/>
        <action name="form/SubmitForm" class="io.github.carlos_emr.carlos.form.pageUtil.FrmForm2Action"/>
        <action name="form/RHPrevention" class="io.github.carlos_emr.carlos.form.pageUtil.FrmFormRHPrevention2Action">
            <result name="success">/WEB-INF/jsp/form/formRhImmuneGlobulin.jsp</result>
        </action>
        <action name="form/AddRHWorkFlow" class="io.github.carlos_emr.carlos.form.pageUtil.FrmFormAddRHWorkFlow2Action">
            <result name="success">/form/RHPrevention</result>
        </action>
        <action name="form/BCAR2020" class="io.github.carlos_emr.carlos.form.FrmBCAR20202Action">
            <result name="pg1">/WEB-INF/jsp/form/formBCAR2020pg1.jsp</result>
            <result name="pg2">/WEB-INF/jsp/form/formBCAR2020pg2.jsp</result>
            <result name="pg3">/WEB-INF/jsp/form/formBCAR2020pg3.jsp</result>
            <result name="pg4">/WEB-INF/jsp/form/formBCAR2020pg4.jsp</result>
            <result name="pg5">/WEB-INF/jsp/form/formBCAR2020pg5.jsp</result>
            <result name="pg6">/WEB-INF/jsp/form/formBCAR2020Attachments.jsp</result>
            <result name="exit">/WEB-INF/jsp/encounter/close.jsp</result>
        </action>
        <action name="form/*" class="io.github.carlos_emr.carlos.form.gate.ViewForm2Action"/>
        <action name="admin/Flowsheet" class="io.github.carlos_emr.carlos.flowsheet.Flowsheet2Action"/>

    </package>
</struts>
