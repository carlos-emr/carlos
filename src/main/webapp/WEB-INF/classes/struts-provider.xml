            <result name="compose">/email/emailCompose.jsp</result>
        </action>
        <action name="email/emailComposeAction" class="io.github.carlos_emr.carlos.email.action.EmailCompose2Action">
            <result name="compose">/email/emailCompose.jsp</result>
            <result name="eFormError">/eform/efmshowform_data.jsp?error=true</result>
        </action>
        <action name="email/emailSendAction" class="io.github.carlos_emr.carlos.email.action.EmailSend2Action">
            <result name="success">/email/emailCompose.jsp</result>
            <result name="EFORM">/eform/efmshowform_data.jsp</result>
        </action>
