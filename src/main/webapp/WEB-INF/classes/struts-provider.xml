            <result name="displayList">/WEB-INF/jsp/web/inboxhub/InboxhubListMode.jsp</result>
            <result name="displayView">/WEB-INF/jsp/web/inboxhub/InboxhubViewMode.jsp</result>
            <result name="unauthorized">/WEB-INF/jsp/error/securityError.jsp</result>
            <result name="error">/WEB-INF/jsp/error/failure.jsp</result>
        </action>
        <action name="admin/ManageFax" class="io.github.carlos_emr.carlos.fax.admin.ConfigureFax2Action">
        </action>
        <action name="admin/ManageFaxes" class="io.github.carlos_emr.carlos.fax.admin.ManageFaxes2Action">
            <result name="faxstatus">/WEB-INF/jsp/admin/faxStatusResults.jspf</result>
        </action>
        <action name="fax/faxAction" class="io.github.carlos_emr.carlos.fax.action.Fax2Action">
            <result name="preview">/WEB-INF/jsp/fax/CoverPage.jsp</result>
            <result name="error">/WEB-INF/jsp/error/errorpage.jsp</result>
            <result name="CONSULTATION">/encounter/ViewRequest</result>
            <result name="EFORM">/eform/efmshowform_data</result>
            <result name="eFormError">/eform/efmshowform_data?error=true</result>
        </action>
        <action name="admin/ManageEmails" class="io.github.carlos_emr.carlos.email.admin.ManageEmails2Action">
