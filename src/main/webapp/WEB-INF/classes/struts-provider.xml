        <action name="provider/providerSignatureStamp" class="io.github.carlos_emr.carlos.provider.web.ProviderSignatureStamp2Action">
            <interceptor-ref name="defaultStack">
            <param name="actionFileUpload.allowedTypes">image/png,image/jpeg,image/gif</param>
            <param name="actionFileUpload.maximumSize">2097152</param>
        </interceptor-ref>
            <result name="input" type="httpheader">
            <param name="status">400</param>
        </result>
        </action>
