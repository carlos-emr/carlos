        </action>
        <action name="oscarReport/oscarMeasurements/InitializePatientsInAbnormalRangeCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptInitializePatientsInAbnormalRangeCDMReport2Action">
