            <result name="done">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
            <result name="success">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
            <result name="deleted">/oscarReport/reportByTemplate/homePage.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/generateOutFilesAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.GenerateOutFiles2Action">
            <result name="success">/oscarReport/reportByTemplate/resultReport.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/uploadTemplates" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.UploadTemplates2Action">
            <result name="success">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
        </action>
