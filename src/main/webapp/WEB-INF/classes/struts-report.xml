            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateEnvelopes" class="io.github.carlos_emr.carlos.report.pageUtil.GenerateEnvelopes2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateSpreadsheet" class="io.github.carlos_emr.carlos.report.pageUtil.GeneratePatientSpreadSheetList2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateLetters" class="io.github.carlos_emr.carlos.report.pageUtil.GeneratePatientLetters2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
