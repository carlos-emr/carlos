<!--
    CARLOS EMR - Reports Actions
    Contains action mappings for clinical reports, demographic reports, measurement reports, and data export.
-->
<struts>
    <package name="report" namespace="/" extends="struts-default">

        <global-results>
            <result name="securityError">/securityError.jsp</result>
            <result name="error">/errorpage.jsp</result>
        </global-results>

        <global-exception-mappings>
            <exception-mapping exception="java.lang.SecurityException" result="securityError"/>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

        <action name="report/printLabDaySheetAction" class="io.github.carlos_emr.carlos.report.pageUtil.printLabDaySheet2Action"/>
        <action name="oscarReport/FluBilling" class="io.github.carlos_emr.carlos.report.pageUtil.RptFluBilling2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/oscarReportFluBilling.jsp</result>
        </action>
        <action name="oscarReport/RptByExample" class="io.github.carlos_emr.carlos.report.pageUtil.RptByExample2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/RptByExample.jsp</result>
        </action>
        <action name="oscarReport/RptViewAllQueryByExamples" class="io.github.carlos_emr.carlos.report.pageUtil.RptViewAllQueryByExamples2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/RptViewAllQueryByExamples.jsp</result>
        </action>
        <action name="oscarReport/RptByExamplesFavorite" class="io.github.carlos_emr.carlos.report.pageUtil.RptByExamplesFavorite2Action">
            <result name="edit">/WEB-INF/jsp/oscarReport/RptByExamplesFavorite.jsp</result>
            <result name="success">/WEB-INF/jsp/oscarReport/RptByExamplesAllFavorites.jsp</result>
        </action>
        <action name="oscarReport/RptByExamplesAllFavorites" class="io.github.carlos_emr.carlos.report.pageUtil.RptByExamplesAllFavorites2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/RptByExamplesAllFavorites.jsp</result>
        </action>
        <action name="report/DemographicReport" class="io.github.carlos_emr.carlos.report.pageUtil.RptDemographicReport2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/CreateDemographicSet" class="io.github.carlos_emr.carlos.report.pageUtil.RptCreateDemographicSet2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="oscarReport/obec" class="io.github.carlos_emr.carlos.report.pageUtil.Obec2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/obec.jsp</result>
            <result name="input">/WEB-INF/jsp/oscarReport/obec.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/SetupSelectCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptSetupSelectCDMReport2Action">
            <result name="continue">/oscarReport/oscarMeasurements/SelectCDMReport.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/SelectCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptSelectCDMReport2Action">
            <result name="patientWhoMetGuideline">/oscarReport/oscarMeasurements/InitializePatientsMetGuidelineCDMReport.jsp</result>
            <result name="patientInAbnormalRange">/oscarReport/oscarMeasurements/InitializePatientsInAbnormalRangeCDMReport.jsp</result>
            <result name="freqencyOfReleventTests">/oscarReport/oscarMeasurements/InitializeFrequencyOfRelevantTestsCDMReport.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/InitializePatientsMetGuidelineCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptInitializePatientsMetGuidelineCDMReport2Action">
            <result name="success">/oscarReport/oscarMeasurements/CDMReport.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/InitializePatientsInAbnormalRangeCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptInitializePatientsInAbnormalRangeCDMReport2Action">
            <result name="success">/oscarReport/oscarMeasurements/CDMReport.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/InitializeFrequencyOfRelevantTestsCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptInitializeFrequencyOfRelevantTestsCDMReport2Action">
            <result name="success">/oscarReport/oscarMeasurements/CDMReport.jsp</result>
        </action>
        <action name="report/DemographicSetEdit" class="io.github.carlos_emr.carlos.report.pageUtil.DemographicSetEdit2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/demographicSetEdit.jsp</result>
        </action>
        <action name="report/SetEligibility" class="io.github.carlos_emr.carlos.report.pageUtil.DemographicSetEligibility2Action">
            <result name="success">/WEB-INF/jsp/oscarReport/demographicSetEdit.jsp</result>
        </action>
        <action name="RunClinicalReport" class="io.github.carlos_emr.carlos.report.ClinicalReports.PageUtil.RunClinicalReport2Action">
            <result name="success">/WEB-INF/jsp/report/ClinicalReports.jsp</result>
        </action>
        <action name="report/RemoveClinicalReport" class="io.github.carlos_emr.carlos.report.ClinicalReports.PageUtil.RemoveClinicalReportFromHistory2Action">
            <result name="success">/WEB-INF/jsp/report/ClinicalReports.jsp</result>
        </action>
        <action name="report/DeleteDemographicReport" class="io.github.carlos_emr.carlos.report.pageUtil.RptDemographQueryFavouriteDelete2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateEnvelopes" class="io.github.carlos_emr.carlos.report.pageUtil.GenerateEnvelopes2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateSpreadsheet" class="io.github.carlos_emr.carlos.report.pageUtil.GeneratePatientSpreadSheetList2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/GenerateLetters" class="io.github.carlos_emr.carlos.report.pageUtil.GeneratePatientLetters2Action">
            <result name="success">/oscarReport/ReportDemographicReport.jsp</result>
        </action>
        <action name="report/ViewManageLetters" class="io.github.carlos_emr.carlos.report.pageUtil.ViewManageLetters2Action">
            <result name="success">/WEB-INF/jsp/report/ManageLetters.jsp</result>
        </action>
        <action name="report/ManageLetters" class="io.github.carlos_emr.carlos.report.pageUtil.ManagePatientLetters2Action">
            <result name="success">/report/GenerateLetters.jsp</result>
            <result name="success_manage_from_prevention">/WEB-INF/jsp/oscarPrevention/PreventionReporting.jsp</result>
        </action>
        <action name="report/DownloadLetter" class="io.github.carlos_emr.carlos.report.pageUtil.DownloadPatientLetters2Action">
            <result name="success">/report/GenerateLetters.jsp</result>
        </action>
        <action name="report/DeleteLetter" class="io.github.carlos_emr.carlos.report.pageUtil.DeletePatientLetters2Action">
            <result name="success">/WEB-INF/jsp/report/ManageLetters.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/GenerateReportAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.GenerateReport2Action">
            <result name="success">/oscarReport/reportByTemplate/resultReport.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/exportTemplateAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.ExportTemplate2Action">
            <result name="success">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/addEditTemplatesAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.ManageTemplates2Action">
            <result name="done">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
            <result name="success">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
            <result name="deleted">/oscarReport/reportByTemplate/homePage.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/generateOutFilesAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.GenerateOutFiles2Action">
            <result name="success">/oscarReport/reportByTemplate/resultReport.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/uploadTemplates" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.UploadTemplates2Action">
            <result name="success">/oscarReport/reportByTemplate/addEditTemplate.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/rbtGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTGetGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/templateGroups.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/tempInGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTGetTemplatesInGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/templateGroups.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/addGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTAddGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/rbtGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/rbtAddToGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTAddToGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/actions/tempInGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/remFromGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTRemoveFromGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/actions/tempInGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/delGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTDeleteGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/rbtGroup.do</result>
        </action>
        <action name="appointment/printAppointmentReceiptAction" class="io.github.carlos_emr.carlos.report.pageUtil.PrintAppointmentReceipt2Action"/>

    </package>
</struts>
