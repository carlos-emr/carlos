            <result name="patientInAbnormalRange">/oscarReport/oscarMeasurements/InitializePatientsInAbnormalRangeCDMReport.jsp</result>
            <result name="freqencyOfReleventTests">/oscarReport/oscarMeasurements/InitializeFrequencyOfRelevantTestsCDMReport.jsp</result>
        </action>
        <action name="oscarReport/oscarMeasurements/InitializePatientsMetGuidelineCDMReport" class="io.github.carlos_emr.carlos.report.oscarMeasurements.pageUtil.RptInitializePatientsMetGuidelineCDMReport2Action">
