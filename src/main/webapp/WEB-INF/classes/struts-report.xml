            <result name="success">/report/GenerateLetters.jsp</result>
            <result name="success_manage_from_prevention">/oscarPrevention/PreventionReporting.jsp</result>
        </action>
        <action name="report/DownloadLetter" class="io.github.carlos_emr.carlos.report.pageUtil.DownloadPatientLetters2Action">
            <result name="success">/report/GenerateLetters.jsp</result>
        </action>
        <action name="report/DeleteLetter" class="io.github.carlos_emr.carlos.report.pageUtil.DeletePatientLetters2Action">
            <result name="success">/report/ManageLetters.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/GenerateReportAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.GenerateReport2Action">
            <result name="success">/oscarReport/reportByTemplate/resultReport.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/exportTemplateAction" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.ExportTemplate2Action">
            <result name="success">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
            <result name="fail">/oscarReport/reportByTemplate/reportConfiguration.jsp</result>
        </action>
