<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 7.1//EN" "https://struts.apache.org/dtds/struts-7.1.dtd">
<!--
    CARLOS EMR - Reports Actions
    Contains 38 action mappings for clinical reports, demographic reports, measurement reports, and data export.
-->
<struts>
