            <result name="success">/oscarReport/reportByTemplate/templateGroups.jsp</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/addGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTAddGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/rbtGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/rbtAddToGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTAddToGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/actions/tempInGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/remFromGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTRemoveFromGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/actions/tempInGroup.do</result>
        </action>
        <action name="oscarReport/reportByTemplate/actions/delGroup" class="io.github.carlos_emr.carlos.report.reportByTemplate.actions.RBTDeleteGroup2Action">
            <result name="success">/oscarReport/reportByTemplate/rbtGroup.do</result>
        </action>
        <action name="appointment/printAppointmentReceiptAction" class="io.github.carlos_emr.carlos.report.pageUtil.PrintAppointmentReceipt2Action"/>

