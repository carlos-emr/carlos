            <result name="success">/WEB-INF/jsp/appointment/appointmentaddarecord.jsp</result>
        </action>
        <action name="appointment/UpdateRecord" class="io.github.carlos_emr.carlos.appointment.pageUtil.AppointmentUpdateRecord2Action">
            <result name="success">/WEB-INF/jsp/appointment/appointmentupdatearecord.jsp</result>
        </action>
