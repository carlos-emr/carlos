            <result name="view">/WEB-INF/jsp/demographic/viewContact.jsp</result>
            <result name="manage">/WEB-INF/jsp/demographic/ManageContacts.jsp</result>
            <result name="windowClose">/WEB-INF/jsp/demographic/close.jsp</result>
