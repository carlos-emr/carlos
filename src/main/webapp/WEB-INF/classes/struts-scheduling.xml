        </action>
        <action name="appointment/appointmentcopyrecord" class="io.github.carlos_emr.carlos.appointment.gate.ViewAppointmentWrite2Action">
            <result name="success">/WEB-INF/jsp/appointment/appointmentcopyrecord.jsp</result>
