            <result name="edit">/appointment/appointmentTypeAction.do?oper=edit</result>
            <result name="success">/WEB-INF/jsp/appointment/appointmentTypeList.jsp</result>
            <result name="failure">/WEB-INF/jsp/appointment/appointmentTypeList.jsp</result>
            <result name="redirect" type="redirectAction">
            <param name="actionName">appointmentTypeAction</param>
            <param name="namespace">/appointment</param>
        </result>
        </action>

        <!--
            ===== appointment/ JSP view gates =====
            Tail-interactive slice of the appointment module migration:
            all public-path .jsp moved behind /WEB-INF/jsp/ and reached
            only through these .do action gates. Closes the residue CVE
            vectors where appointmentaddarecord/update/delete/cut.jsp
            lived in both public and WEB-INF paths with divergent logic.
        -->
        <action name="appointment/addappointment" class="io.github.carlos_emr.carlos.appointment.gate.ViewAppointmentWrite2Action">
            <result name="success">/WEB-INF/jsp/appointment/addappointment.jsp</result>
        </action>
        <action name="appointment/editappointment" class="io.github.carlos_emr.carlos.appointment.gate.ViewAppointmentWrite2Action">
            <result name="success">/WEB-INF/jsp/appointment/editappointment.jsp</result>
        </action>
