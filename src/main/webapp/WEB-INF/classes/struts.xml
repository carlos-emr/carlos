<!--
    CARLOS EMR - Struts Configuration
    This file contains global constants and includes module-specific action configurations.
    Each struts-*.xml file defines actions for a specific functional domain.
-->
<struts>
    <!-- Global constants -->
    <constant name="struts.mapper.action.prefix.enabled" value="false"/>
    <constant name="struts.action.extension" value="do" />
    <constant name="struts.devMode" value="${struts.devMode}"/>
    <constant name="struts.objectFactory" value="spring"/>
    <constant name="struts.enable.SlashesInActionNames" value="true" />
    <constant name="struts.mapper.alwaysSelectFullNamespace" value="false" />
    <constant name="struts.actionConfig.fallbackToEmptyNamespace" value="true" />
    <constant name="struts.serve.static" value="true" />
    <constant name="struts.serve.static.browserCache" value="true" />
    <constant name="struts.action.excludePattern" value=".*\.(css|js|png|jpg|gif)$|^/ws/.*|^/servlet/.*" />
    <constant name="struts.custom.i18n.resources" value="oscarResources,MessageResources_mcedt"/>
    <constant name="struts.multipart.maxSize" value="524288000" />
    <!-- Use stream-based multipart parser (reads from getInputStream()) instead of the default
         jakarta parser (reads from getParts()). Required because CarlosCsrfGuardFilter wraps
         multipart requests with MultiReadHttpServletRequest for CSRF token extraction, and
         getParts() on the wrapped request fails since the underlying stream was consumed. -->
    <constant name="struts.multipart.parser" value="jakarta-stream" />

    <!-- Module configurations (alphabetical) -->
    <include file="struts-admin.xml"/>
    <include file="struts-billing.xml"/>
    <include file="struts-clinical.xml"/>
    <include file="struts-demographic.xml"/>
    <include file="struts-document.xml"/>
    <include file="struts-eform.xml"/>
    <include file="struts-encounter.xml"/>
    <include file="struts-form.xml"/>
    <include file="struts-integration.xml"/>
    <include file="struts-lab.xml"/>
    <include file="struts-login.xml"/>
    <include file="struts-messenger.xml"/>
    <include file="struts-pmmodule.xml"/>
    <include file="struts-prescription.xml"/>
    <include file="struts-provider.xml"/>
    <include file="struts-report.xml"/>
    <include file="struts-scheduling.xml"/>
</struts>
