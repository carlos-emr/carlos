							class="xlink" rel="${ctx}/billing/CA/BC/GenerateTeleplanFile"><fmt:message key="admin.admin.simulateSubFile2"/></a></li>
						<li><a href='javascript:void(0);'
							class="xlink" rel="${ctx}/billing/CA/BC/SimulateTeleplanFile"><fmt:message key="admin.admin.genTeleplanFile2"/></a></li>
						<li><a href='javascript:void(0);'
							class="xlink" rel="${ctx}/billing/CA/BC/ManageTeleplan"><fmt:message key="admin.admin.manageTeleplan"/></a></li>
					</oscar:oscarPropertiesCheck>
					<oscar:oscarPropertiesCheck property="NEW_BC_TELEPLAN" value="no"
						defaultVal="true">
						<li><a href='javascript:void(0);'
							class="xlink" rel="${ctx}/billing/CA/BC/ViewBillingTA"><fmt:message key="admin.admin.uploadRemittance"/></a></li>
					</oscar:oscarPropertiesCheck>
					<li><a href='javascript:void(0);'
						class="xlink" rel="${ctx}/billing/CA/BC/ProcessRemittance"><fmt:message key="admin.admin.reconciliationReports"/></a></li>
					<li><a href='javascript:void(0);'
