					<li><a href='javascript:void(0);'
						class="xlink" rel="${ctx}<%= oscarVariables.getProperty("RA_FORWORD", "/billing/CA/ON/ViewGenRA") %>"><fmt:message key="admin.admin.btnBillingReconciliation"/></a></li>
					<!--  li><a href='javascript:void(0);' onclick ='popupPage(600,1000,"${ctx}/billing/CA/ON/billingOBECEA.jsp");return false;'><fmt:message key="admin.admin.btnEDTBillingReportGenerator"/></a></li-->
					<li><a href='javascript:void(0);'
						class="xlink" rel="${ctx}/billing/CA/ON/ViewBillStatus"><fmt:message key="admin.admin.invoiceRpts"/></a></li>
		                        <li><a href='javascript:void(0);'
