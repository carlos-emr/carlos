						class="xlink" rel="${ctx}/billing/CA/BC/billingAddCode"><fmt:message key="admin.admin.ManagePrivFrm"/></a></li>
					<oscar:oscarPropertiesCheck property="BC_BILLING_CODE_MANAGEMENT"
						value="yes">
						<li><a href='javascript:void(0);'
							class="xlink" rel="${ctx}/billing/CA/BC/billingAddCode"><fmt:message key="admin.admin.ManageBillCodes"/></a></li>
					</oscar:oscarPropertiesCheck>
					<li><a href='javascript:void(0);'
						class="xlink" rel="${ctx}/billing/CA/BC/showServiceCodeAssocs"><fmt:message key="admin.admin.ManageServiceDiagnosticCodeAssoc"/></a></li>
					<li><a href='javascript:void(0);'
						class="xlink" rel="${ctx}/billing/CA/BC/supServiceCodeAssocAction"><fmt:message key="admin.admin.ManageProcedureFeeCodeAssoc"/></a></li>

