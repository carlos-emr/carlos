				</div>
	</security:oscarSec>
<!-- #Data Management END-->




	</div> <!-- ACCORDION END -->
	
</div><!-- SIDE END -->

<script>
function popupPage(vheight,vwidth,varpage) { //open a new popup window
	  var page = "" + varpage;
	  windowprops = "height="+vheight+",width="+vwidth+",location=no,scrollbars=yes,menubars=no,toolbars=no,resizable=yes,screenX=0,screenY=0,top=0,left=0";//360,680
	  var popup=window.open(page, "groupno", windowprops);
	  if (popup != null) {
	    if (popup.opener == null) {
	      popup.opener = self;
	    }
	    popup.focus();
	  }
}

$(document).ready(function(){
	$(".accordion-header").click(function(e) {
		if($(this).hasClass('selected-heading')) {
			$('.accordion-header ').removeClass('selected-heading');
		}else{
        	$('.accordion-header').not(this).removeClass('selected-heading');
        	$(this).addClass('selected-heading');
		}
	});

	$(".xlink").click(function(e) {
		var source = $(this).attr('rel');
		var submitForm = $(this).data('submit-form');
		var iframeTitle = $(this).data('frame-title') || $.trim($(this).text()) || "Administration page";
		$("#dynamic-content").addClass("dynamic-iframe-content");
		$("#dynamic-content").empty().append($("<iframe>", {
			id: "myFrame",
			name: "myFrame",
			title: iframeTitle,
			loading: "lazy",
			role: "region",
			"aria-live": "polite"
		}).css("border", "0"));
		if (submitForm) {
			var form = document.getElementById(submitForm);
			if (form) {
				form.submit();
			}
		} else {
			$("#myFrame").attr("src", source);
		}
		$("html, body").animate({ scrollTop: 0 }, "slow");
	});


	//using this to collapse and load items so we can have direct links to menu items
	try
	  {
		var show = getUrlVars()["show"];

		if(show!=null){
			var load = getUrlVars()["load"];
			var pageToLoad="";
			
			if(show!=null & load!=null){
				pageToLoad=$('.default'+show+load).attr('href');
			}else{
				pageToLoad=$('.default'+show).attr('href');		
			}

		//expand request menu item
		bootstrap.Collapse.getOrCreateInstance(document.getElementById('collapse'+show)).show();

		//load request page or load default
		$("#dynamic-content").load(pageToLoad, 
				function(response, status, xhr) {
			  		if (status == "error") {
				    	var msg = "Sorry but there was an error: ";
				    	$("#dynamic-content").html(msg + xhr.status + " " + xhr.statusText);
					}
		});	
		
		}
	  }
	catch(err)
	  {
	  //do nothing
	  }	

});

//Read a page's GET URL variables and return them as an associative array.
function getUrlVars()
{
    var vars = [], hash;
    var hashes = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
    for(var i = 0; i < hashes.length; i++)
    {
        hash = hashes[i].split('=');
        vars.push(hash[0]);
        vars[hash[0]] = hash[1];
    }
    return vars;
}
</script>
