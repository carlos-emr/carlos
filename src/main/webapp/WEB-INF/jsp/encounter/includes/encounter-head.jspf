<%@ taglib uri="owasp.encoder.jakarta.advanced" prefix="e" %>
<%@ taglib uri="carlos" prefix="carlos" %>
    <head>
        <%@ include file="/WEB-INF/jsp/includes/global-head.jspf" %>

        <title><fmt:setBundle basename="oscarResources"/><fmt:message key="encounter.Index.title"/> - <oscar:nameage
                demographicNo="${bean.demographicNo}"/></title>
        <%-- S5131: getServerName() returns the Host header — safe when deployed behind a reverse proxy that validates the Host header (required for production) --%>
        <base href="<%= request.getScheme() + "://" + request.getServerName() + ":" + request.getServerPort() + request.getContextPath() + "/" %>"> <%-- NOSONAR --%>

        <link rel="stylesheet" type="text/css" media="all" href="${ctx}/share/css/extractedFromPages.css"/>
        <link rel="stylesheet" type="text/css" href="${ctx}/encounter/encounterStyles.css">
        <link rel="stylesheet" type="text/css" href="${ctx}/encounter/css/encounter-page.css">

        <script type="text/javascript">jQuery.noConflict();</script>
        <!-- jQuery.noConflict() frees $ for the Prototype shim; use jQuery() for jQuery calls -->
        <script src="${ctx}/share/javascript/prototype-compat.js" type="text/javascript"></script>

        <%-- Popup menu scripts --%>
        <script src="${ctx}/share/javascript/popupmenu.js" type="text/javascript"></script>
        <script src="${ctx}/share/javascript/menutility.js" type="text/javascript"></script>

        <%-- Server-side configuration for encounter.js --%>
        <script type="text/javascript">
            var encounterConfig = {
                ctx: "${carlos:forJavaScript(ctx)}",
                patientSex: "<carlos:encode value='${bean.patientSex}' context="javaScript"/>",
                pAge: "<carlos:encode value='${pAge}' context="javaScript"/>",
                popUrl: <c:choose><c:when test="${not empty popUrl}">"<carlos:encode value='${popUrl}' context="javaScript"/>"</c:when><c:otherwise>null</c:otherwise></c:choose>,
                i18n: {
                    title: "<fmt:setBundle basename='oscarResources'/><fmt:message key='encounter.Index.title'/>",
                    closeEncounterConfirm: "<fmt:message key='encounter.Index.closeEncounterWindowConfirm'/>",
                    confirmSplit: "<fmt:message key='encounter.Index.confirmSplit'/>",
                    popupPageAlert: "<fmt:message key='encounter.Index.popupPageAlert'/>",
                    onUnbilledConfirm: "<fmt:message key='encounter.Index.onUnbilledConfirm'/>",
                    popupSearchPageWindow: "<fmt:message key='encounter.Index.popupSearchPageWindow'/>"
                },
                images: {
                    expand: "${carlos:forJavaScript(ctx)}/encounter/graphics/expand.gif",
                    collapse: "${carlos:forJavaScript(ctx)}/messenger/img/collapse.gif",
                    transparent: "${carlos:forJavaScript(ctx)}/images/clear.gif"
                },
                urls: {
                    navSections: {
                        preventions: "${carlos:forJavaScript(ctx)}/encounter/displayPrevention?hC=009999",
                        tickler: "${carlos:forJavaScript(ctx)}/encounter/displayTickler?hC=FF6600",
                        Dx: "${carlos:forJavaScript(ctx)}/encounter/displayDisease?hC=5A5A5A",
                        forms: "${carlos:forJavaScript(ctx)}/encounter/displayForms?hC=917611",
                        eforms: "${carlos:forJavaScript(ctx)}/encounter/displayEForms?hC=11CC00",
                        docs: "${carlos:forJavaScript(ctx)}/encounter/displayDocuments?hC=476BB3",
                        labs: "${carlos:forJavaScript(ctx)}/encounter/displayLabs?hC=A0509C",
                        HRM: "${carlos:forJavaScript(ctx)}/encounter/displayHRM?hC=28A0A8",
                        msgs: "${carlos:forJavaScript(ctx)}/encounter/displayMessages?hC=DDDD00",
                        measurements: "${carlos:forJavaScript(ctx)}/encounter/displayMeasurements?hC=344887",
                        consultation: "${carlos:forJavaScript(ctx)}/encounter/displayConsultation"
                    },
                    leftNavbar: {
                        preventions: "${carlos:forJavaScript(ctx)}/encounter/displayPrevention?hC=009999",
                        tickler: "${carlos:forJavaScript(ctx)}/encounter/displayTickler?hC=FF6600",
                        Dx: "${carlos:forJavaScript(ctx)}/encounter/displayDisease?hC=5A5A5A",
                        forms: "${carlos:forJavaScript(ctx)}/encounter/displayForms?hC=917611",
                        eforms: "${carlos:forJavaScript(ctx)}/encounter/displayEForms?hC=11CC00",
                        docs: "${carlos:forJavaScript(ctx)}/encounter/displayDocuments?hC=476BB3",
                        labs: "${carlos:forJavaScript(ctx)}/encounter/displayLabs?hC=A0509C",
                        HRM: "${carlos:forJavaScript(ctx)}/encounter/displayHRM?hC=28A0A8",
                        msgs: "${carlos:forJavaScript(ctx)}/encounter/displayMessages?hC=DDDD00",
                        measurements: "${carlos:forJavaScript(ctx)}/encounter/displayMeasurements?hC=344887",
                        consultation: "${carlos:forJavaScript(ctx)}/encounter/displayConsultation?hC=",
                        eConsult: "${carlos:forJavaScript(ctx)}/encounter/displayEconsultation"
                    }
                },
                calculators: [
                    { name: "<fmt:message key='encounter.Index.bodyMass'/>", action: "popupPage(650,775,'BodyMassIndex','http://www.intmed.mcw.edu/clincalc/body.html')" },
                    { name: "<fmt:message key='encounter.Index.coronary'/>", action: "popupPage(525,775,'CoronaryArteryDiseaseRisk','${ctx}/encounter/calculators/ViewCoronaryArteryDiseaseRiskPrediction?sex=<carlos:encode value='${bean.patientSex}' context="javaScript"/>&age=<carlos:encode value='${pAge}' context="javaScript"/>')" },
                    { name: "<fmt:message key='encounter.Index.msgOsteoporotic'/>", action: "popupPage(525,775,'OsteoporoticFracture','${ctx}/encounter/calculators/ViewOsteoporoticFracture?sex=<carlos:encode value='${bean.patientSex}' context="javaScript"/>&age=<carlos:encode value='${pAge}' context="javaScript"/>')" },
                    { name: "<fmt:message key='encounter.Index.pregnancy'/>", action: "popupPage(650,775,'PregancyCalculator','http://www.intmed.mcw.edu/clincalc/pregnancy.html')" },
                    { name: "<fmt:message key='encounter.Index.simpleCalculator'/>", action: "popupPage(400,500,'SimpleCalc','${ctx}/encounter/calculators/ViewSimpleCalculator')" },
                    { name: "<fmt:message key='encounter.Index.generalConversions'/>", action: "popupPage(650,775,'GeneralConversions','${ctx}/encounter/calculators/ViewGeneralCalculators')" }
                ],
                templates: [<c:forEach var="tmpl" items="${templateNames}" varStatus="s">"${tmpl}"<c:if test="${!s.last}">,</c:if></c:forEach>]
            };
        </script>
        <script type="text/javascript" src="${ctx}/encounter/js/encounter.js"></script>
    </head>
