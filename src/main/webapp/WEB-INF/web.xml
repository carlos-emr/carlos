  <absolute-ordering />

  <context-param>
    <param-name>contextConfigLocation</param-name>
    <param-value>
      classpath:net/bull/javamelody/monitoring-spring.xml
      classpath:applicationContext*.xml
    </param-value>
  </context-param>

    <!-- ResponseSanitizationFilter MUST be the outermost filter (first filter-mapping) so it
         can intercept stack traces from all downstream layers: other WAF filters, the Struts
         dispatcher, JSP compilation errors, and unhandled exceptions. It wraps the response to
         capture PrintWriter output, detects Java stack trace markers in error responses, and
         replaces any tainted body with a generic page containing only the HTTP status code and
         a correlation ID for log lookup. -->
    <filter>
        <filter-name>ResponseSanitizationFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.utility.ResponseSanitizationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ResponseSanitizationFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <!-- ERROR dispatch covers responses generated by Tomcat's error-page mechanism,
             ensuring stack traces in error-page resources are also sanitized. -->
        <dispatcher>ERROR</dispatcher>
    </filter-mapping>

        <filter>
		   <filter-name>monitoring</filter-name>
		   <filter-class>net.bull.javamelody.MonitoringFilter</filter-class>
		   <async-supported>true</async-supported>
		   <init-param>
				<param-name>system-actions-enabled</param-name>
				<param-value>false</param-value>
			</init-param>
			<init-param>
				<param-name>disabled</param-name>
				<param-value>false</param-value>
			</init-param>
        </filter>
        <filter-mapping>
			<filter-name>monitoring</filter-name>
			<url-pattern>/*</url-pattern>
			<dispatcher>REQUEST</dispatcher>
			<dispatcher>ASYNC</dispatcher>
        </filter-mapping>

    <!-- ==================== WAF Layer (runs before all application filters) ====================
         All WAF components are disabled by default — enable via carlos.properties:
           WAF_RATE_LIMIT_ENABLED=true    (per-IP rate limiting with path tiers)
           WAF_GEOIP_ENABLED=true         (GeoIP country filtering)
           WAF_DROP_LIST_ENABLED=true     (Spamhaus DROP list, requires WAF_GEOIP_ENABLED)
           WAF_ENABLED=true               (request inspection: SQLi, XSS, traversal, bots)
    -->

    <!-- XforwardHeaderFilter: resolves real client IP from X-Forwarded-For only when the
         immediate peer is a configured trusted proxy. Mapped first in the WAF layer so that
         all subsequent filters (including RateLimitFilter) use the trusted client IP rather
         than blindly trusting a spoofable header. -->
    <filter>
        <filter-name>XforwardHeader</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.XforwardHeaderFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>XforwardHeader</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Rate limiting: configurable per-path rate tiers with detect/enforce mode.
         Controlled by WAF_RATE_LIMIT_ENABLED in carlos.properties.
         Configuration via WAF_RATE_LIMIT_* keys in carlos.properties.
         XforwardHeaderFilter is mapped immediately above so rate limiting uses the real client
         IP even when the application is deployed behind a reverse proxy. -->
    <filter>
        <filter-name>RateLimitFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.RateLimitFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ResponseDefaultsFilter MUST be ordered before Struts execution. Struts action requests
         do not reach later filters once Struts executes them, so this filter must stay ahead of
         the Struts prepare/execute pair to guarantee encoding, caching, and security headers on
         Struts responses. -->
	<filter>
		<filter-name>ResponseDefaultsFilter</filter-name>
		<filter-class>io.github.carlos_emr.carlos.utility.ResponseDefaultsFilter</filter-class>
		<init-param>
			<param-name>noCacheEndings</param-name>
			<param-value>.jsp,.jsf,.json</param-value>
		</init-param>
    </filter>
    <filter-mapping>
		<filter-name>ResponseDefaultsFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

    <!-- Forward bare context-root and /index requests directly to the internal login JSP.
         This replaces the old public index welcome files and must run before Struts so
         "/" never falls through to container welcome-file resolution. The same filter
         only guards /forcepasswordreset method routing; the Struts action owns token checks. -->
    <filter>
        <filter-name>RootEntryRedirectFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.login.RootEntryRedirectFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RootEntryRedirectFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>

    <!-- CSRFGuard, CsrfGuardScriptInjectionFilter, and LogoutBroadcastFilter MUST be ordered
         before Struts execution. Once Struts executes an action, later filters in the chain do
         not run for that request. Placing these filters here ensures:
          1. CSRFGuard validates tokens on all Struts action POST requests. This mapping
             intentionally omits dispatcher elements, so Jakarta/Tomcat applies the default
             REQUEST dispatcher only; JSP FORWARD script injection is handled by the next filter.
           2. CsrfGuardScriptInjectionFilter is mapped for FORWARD dispatches to JSPs so
              csrfguard.js is injected at the JSP render layer without double-wrapping
              Struts REQUEST responses. Re-adding REQUEST dispatch here can cause Struts/JSP
              responses to be captured by two wrappers and has previously produced blank
              schedule pages even though the action completed successfully.
           3. LogoutBroadcastFilter remains before Struts so it can inject into
              Struts-rendered HTML pages (e.g. Inboxhub, DisplayMessages), but it
              only wraps authenticated/session-establishing requests and configures
              its large buffer lazily for HTML responses.
         Filter declarations remain in their respective sections below;
         only filter-mapping order determines chain position. -->
    <filter-mapping>
        <filter-name>CSRFGuard</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfGuardScriptInjectionFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>
    <filter-mapping>
        <filter-name>LogoutBroadcastFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>

    <!-- HttpMethodGuardFilter: blocks GET requests on mutator actions and JSPs.
         Must be ordered after CSRFGuard (which validates POST tokens) and before Struts
         execution. This ensures mutator
         GET requests are rejected before Struts processes them. -->
    <filter>
        <filter-name>HttpMethodGuardFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.HttpMethodGuardFilter</filter-class>
        <!-- AddEditServiceCode is a search/add/edit hybrid — admin.jsp opens it
             via popupPage (window.open / GET) for the initial picker render.
             The action's own POST-only gate already requires POST when an
             `action` mutation parameter is present, so allowing GET here is
             safe. The action URL "AddEditServiceCode" matches the filter's
             "add" prefix rule but the page is not a pure mutator. -->
        <init-param>
            <param-name>allowList</param-name>
            <param-value>addeditservicecode</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>HttpMethodGuardFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- LoginFilter is the canonical authenticated-session gate for Struts and servlet routes.
         It must run before Struts prepare/execute so unauthenticated protected requests cannot
         fall through to action execution or Struts 404 handling first. Action-level session
         checks remain as defence-in-depth for direct unit tests and future filter-order changes. -->
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

	<filter>
		<filter-name>struts2-prepare</filter-name>
		<filter-class>org.apache.struts2.dispatcher.filter.StrutsPrepareFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>struts2-prepare</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
		<dispatcher>FORWARD</dispatcher>
		<dispatcher>INCLUDE</dispatcher>
	</filter-mapping>
    <!-- LoggedInUserFilter runs in the documented custom-filter gap between
         Struts prepare and execute so action requests have derived
         authenticated-session context before action invocation. -->
    <filter-mapping>
        <filter-name>LoggedInUserFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>
	<filter>
		<filter-name>struts2-execute</filter-name>
		<filter-class>org.apache.struts2.dispatcher.filter.StrutsExecuteFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>struts2-execute</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
		<dispatcher>FORWARD</dispatcher>
		<dispatcher>INCLUDE</dispatcher>
	</filter-mapping>
    <filter>
