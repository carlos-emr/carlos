    <!-- ==================== WAF Layer (runs before all application filters) ==================== -->

    <!-- Tomcat 11 built-in rate limiter: 100 requests/minute per IP (global).
         When behind a reverse proxy, ensure RemoteIpFilter (or XforwardHeaderFilter) is
         mapped before this filter so rate limiting uses the real client IP. -->
    <filter>
        <filter-name>RateLimitFilter</filter-name>
        <filter-class>org.apache.catalina.filters.RateLimitFilter</filter-class>
        <init-param>
            <param-name>bucketRequests</param-name>
            <param-value>100</param-value>
        </init-param>
        <init-param>
            <param-name>bucketDuration</param-name>
            <param-value>60</param-value>
        </init-param>
        <init-param>
            <param-name>statusCode</param-name>
            <param-value>429</param-value>
        </init-param>
        <init-param>
            <param-name>statusMessage</param-name>
            <param-value>Too Many Requests</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Login-specific rate limit: 10 attempts/minute per IP (brute force protection) -->
    <filter>
        <filter-name>LoginRateLimitFilter</filter-name>
        <filter-class>org.apache.catalina.filters.RateLimitFilter</filter-class>
        <init-param>
            <param-name>bucketRequests</param-name>
            <param-value>10</param-value>
        </init-param>
        <init-param>
            <param-name>bucketDuration</param-name>
            <param-value>60</param-value>
        </init-param>
        <init-param>
            <param-name>statusCode</param-name>
            <param-value>429</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>LoginRateLimitFilter</filter-name>
        <url-pattern>/login.do</url-pattern>
    </filter-mapping>

    <!-- GeoIP filter: restricts access to Canadian IPs only + Spamhaus DROP list blocking.
         Requires GeoLite2-Country.mmdb at /opt/geoip/ (disabled gracefully if not present).
         In detect mode by default — set mode=enforce in production after verifying logs. -->
    <filter>
        <filter-name>GeoIpFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.GeoIpFilter</filter-class>
        <init-param>
            <param-name>geoipDatabase</param-name>
            <param-value>/opt/geoip/GeoLite2-Country.mmdb</param-value>
        </init-param>
        <init-param>
            <param-name>allowedCountries</param-name>
            <param-value>CA</param-value>
        </init-param>
        <init-param>
            <param-name>mode</param-name>
            <param-value>detect</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>GeoIpFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- WAF filter: request inspection for SQLi, XSS, path traversal, command injection,
         scanner detection, and request limits. Configuration in /WEB-INF/waf-rules.properties.
         Starts in detect mode — review waf.filter logs before switching to enforce. -->
    <filter>
