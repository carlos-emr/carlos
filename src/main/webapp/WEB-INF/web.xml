    <!-- ResponseDefaultsFilter MUST be ordered before struts2. Struts2's StrutsPrepareAndExecuteFilter
         does not call chain.doFilter() for requests it handles, so any filter after it in the
         chain is never invoked for Struts action responses. Ensuring this filter runs before
         struts2 guarantees encoding, caching, and security headers are applied to Struts action responses. -->
    <filter>
        <filter-name>ResponseDefaultsFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.utility.ResponseDefaultsFilter</filter-class>
		<init-param>
			<param-name>noCacheEndings</param-name>
			<param-value>.jsp,.jsf,.json,.do</param-value>
		</init-param>
    </filter>
    <filter-mapping>
		<filter-name>ResponseDefaultsFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

    <!-- CSRFGuard, CsrfGuardScriptInjectionFilter, and LogoutBroadcastFilter MUST be ordered
         before struts2. StrutsPrepareAndExecuteFilter does not call chain.doFilter() for
         requests it handles, so filters placed after it in the chain are never invoked for
         Struts action (.do) responses. Placing these filters here ensures:
           1. CSRFGuard validates tokens on all Struts action POST requests
           2. CsrfGuardScriptInjectionFilter skips .do REQUEST dispatch (Tomcat 11 unwraps
              wrappers during forward), but runs on the FORWARD dispatch to the JSP where
              it wraps the response and injects csrfguard.js. The FORWARD dispatcher also
              prevents the default 8KB response buffer from truncating large JSP pages.
           3. LogoutBroadcastFilter wraps the response BEFORE Struts renders,
              so the logout broadcast script is injected into Struts-rendered HTML pages
              (e.g. Inboxhub.do, DisplayMessages.do)
         Filter declarations remain in their respective sections below;
         only filter-mapping order determines chain position. -->
    <filter-mapping>
        <filter-name>CSRFGuard</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfGuardScriptInjectionFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>
    <filter-mapping>
        <filter-name>LogoutBroadcastFilter</filter-name>
        <url-pattern>*.do</url-pattern>
    </filter-mapping>

    <!-- HttpMethodGuardFilter: blocks GET requests on mutator actions and JSPs.
         Must be ordered after CSRFGuard (which validates POST tokens) and before Struts
         (which does not call chain.doFilter for handled requests). This ensures mutator
         GET requests are rejected before Struts processes them. -->
    <filter>
        <filter-name>HttpMethodGuardFilter</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.HttpMethodGuardFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>HttpMethodGuardFilter</filter-name>
        <url-pattern>*.do</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>HttpMethodGuardFilter</filter-name>
        <url-pattern>*.jsp</url-pattern>
    </filter-mapping>

