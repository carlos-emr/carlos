    <!--  Cross Site Request Forgery (CSRFGuard 4.5) — Bootstrap Only
         web.xml contains ONLY the infrastructure wiring for CSRFGuard:
           - Config pointer (Owasp.CsrfGuard.Config): tells CSRFGuard where to find its properties file
           - Listeners: required for session-lifecycle token management
           - Filter registration: our custom validation filter
           - CsrfServlet: serves the dynamic csrfguard.js to clients

         All functional CSRFGuard configuration (token settings, protected methods, unprotected URLs,
         JavaScript injection behaviour, etc.) belongs EXCLUSIVELY in:
           src/main/webapp/WEB-INF/Owasp.CsrfGuard.properties

         For environment-specific overrides (e.g. enabling Config.Print in development), create:
           src/main/resources/Owasp.CsrfGuard.overlay.properties
         That file is picked up automatically by ConfigurationAutodetectProviderFactory and
         should NOT be committed for production deployments.

         See docs/csrf-protection-architecture.md for the full configuration architecture.
    -->
    <context-param>
        <param-name>Owasp.CsrfGuard.Config</param-name>
        <param-value>WEB-INF/Owasp.CsrfGuard.properties</param-value>
    </context-param>
    <listener>
        <listener-class>org.owasp.csrfguard.CsrfGuardServletContextListener</listener-class>
    </listener>
    <listener>
        <listener-class>org.owasp.csrfguard.CsrfGuardHttpSessionListener</listener-class>
    </listener>
    <filter>
        <filter-name>CSRFGuard</filter-name>
        <filter-class>io.github.carlos_emr.carlos.app.CarlosCsrfGuardFilter</filter-class>
    </filter>
    <!-- filter-mapping for CSRFGuard is declared earlier in the file, before struts2,
         so CSRF validation runs for all Struts action requests. -->
    <servlet>
        <servlet-name>CsrfServlet</servlet-name>
        <servlet-class>org.owasp.csrfguard.servlet.JavaScriptServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CsrfServlet</servlet-name>
        <url-pattern>/csrfguard</url-pattern>
    </servlet-mapping>

