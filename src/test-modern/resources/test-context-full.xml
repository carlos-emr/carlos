<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd
                           http://www.springframework.org/schema/tx
                           http://www.springframework.org/schema/tx/spring-tx.xsd
                           http://www.springframework.org/schema/context
                           http://www.springframework.org/schema/context/spring-context.xsd
                           http://www.springframework.org/schema/aop
                           http://www.springframework.org/schema/aop/spring-aop.xsd">

    <!--
        Full Spring Test Context Configuration

        This configuration file sets up a complete Spring context for integration testing
        that closely mimics the production environment while using an in-memory H2 database.

        Key Components:
        - H2 in-memory database configured with MySQL compatibility mode
        - Dual Hibernate SessionFactory and JPA EntityManagerFactory configuration
        - Transaction management with automatic rollback for test isolation
        - Manual bean definitions to avoid circular dependencies
        - Mock security components for bypassing authentication

        Database Configuration:
        - Uses H2 with MODE=MySQL for MySQL compatibility
        - DATABASE_TO_LOWER=TRUE to handle case-insensitive table/column names
        - Connection pooling via Apache DBCP

        Entity Management:
        - Supports both .hbm.xml mappings (legacy) and JPA annotations
        - Explicit entity listing in persistence.xml to prevent scanning issues
        - Custom OscarMySQL5Dialect adapted for H2

        Transaction Management:
        - @Transactional support with automatic rollback
        - Proper isolation between test methods
        - EntityManager flush/clear support for testing detached entities
    -->

    <aop:aspectj-autoproxy proxy-target-class="true"/>
    <context:annotation-config/>
    <tx:annotation-driven proxy-target-class="true"/>

    <!-- Properties -->
    <bean id="propertyConfigurer" class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
        <property name="properties">
            <props>
                <prop key="db_driver">org.h2.Driver</prop>
                <prop key="db_uri">jdbc:h2:mem:testdb</prop>
                <prop key="db_name">;MODE=MySQL;DB_CLOSE_DELAY=-1;DATABASE_TO_LOWER=TRUE;IGNORECASE=TRUE</prop>
                <prop key="db_username">sa</prop>
                <prop key="db_password"></prop>
                <prop key="db_max_active">10</prop>
                <prop key="db_max_idle">5</prop>
                <prop key="db_max_wait">10000</prop>
                <prop key="db_validationQuery">SELECT 1</prop>
                <prop key="db_remove_abandoned">false</prop>
                <prop key="db_remove_abandoned_timeout">300</prop>
                <prop key="db_log_abandoned">false</prop>
                <prop key="hibernate.dialect">org.hibernate.dialect.H2Dialect</prop>
                <prop key="hibernate.show_sql">false</prop>
                <prop key="hibernate.generate_statistics">false</prop>
                <prop key="casemgmt.note.password.enabled">false</prop>
                <prop key="pmm.refer.temporaryAdmission.enabled">false</prop>
                <prop key="pmm.client.search.outside.of.domain.enabled">false</prop>
            </props>
        </property>
    </bean>

    <!-- DataSource -->
    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
        <property name="driverClassName" value="${db_driver}" />
        <property name="url" value="${db_uri}${db_name}" />
        <property name="username" value="${db_username}" />
        <property name="password" value="${db_password}" />
        <property name="defaultAutoCommit" value="true" />
        <property name="maxTotal" value="${db_max_active}" />
        <property name="maxIdle" value="${db_max_idle}" />
        <property name="maxWaitMillis" value="${db_max_wait}" />
        <property name="testOnBorrow" value="true" />
        <property name="validationQuery" value="${db_validationQuery}" />
        <property name="poolPreparedStatements" value="false" />
    </bean>

    <!-- Transaction-aware DataSource proxy for Hibernate/JPA mixed-mode support.
         During the Hibernate→JPA migration, legacy HibernateDaoSupport DAOs and modern
         JPA EntityManager DAOs coexist. JpaTransactionManager manages the JDBC Connection,
         and this proxy ensures standalone SessionFactory Sessions share the SAME Connection
         so that all writes participate in a single Spring-managed transaction. -->
    <bean id="transactionAwareDataSource"
          class="org.springframework.jdbc.datasource.TransactionAwareDataSourceProxy">
        <constructor-arg ref="dataSource" />
    </bean>

    <!-- Initialize lookup tables after SessionFactory creates schema -->
    <bean id="databaseInitializer" class="org.springframework.jdbc.datasource.init.DataSourceInitializer" depends-on="sessionFactory">
        <property name="dataSource" ref="dataSource"/>
        <property name="databasePopulator">
            <bean class="org.springframework.jdbc.datasource.init.ResourceDatabasePopulator">
                <property name="scripts">
                    <list>
                        <value>classpath:test-lookup-tables.sql</value>
                    </list>
                </property>
                <property name="sqlScriptEncoding" value="UTF-8"/>
            </bean>
        </property>
    </bean>

    <!-- JPA EntityManagerFactory - creates schema for all HBM mappings -->
    <bean id="entityManagerFactory" class="org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean">
        <property name="dataSource" ref="dataSource" />
        <property name="persistenceUnitName" value="entityManagerFactory" />
        <property name="persistenceProvider">
            <bean class="org.hibernate.jpa.HibernatePersistenceProvider" />
        </property>
        <!-- Scan all packages with entities -->
        <property name="packagesToScan">
            <list>
                <value>io.github.carlos_emr.carlos</value>
            </list>
        </property>
        <!-- Include HBM mappings for entities that need them -->
        <property name="mappingResources">
            <list>
                <value>io/github/carlos_emr/carlos/commn/model/Provider.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/commn/model/Demographic.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/Program.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramClientStatus.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramTeam.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramQueue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramProvider.hbm.xml</value>
                <!-- Secuserrole.hbm.xml creates secUserRole table with auto-increment id column.
                     SecUserRole.hbm.xml is excluded from EMF to avoid table conflict (composite key schema).
                     SecUserRole.hbm.xml is still in sessionFactory for DAOs that use composite key reads. -->
                <value>com/quatro/model/security/Secuserrole.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramAccess.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/AccessType.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_issue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/issue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note_ext.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note_link.hbm.xml</value>
                <value>com/quatro/model/security/Secrole.hbm.xml</value>
                <value>com/quatro/model/security/SecProvider.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramFunctionalUser.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/FunctionalUserType.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramClientRestriction.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/DefaultRoleAccess.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ClientReferral.hbm.xml</value>
                <!-- Security model mappings for Hibernate migration tests -->
                <value>com/quatro/model/security/Secobjectname.hbm.xml</value>
                <value>com/quatro/model/security/Secobjprivilege.hbm.xml</value>
                <value>com/quatro/model/security/UserAccessValue.hbm.xml</value>
                <!-- CaseManagement additional mappings -->
                <value>io/github/carlos_emr/carlos/casemgmt/model/ClientImage.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_cpp.hbm.xml</value>
                <!-- PMmodule additional mappings -->
                <value>io/github/carlos_emr/carlos/PMmodule/model/Agency.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramSignature.hbm.xml</value>
            </list>
        </property>
        <property name="jpaVendorAdapter">
            <bean class="org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter">
                <property name="database" value="H2" />
                <property name="showSql" value="false" />
                <property name="generateDdl" value="true" />
            </bean>
        </property>
        <property name="jpaProperties">
            <props>
                <prop key="hibernate.dialect">${hibernate.dialect}</prop>
                <prop key="hibernate.show_sql">true</prop>
                <prop key="hibernate.format_sql">true</prop>
                <!-- Schema creation managed by EntityManagerFactory -->
                <prop key="hibernate.hbm2ddl.auto">create</prop>
                <!-- Use SpringSessionContext so HibernateDaoSupport DAOs share the same session -->
                <prop key="hibernate.current_session_context_class">org.springframework.orm.hibernate5.SpringSessionContext</prop>
                <prop key="hibernate.flushMode">AUTO</prop>
                <prop key="org.hibernate.flushMode">AUTO</prop>
                <prop key="javax.persistence.flush-mode">AUTO</prop>
                <prop key="hibernate.transaction.flush_before_completion">true</prop>
                <prop key="hibernate.transaction.auto_close_session">false</prop>
                <prop key="hibernate.cache.use_second_level_cache">false</prop>
                <prop key="hibernate.id.new_generator_mappings">true</prop>
                <prop key="hibernate.archive.autodetection">class,hbm</prop>
                <prop key="hibernate.ejb.metamodel.population">enabled</prop>
            </props>
        </property>
    </bean>

    <!-- Standalone Hibernate SessionFactory for HibernateDaoSupport DAOs - uses schema from EntityManagerFactory.
         Uses transactionAwareDataSource so Sessions share the same JDBC Connection as
         the JPA EntityManager, enabling both to participate in a single Spring transaction. -->
    <bean id="sessionFactory" class="org.springframework.orm.hibernate5.LocalSessionFactoryBean" depends-on="entityManagerFactory">
        <property name="dataSource" ref="transactionAwareDataSource" />
        <!-- Explicitly list @Entity annotated classes needed for tests -->
        <property name="annotatedClasses">
            <list>
                <value>io.github.carlos_emr.carlos.commn.model.Tickler</value>
                <value>io.github.carlos_emr.carlos.commn.model.TicklerUpdate</value>
                <value>io.github.carlos_emr.carlos.commn.model.TicklerCategory</value>
                <value>io.github.carlos_emr.carlos.commn.model.TicklerComment</value>
                <value>io.github.carlos_emr.carlos.commn.model.CustomFilter</value>
                <value>io.github.carlos_emr.carlos.commn.model.Admission</value>
                <value>io.github.carlos_emr.carlos.commn.model.OscarLog</value>
                <value>io.github.carlos_emr.carlos.commn.model.Facility</value>
                <value>io.github.carlos_emr.carlos.commn.model.DemographicMerged</value>
                <value>io.github.carlos_emr.carlos.form.model.FormRourke2009</value>
                <!-- Healthcare domain entities for manager/DAO integration tests -->
                <value>io.github.carlos_emr.carlos.commn.model.Allergy</value>
                <value>io.github.carlos_emr.carlos.commn.model.Appointment</value>
                <value>io.github.carlos_emr.carlos.commn.model.AppointmentArchive</value>
                <value>io.github.carlos_emr.carlos.commn.model.AppointmentStatus</value>
                <value>io.github.carlos_emr.carlos.commn.model.AppointmentType</value>
                <value>io.github.carlos_emr.carlos.commn.model.Drug</value>
                <value>io.github.carlos_emr.carlos.commn.model.Prescription</value>
                <value>io.github.carlos_emr.carlos.commn.model.Measurement</value>
                <value>io.github.carlos_emr.carlos.commn.model.MeasurementMap</value>
                <value>io.github.carlos_emr.carlos.commn.model.Prevention</value>
                <value>io.github.carlos_emr.carlos.commn.model.PreventionExt</value>
                <value>io.github.carlos_emr.carlos.commn.model.Hl7TextInfo</value>
                <value>io.github.carlos_emr.carlos.commn.model.Hl7TextMessage</value>
                <value>io.github.carlos_emr.carlos.commn.model.PatientLabRouting</value>
                <value>io.github.carlos_emr.carlos.commn.model.ConsultationRequest</value>
                <value>io.github.carlos_emr.carlos.commn.model.ConsultationResponse</value>
                <value>io.github.carlos_emr.carlos.commn.model.ScheduleDate</value>
                <value>io.github.carlos_emr.carlos.commn.model.ScheduleHoliday</value>
                <value>io.github.carlos_emr.carlos.commn.model.ScheduleTemplate</value>
                <value>io.github.carlos_emr.carlos.commn.model.ScheduleTemplateCode</value>
                <value>io.github.carlos_emr.carlos.commn.model.LookupList</value>
                <value>io.github.carlos_emr.carlos.commn.model.LookupListItem</value>
                <value>io.github.carlos_emr.carlos.commn.model.ProfessionalSpecialist</value>
                <value>io.github.carlos_emr.carlos.commn.model.DemographicContact</value>
                <value>io.github.carlos_emr.carlos.commn.model.ConsultationServices</value>
                <value>io.github.carlos_emr.carlos.commn.model.ConsultDocs</value>
                <value>io.github.carlos_emr.carlos.commn.model.ConsultResponseDoc</value>
            </list>
        </property>
        <property name="mappingResources">
            <list>
                <value>io/github/carlos_emr/carlos/commn/model/Provider.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/commn/model/Demographic.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/Program.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramClientStatus.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramTeam.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramQueue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramProvider.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/SecUserRole.hbm.xml</value>
                <value>com/quatro/model/security/Secuserrole.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramAccess.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/AccessType.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_issue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/issue.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note_ext.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_note_link.hbm.xml</value>
                <value>com/quatro/model/security/Secrole.hbm.xml</value>
                <value>com/quatro/model/security/SecProvider.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramFunctionalUser.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/FunctionalUserType.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramClientRestriction.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/DefaultRoleAccess.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ClientReferral.hbm.xml</value>
                <!-- Security model mappings for Hibernate migration tests -->
                <value>com/quatro/model/security/Secobjectname.hbm.xml</value>
                <value>com/quatro/model/security/Secobjprivilege.hbm.xml</value>
                <value>com/quatro/model/security/UserAccessValue.hbm.xml</value>
                <!-- CaseManagement additional mappings -->
                <value>io/github/carlos_emr/carlos/casemgmt/model/ClientImage.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/casemgmt/model/casemgmt_cpp.hbm.xml</value>
                <!-- PMmodule additional mappings -->
                <value>io/github/carlos_emr/carlos/PMmodule/model/Agency.hbm.xml</value>
                <value>io/github/carlos_emr/carlos/PMmodule/model/ProgramSignature.hbm.xml</value>
            </list>
        </property>
        <property name="hibernateProperties">
            <props>
                <prop key="hibernate.dialect">org.hibernate.dialect.H2Dialect</prop>
                <prop key="hibernate.show_sql">true</prop>
                <prop key="hibernate.format_sql">true</prop>
                <!-- Schema already created by EntityManagerFactory - use validate to avoid conflicts -->
                <prop key="hibernate.hbm2ddl.auto">none</prop>
                <prop key="hibernate.current_session_context_class">org.springframework.orm.hibernate5.SpringSessionContext</prop>
                <prop key="hibernate.cache.use_second_level_cache">false</prop>
                <!-- Allow HibernateDaoSupport DAOs to write within JPA-managed transactions.
                     The JDBC Connection IS transactional (managed by JpaTransactionManager via
                     TransactionAwareDataSourceProxy), but Hibernate's Session doesn't know about
                     the JPA transaction. This tells Hibernate to trust the Connection's transaction
                     state instead of requiring a Hibernate-level transaction. -->
                <prop key="hibernate.allow_update_outside_transaction">true</prop>
            </props>
        </property>
    </bean>

    <!-- Configure HibernateTemplate -->
    <bean id="hibernateTemplate" class="org.springframework.orm.hibernate5.HibernateTemplate">
        <property name="sessionFactory" ref="sessionFactory" />
        <property name="checkWriteOperations" value="false" />
    </bean>

    <!-- TransactionManager - JpaTransactionManager coordinates both JPA EntityManager and Hibernate Session -->
    <bean id="transactionManager" class="org.springframework.orm.jpa.JpaTransactionManager">
        <property name="entityManagerFactory" ref="entityManagerFactory" />
        <property name="defaultTimeout" value="60" />
        <property name="nestedTransactionAllowed" value="true" />
    </bean>

    <!-- Enable annotation-driven transactions -->
    <tx:annotation-driven transaction-manager="transactionManager" />

    <!-- Component scanning disabled - we'll manually define beans instead -->
    <!-- This avoids issues with DAOs trying to access SpringUtils during initialization -->

    <!-- Manually define DAOs needed for Tickler tests -->
    <bean id="ticklerDao" class="io.github.carlos_emr.carlos.commn.dao.TicklerDaoImpl" autowire="byName" />
